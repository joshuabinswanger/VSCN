---
import Layout from "../../layouts/Layout.astro";
import InfoPage from "../../components/InfoPage.astro";
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "de" } },
  ];
}

const { lang = "en" } = Astro.params;
const currentLang = (lang || "en") as Lang;
const t = useTranslations(currentLang);

const title = "Info — VSCN";
const description = currentLang === "de"
  ? "Das Visual Science Communication Network verbindet Menschen, die Wissen visualisieren, und baut eine Community an der Schnittstelle von Wissenschaft, Illustration und Design."
  : "The Visual Science Communication Network connects people passionate about visualizing knowledge and builds community where science meets illustration and design.";
---

<Layout
  title={title}
  description={description}
  lang={currentLang}
>
  <InfoPage lang={currentLang} />
</Layout>
