---
import Layout from "../../layouts/Layout.astro";
import OnboardingForm from "../../components/OnboardingForm.astro";
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "de" } },
  ];
}

const { lang = "en" } = Astro.params;
const currentLang = (lang || "en") as Lang;
const t = useTranslations(currentLang);

const title = currentLang === "de" ? "Willkommen bei VSCN" : "Welcome to VSCN";
---

<Layout title={title} noindex lang={currentLang}>
  <OnboardingForm lang={currentLang} />
</Layout>
