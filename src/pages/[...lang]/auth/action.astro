---
import Layout from "../../../layouts/Layout.astro";
import { useTranslations } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/utils";

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "de" } },
  ];
}

const { lang = "en" } = Astro.params;
const currentLang = (lang || "en") as Lang;
const t = useTranslations(currentLang);

const title = currentLang === "de" ? "Konto" : "Account";
---

<Layout title={title} lang={currentLang}>
  <div class="action-wrap">
    <div id="view-loading" class="action-view">
      <p class="state-msg">{currentLang === "de" ? "Bitte warten…" : "Please wait…"}</p>
    </div>

    <div id="view-reset-form" class="action-view" style="display:none;">
      <header class="action-header">
        <h1 class="action-title">{currentLang === "de" ? "Neues Passwort festlegen" : "Set a new password"}</h1>
      </header>
      <form id="reset-form" class="action-form">
        <div class="field">
          <label class="label" for="new-password">{currentLang === "de" ? "Neues Passwort" : "New password"}</label>
          <input id="new-password" type="password" class="input" placeholder="••••••••" required autocomplete="new-password" />
        </div>
        <div class="field">
          <label class="label" for="confirm-password">{currentLang === "de" ? "Passwort bestätigen" : "Confirm password"}</label>
          <input id="confirm-password" type="password" class="input" placeholder="••••••••" required autocomplete="new-password" />
        </div>
        <p id="reset-error" class="msg-err" style="display:none;"></p>
        <div class="action-footer">
          <button type="submit" id="reset-submit" class="btn-solid">{currentLang === "de" ? "Passwort festlegen" : "Set password"}</button>
        </div>
      </form>
    </div>

    <div id="view-success" class="action-view" style="display:none;">
      <header class="action-header">
        <h1 class="action-title" id="success-title"></h1>
        <p class="action-sub" id="success-sub"></p>
      </header>
      <a id="success-link" href={currentLang === "de" ? "/de/signup" : "/signup"} class="btn-solid">{currentLang === "de" ? "Weiter" : "Continue"}</a>
    </div>

    <div id="view-error" class="action-view" style="display:none;">
      <header class="action-header">
        <h1 class="action-title">{currentLang === "de" ? "Link abgelaufen" : "Link expired"}</h1>
        <p class="action-sub">
          {currentLang === "de" 
            ? "Dieser Link ist nicht mehr gültig. Er wurde möglicherweise bereits verwendet oder ist abgelaufen."
            : "This link is no longer valid. It may have already been used or has expired."}
        </p>
      </header>
      <a href={currentLang === "de" ? "/de/signup" : "/signup"} class="btn-solid">{currentLang === "de" ? "Zurück zur Registrierung" : "Back to sign up"}</a>
    </div>
  </div>
</Layout>

<style>
  .action-wrap {
    width: 100%;
    max-width: 500px;
    margin: clamp(2rem, 4vw, 4rem) auto;
    padding: 0 15px;
    box-sizing: border-box;

    @media (--bp-desktop) {
      padding: 0;
    }
  }

  @media (min-width: 560px) {
    .action-wrap {
      background: #fff;
      border: 1.5px solid #ebebeb;
      border-radius: var(--radius-xl);
      padding: clamp(2rem, 4vw, 3rem);
    }
  }

  .action-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .action-title {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-dark);
  }

  .action-sub {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.5;
  }

  .action-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .action-footer {
    display: flex;
    justify-content: flex-end;
    padding-top: 0.5rem;
  }

  .state-msg {
    color: #999;
    font-size: 0.9rem;
  }
</style>

<script>
  import { auth } from "../../../lib/firebase.ts";
  import {
    applyActionCode,
    confirmPasswordReset,
    verifyPasswordResetCode,
  } from "firebase/auth";
  import { publishCurrentUserProfile } from "../../../lib/firestore.ts";

  const params = new URLSearchParams(window.location.search);
  const mode = params.get("mode");
  const oobCode = params.get("oobCode");

  // Determine language from the URL path
  const lang = window.location.pathname.startsWith("/de/") ? "de" : "en";
  const prefix = lang === "de" ? "/de" : "";

  function showView(id: string) {
    document.querySelectorAll<HTMLElement>(".action-view").forEach((v) => {
      v.style.display = "none";
    });
    const el = document.getElementById(id);
    if (el) el.style.display = "block";
  }

  function showSuccess(title: string, sub: string, href = "/signup") {
    document.getElementById("success-title")!.textContent = title;
    document.getElementById("success-sub")!.textContent = sub;
    (document.getElementById("success-link") as HTMLAnchorElement).href = prefix + href;
    showView("view-success");
  }

  document.addEventListener("astro:page-load", async () => {
    if (!oobCode) {
      showView("view-error");
      return;
    }

    if (mode === "verifyEmail") {
      try {
        await applyActionCode(auth, oobCode);
        const user = auth.currentUser;
        if (user) {
          await user.reload();
          await user.getIdToken(true);
          await publishCurrentUserProfile(user.uid);
        }
        showSuccess(
          lang === "de" ? "E-Mail verifiziert!" : "Email verified!",
          lang === "de" 
            ? "Ihr Konto ist jetzt aktiv. Weiter zur Community." 
            : "Your account is now active. Continue to the community.",
          "/community",
        );
      } catch {
        showView("view-error");
      }

    } else if (mode === "resetPassword") {
      try {
        await verifyPasswordResetCode(auth, oobCode);
        showView("view-reset-form");

        const form = document.getElementById("reset-form") as HTMLFormElement;
        const submitBtn = document.getElementById("reset-submit") as HTMLButtonElement;
        const errorEl = document.getElementById("reset-error")!;

        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          const newPw = (document.getElementById("new-password") as HTMLInputElement).value;
          const confirmPw = (document.getElementById("confirm-password") as HTMLInputElement).value;

          errorEl.style.display = "none";

          if (newPw !== confirmPw) {
            errorEl.textContent = lang === "de" ? "Passwörter stimmen nicht überein." : "Passwords don't match.";
            errorEl.style.display = "block";
            return;
          }
          if (newPw.length < 6) {
            errorEl.textContent = lang === "de" ? "Das Passwort muss mindestens 6 Zeichen lang sein." : "Password must be at least 6 characters.";
            errorEl.style.display = "block";
            return;
          }

          submitBtn.disabled = true;
          submitBtn.textContent = lang === "de" ? "Speichern…" : "Saving…";

          try {
            await confirmPasswordReset(auth, oobCode, newPw);
            showSuccess(
              lang === "de" ? "Passwort aktualisiert!" : "Password updated!",
              lang === "de"
                ? "Sie können sich jetzt mit Ihrem neuen Passwort anmelden."
                : "You can now sign in with your new password.",
              "/signup",
            );
          } catch {
            errorEl.textContent = lang === "de" 
              ? "Passwort konnte nicht festgelegt werden. Der Link ist möglicherweise abgelaufen."
              : "Could not set password. The link may have expired.";
            errorEl.style.display = "block";
            submitBtn.disabled = false;
            submitBtn.textContent = lang === "de" ? "Passwort festlegen" : "Set password";
          }
        });
      } catch {
        showView("view-error");
      }

    } else if (mode === "recoverEmail") {
      try {
        await applyActionCode(auth, oobCode);
        showSuccess(
          lang === "de" ? "E-Mail wiederhergestellt" : "Email recovered",
          lang === "de"
            ? "Ihre ursprüngliche E-Mail-Adresse wurde wiederhergestellt. Bitte melden Sie sich erneut an."
            : "Your original email address has been restored. Please sign in again.",
          "/signup",
        );
      } catch {
        showView("view-error");
      }

    } else {
      showView("view-error");
    }
  });
</script>
