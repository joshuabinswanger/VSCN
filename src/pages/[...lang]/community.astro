---
import { cert, getApps, initializeApp } from "firebase-admin/app";
import { getFirestore } from "firebase-admin/firestore";
import Layout from "../../layouts/Layout.astro";
import CommunityGrid from "../../components/CommunityGrid.astro";
import type { PublicProfileDoc } from "../../lib/firestore.ts";
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "de" } },
  ];
}

const { lang = "en" } = Astro.params;
const currentLang = (lang || "en") as Lang;
const t = useTranslations(currentLang);

type Member = PublicProfileDoc & { uid: string };
let members: Member[] = [];

try {
  const serviceAccountJson = process.env.FIREBASE_SERVICE_ACCOUNT;
  if (!serviceAccountJson) throw new Error("FIREBASE_SERVICE_ACCOUNT env var not set");

  const app =
    getApps().length === 0
      ? initializeApp({ credential: cert(JSON.parse(serviceAccountJson)) })
      : getApps()[0];

  const adminDb = getFirestore(app);
  const snap = await adminDb.collection("publicProfiles").orderBy("displayName").get();

  members = snap.docs
    .filter((d) => d.data().active !== false)
    .map((d) => ({
      uid: d.id,
      ...(d.data() as PublicProfileDoc),
    }));
  console.log(`[community] Fetched ${members.length} members using Admin SDK.`);
} catch (err) {
  console.error("[community] Failed to fetch members at build time:", err);
}

const title = currentLang === "de" ? "Community — VSCN" : "Community — VSCN";
const description = currentLang === "de"
  ? "Entdecken Sie die VSCN-Community — ein wachsendes Verzeichnis von Wissenschaftlern, Illustratoren, Designern und Wissenschaftskommunikatoren."
  : "Browse the VSCN community — a growing directory of scientists, illustrators, designers, and science communicators.";
---

<Layout
  title={title}
  description={description}
  lang={currentLang}
>
  <CommunityGrid members={members} lang={currentLang} />
</Layout>
