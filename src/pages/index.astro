---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home">
  <h1>Welcome to the Community</h1>
  <p style="margin-top: 1rem; color: #555; max-width: 520px;">
    A place to connect, share, and learn together. Join us to be part of the conversation.
  </p>

  <div style="margin-top: 2rem; display: flex; gap: 1rem;">
    <a href="/signup" style="padding: 0.6rem 1.2rem; background: #111; color: #fff; text-decoration: none; border-radius: 4px;">
      Join Now
    </a>
    <a href="/info" style="padding: 0.6rem 1.2rem; border: 1px solid #ccc; text-decoration: none; border-radius: 4px; color: #333;">
      Learn More
    </a>
  </div>
</Layout>
