---
import Layout from "../layouts/Layout.astro";
---

<Layout title="VSCN — Visual Science Communication Network" fullscreen>

  <div class="scene">

    <!-- 7 repeating ticker rows filling the full background -->
    <div class="tickers">
      {[60, 68, 76, 84, 92, 100, 108].map((speed) => (
        <div class="ticker-row">
          <div class="ticker-track" style={`animation-duration: ${speed}s`}>
            {["VSCN","VSCN","VSCN","VSCN","VSCN","VSCN","VSCN","VSCN",
              "VSCN","VSCN","VSCN","VSCN","VSCN","VSCN","VSCN","VSCN"].map((t) => (
              <span>{t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Content overlay -->
    <div class="content">
      <div class="card">
        <p class="desc">
          <strong>VSCN</strong> — Visual Science Communication Network — is a community of illustrators, scientists, designers, and storytellers who care about making knowledge look as good as it feels to understand.
          <br /><br />
          We're just getting started — come join us!
        </p>
        <div class="actions">
          <a href="/signup" class="btn-primary">Join the Network</a>
          <a href="/community" class="btn-ghost">Community</a>
          <a href="/profile" class="btn-ghost">Profile</a>
        </div>
      </div>
    </div>

  </div>

</Layout>

<style>
  /* Scene fills the full viewport — nav floats above via sticky+z-index */
  .scene {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  /* ── Ticker background ── */
  .tickers {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
  }

  .ticker-row {
    flex: 1;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .ticker-track {
    display: flex;
    gap: 0;
    white-space: nowrap;
    width: max-content;
    animation: scroll 45s linear infinite;
  }

  .ticker-track span {
    font-family: var(--font-space-mono), monospace;
    font-size: 12vh;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-dark);
    user-select: none;
  }

  @keyframes scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Full-height gradient overlay ── */
  .scene::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 15%,
      rgba(250,250,250,0.95) 15%,   /* fafafa */
      var(--color-bg) 95%
    );
    pointer-events: none;
  }

  /* ── Content overlay ── */
  .content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 2.5rem;
    z-index: 1;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem 2.25rem;
    max-width: 520px;
    width: 100%;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1.5px solid rgba(0, 0, 0, 0.08);
    border-radius: 14px;
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.07);
  }

  .desc {
    font-family: system-ui, sans-serif;
    font-weight: 400;
    font-size: clamp(0.85rem, 2vw, 1rem);
    color: #111;
    line-height: 1.8;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

</style>
