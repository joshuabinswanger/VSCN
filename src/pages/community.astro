---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Community" navLinks={false}>

  <div class="page-header">
    <h1 class="page-title">Community</h1>
    <p class="page-sub">Everyone in the Visual Science Communication Network</p>
  </div>

  <div id="members" class="member-grid">
    <p class="state-msg">Loading members…</p>
  </div>

</Layout>

<style is:global>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    font-family: 'Space Mono', monospace;
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #0a0a0a;
  }

  .page-sub {
    margin-top: 0.35rem;
    font-size: 0.9rem;
    color: #888;
  }

  .member-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .state-msg { color: #999; font-size: 0.9rem; }

  /* injected cards */
  .member-card {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border: 1.5px solid #e8e8e8;
    border-radius: 10px;
    background: #fafafa;
    transition: border-color 0.15s;
  }

  .member-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .member-card:hover { border-color: #aaa; }

  .member-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #f0f0f0;
    border: 1.5px solid #e5e5e5;
    flex-shrink: 0;
    /* for div fallback */
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    color: #bbb;
  }

  img.member-avatar {
    object-fit: cover;
    display: block;
  }

  .member-name {
    font-weight: 700;
    font-size: 0.95rem;
    color: #0a0a0a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .member-role {
    font-size: 0.8rem;
    color: #777;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .member-portfolio {
    display: inline-block;
    margin-top: 0.25rem;
    font-size: 0.8rem;
    color: #555;
    text-decoration: none;
    text-decoration: none;
    word-break: break-all;
    transition: color 0.15s, border-color 0.15s;
  }

  .member-portfolio:hover { color: #000; }
</style>

<script>
  import { db } from "../lib/firebase.ts";
  import { collection, getDocs, orderBy, query } from "firebase/firestore";

  const grid = document.getElementById("members")!;

  function normaliseUrl(raw: string): string {
    if (!raw) return "";
    return raw.startsWith("http") ? raw : `https://${raw}`;
  }

  function avatarHtml(photoURL: string, name: string): string {
    if (photoURL) {
      return `<img class="member-avatar" src="${photoURL}" alt="${name}" onerror="this.outerHTML=this.nextElementSibling.outerHTML;this.nextElementSibling.remove()">`;
    }
    const initial = name?.[0]?.toUpperCase() ?? "?";
    return `<div class="member-avatar">${initial}</div>`;
  }

  async function loadMembers() {
    try {
      const snap = await getDocs(query(collection(db, "users"), orderBy("displayName")));

      if (snap.empty) {
        grid.innerHTML = "<p class='state-msg'>No members yet.</p>";
        return;
      }

      grid.innerHTML = snap.docs.map((doc) => {
        const d = doc.data();
        const name      = d.displayName || "Anonymous";
        const role      = d.role ?? "";
        const portfolio = d.portfolio ?? "";
        const photoURL  = d.photoURL ?? "";
        const href      = normaliseUrl(portfolio);

        const portfolioLink = href
          ? `<a class="member-portfolio" href="${href}" target="_blank" rel="noopener">${portfolio}</a>`
          : "";

        return `
          <div class="member-card">
            ${avatarHtml(photoURL, name)}
            <div class="member-info">
              <div class="member-name">${name}</div>
              ${role ? `<div class="member-role">${role}</div>` : ""}
              ${portfolioLink}
            </div>
          </div>`;
      }).join("");

    } catch (err) {
      grid.innerHTML = "<p class='state-msg' style='color:#d94f4f'>Could not load members.</p>";
      console.error(err);
    }
  }

  loadMembers();
</script>
