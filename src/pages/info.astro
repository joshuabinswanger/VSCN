---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Info">
  <h1>About This Community</h1>

  <section style="margin-top: 1.5rem;">
    <h2>What we are</h2>
    <p style="margin-top: 0.5rem; color: #555;">
      We are a community of [describe your community here]. Fill this section with
      your mission, values, or whatever best describes who you are.
    </p>
  </section>

  <section style="margin-top: 2rem;">
    <h2>Rules</h2>
    <ol style="margin-top: 0.5rem; padding-left: 1.4rem; color: #555; display: flex; flex-direction: column; gap: 0.4rem;">
      <li>Be respectful to other members.</li>
      <li>No spam or self-promotion without permission.</li>
      <li>Keep discussions on topic.</li>
      <li>Add your own rules here.</li>
    </ol>
  </section>

  <section style="margin-top: 2rem;">
    <h2>Contact</h2>
    <p style="margin-top: 0.5rem; color: #555;">
      Reach us at <a href="mailto:hello@example.com">hello@example.com</a>
    </p>
  </section>
</Layout>
