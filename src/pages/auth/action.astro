---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Account">
  <div class="action-wrap">
    <div id="view-loading" class="action-view">
      <p class="state-msg">Please wait…</p>
    </div>

    <div id="view-reset-form" class="action-view" style="display:none;">
      <header class="action-header">
        <h1 class="action-title">Set a new password</h1>
      </header>
      <form id="reset-form" class="action-form">
        <div class="field">
          <label class="label" for="new-password">New password</label>
          <input id="new-password" type="password" class="input" placeholder="••••••••" required autocomplete="new-password" />
        </div>
        <div class="field">
          <label class="label" for="confirm-password">Confirm password</label>
          <input id="confirm-password" type="password" class="input" placeholder="••••••••" required autocomplete="new-password" />
        </div>
        <p id="reset-error" class="msg-err" style="display:none;"></p>
        <div class="action-footer">
          <button type="submit" id="reset-submit" class="btn-solid">Set password</button>
        </div>
      </form>
    </div>

    <div id="view-success" class="action-view" style="display:none;">
      <header class="action-header">
        <h1 class="action-title" id="success-title"></h1>
        <p class="action-sub" id="success-sub"></p>
      </header>
      <a id="success-link" href="/signup" class="btn-solid">Continue</a>
    </div>

    <div id="view-error" class="action-view" style="display:none;">
      <header class="action-header">
        <h1 class="action-title">Link expired</h1>
        <p class="action-sub">
          This link is no longer valid. It may have already been used or has expired.
        </p>
      </header>
      <a href="/signup" class="btn-solid">Back to sign up</a>
    </div>
  </div>
</Layout>

<style>
  .action-wrap {
    width: 100%;
    max-width: 500px;
    margin: clamp(2rem, 4vw, 4rem) auto;
    padding: 0 15px;
    box-sizing: border-box;

    @media (--bp-desktop) {
      padding: 0;
    }
  }

  @media (min-width: 560px) {
    .action-wrap {
      background: #fff;
      border: 1.5px solid #ebebeb;
      border-radius: var(--radius-xl);
      padding: clamp(2rem, 4vw, 3rem);
    }
  }

  .action-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .action-title {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-dark);
  }

  .action-sub {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.5;
  }

  .action-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .action-footer {
    display: flex;
    justify-content: flex-end;
    padding-top: 0.5rem;
  }

  .state-msg {
    color: #999;
    font-size: 0.9rem;
  }
</style>

<script>
  import { auth } from "../../lib/firebase.ts";
  import {
    applyActionCode,
    confirmPasswordReset,
    verifyPasswordResetCode,
  } from "firebase/auth";
  import { publishCurrentUserProfile } from "../../lib/firestore.ts";

  const params = new URLSearchParams(window.location.search);
  const mode = params.get("mode");
  const oobCode = params.get("oobCode");

  function showView(id: string) {
    document.querySelectorAll<HTMLElement>(".action-view").forEach((v) => {
      v.style.display = "none";
    });
    const el = document.getElementById(id);
    if (el) el.style.display = "block";
  }

  function showSuccess(title: string, sub: string, href = "/signup") {
    document.getElementById("success-title")!.textContent = title;
    document.getElementById("success-sub")!.textContent = sub;
    (document.getElementById("success-link") as HTMLAnchorElement).href = href;
    showView("view-success");
  }

  document.addEventListener("astro:page-load", async () => {
    if (!oobCode) {
      showView("view-error");
      return;
    }

    if (mode === "verifyEmail") {
      try {
        await applyActionCode(auth, oobCode);
        const user = auth.currentUser;
        if (user) {
          await user.reload();
          await user.getIdToken(true);
          await publishCurrentUserProfile(user.uid);
        }
        showSuccess(
          "Email verified!",
          "Your account is now active. Continue to the community.",
          "/community",
        );
      } catch {
        showView("view-error");
      }

    } else if (mode === "resetPassword") {
      try {
        await verifyPasswordResetCode(auth, oobCode);
        showView("view-reset-form");

        const form = document.getElementById("reset-form") as HTMLFormElement;
        const submitBtn = document.getElementById("reset-submit") as HTMLButtonElement;
        const errorEl = document.getElementById("reset-error")!;

        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          const newPw = (document.getElementById("new-password") as HTMLInputElement).value;
          const confirmPw = (document.getElementById("confirm-password") as HTMLInputElement).value;

          errorEl.style.display = "none";

          if (newPw !== confirmPw) {
            errorEl.textContent = "Passwords don't match.";
            errorEl.style.display = "block";
            return;
          }
          if (newPw.length < 6) {
            errorEl.textContent = "Password must be at least 6 characters.";
            errorEl.style.display = "block";
            return;
          }

          submitBtn.disabled = true;
          submitBtn.textContent = "Saving…";

          try {
            await confirmPasswordReset(auth, oobCode, newPw);
            showSuccess(
              "Password updated!",
              "You can now sign in with your new password.",
              "/signup",
            );
          } catch {
            errorEl.textContent = "Could not set password. The link may have expired.";
            errorEl.style.display = "block";
            submitBtn.disabled = false;
            submitBtn.textContent = "Set password";
          }
        });
      } catch {
        showView("view-error");
      }

    } else if (mode === "recoverEmail") {
      try {
        await applyActionCode(auth, oobCode);
        showSuccess(
          "Email recovered",
          "Your original email address has been restored. Please sign in again.",
          "/signup",
        );
      } catch {
        showView("view-error");
      }

    } else {
      showView("view-error");
    }
  });
</script>
