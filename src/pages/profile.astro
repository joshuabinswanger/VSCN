---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Edit Profile" navLinks={false}>

  <div id="loading" class="loading-state">Loading profile…</div>

  <form id="profile-form" class="profile-form" style="display:none;">

    <header class="form-header">
      <div class="avatar-wrap">
        <img id="avatar-preview" src="" alt="" class="avatar-img" style="display:none;" />
        <div id="avatar-placeholder" class="avatar-placeholder">?</div>
      </div>
      <div>
        <h1 class="form-title">Edit Profile</h1>
        <p class="form-sub">How you appear to the community</p>
      </div>
    </header>

    <hr class="divider" />

    <!-- Display name -->
    <div class="field">
      <label class="label" for="name">Display Name</label>
      <input id="name" type="text" class="input" placeholder="Your name" />
    </div>

    <!-- Role / what you do -->
    <div class="field">
      <label class="label" for="role">What you do</label>
      <input id="role" type="text" class="input" placeholder="e.g. Science Illustrator, Data Journalist, Researcher…" />
    </div>

    <!-- Bio -->
    <div class="field">
      <label class="label" for="bio">About you</label>
      <textarea id="bio" rows="4" class="input textarea" placeholder="A short description of your work, interests, or background…"></textarea>
    </div>

    <!-- Portfolio -->
    <div class="field">
      <label class="label" for="portfolio">Portfolio / Website</label>
      <div class="input-prefix-wrap">
        <span class="input-prefix">https://</span>
        <input id="portfolio" type="text" class="input input-prefixed" placeholder="yoursite.com" />
      </div>
    </div>

    <!-- Avatar upload -->
    <div class="field">
      <label class="label">Profile Image</label>
      <label class="file-btn" for="avatar">
        Choose image
        <input id="avatar" type="file" accept="image/*" style="display:none;" />
      </label>
      <p id="upload-status" class="upload-status" style="display:none;"></p>
    </div>

    <hr class="divider" />

    <div class="form-footer">
      <p id="save-msg" class="msg-ok" style="display:none;">Changes saved.</p>
      <p id="save-error" class="msg-err" style="display:none;"></p>
      <div class="footer-actions">
        <button id="btn-logout" type="button" class="btn-logout">Log Out</button>
        <button type="submit" class="btn-save">Save Changes</button>
      </div>
    </div>

  </form>

</Layout>

<style>
  /* ── Layout ── */
  .loading-state {
    margin-top: 3rem;
    color: #999;
    font-size: 0.9rem;
  }

  .profile-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    max-width: 480px;
    margin: 2rem auto;
    padding: 0;
    box-sizing: border-box;
    overflow: hidden;
  }

  /* ── Header ── */
  .form-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .avatar-wrap { position: relative; flex-shrink: 0; }

  .avatar-img,
  .avatar-placeholder {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
  }

  .avatar-placeholder {
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: #bbb;
    border: 1.5px solid #e5e5e5;
  }

  .form-title {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #0a0a0a;
  }

  .form-sub {
    font-size: 0.85rem;
    color: #888;
    margin-top: 0.2rem;
  }

  .divider {
    border: none;
    border-top: 1px solid #eee;
    margin: 0;
  }

  /* ── Fields ── */
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .label {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #555;
  }

  .input {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    padding: 0.7rem 0.9rem;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    font: inherit;
    font-size: 0.95rem;
    color: #111;
    background: #fafafa;
    transition: border-color 0.15s;
    outline: none;
  }

  .input:focus { border-color: #111; }
  .input::placeholder { color: #bbb; }

  .textarea { resize: vertical; min-height: 96px; }

  /* Portfolio prefix */
  .input-prefix-wrap {
    display: flex;
    align-items: center;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.15s;
    width: 100%;
    min-width: 0;
  }

  .input-prefix-wrap:focus-within { border-color: #111; }

  .input-prefix {
    padding: 0.7rem 0.75rem;
    background: #f5f5f5;
    color: #888;
    font-size: 0.88rem;
    border-right: 1.5px solid #e0e0e0;
    white-space: nowrap;
  }

  .input-prefixed {
    border: none;
    border-radius: 0;
    flex: 1;
    min-width: 0;
  }

  .input-prefixed:focus { border-color: transparent; }

  /* File button */
  .file-btn {
    display: inline-block;
    padding: 0.65rem 1.2rem;
    border: 1.5px solid #ddd;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    color: #333;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    width: fit-content;
  }

  .file-btn:hover { border-color: #111; background: #f9f9f9; }

  .upload-status {
    font-size: 0.82rem;
    color: #666;
  }

  /* ── Footer ── */
  .form-footer {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .btn-logout {
    padding: 0.75rem 1.5rem;
    background: transparent;
    color: #888;
    border: 1.5px solid #ddd;
    border-radius: 8px;
    font: inherit;
    font-size: 0.95rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-logout:hover { border-color: #aaa; color: #333; }

  .btn-save {
    padding: 0.75rem 2rem;
    background: #0a0a0a;
    color: #fff;
    border: none;
    border-radius: 8px;
    font: inherit;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
    margin-left: auto;
  }

  .btn-save:hover { background: #333; }

  .msg-ok  { font-size: 0.88rem; color: #2a9d5c; }
  .msg-err { font-size: 0.88rem; color: #d94f4f; }
</style>

<script>
  import { auth, db, storage } from "../lib/firebase.ts";
  import { onAuthStateChanged, updateProfile, signOut } from "firebase/auth";
  import { doc, getDoc, setDoc } from "firebase/firestore";
  import { ref, uploadBytesResumable, getDownloadURL } from "firebase/storage";

  const loadingEl        = document.getElementById("loading")!;
  const form             = document.getElementById("profile-form") as HTMLFormElement;
  const nameInput        = document.getElementById("name") as HTMLInputElement;
  const roleInput        = document.getElementById("role") as HTMLInputElement;
  const bioInput         = document.getElementById("bio") as HTMLTextAreaElement;
  const portfolioInput   = document.getElementById("portfolio") as HTMLInputElement;
  const avatarInput      = document.getElementById("avatar") as HTMLInputElement;
  const avatarImg        = document.getElementById("avatar-preview") as HTMLImageElement;
  const avatarPlaceholder = document.getElementById("avatar-placeholder")!;
  const uploadStatus     = document.getElementById("upload-status")!;
  const saveMsg          = document.getElementById("save-msg")!;
  const saveError        = document.getElementById("save-error")!;

  function showPreview(url: string) {
    if (url) {
      avatarImg.src = url;
      avatarImg.style.display = "block";
      avatarPlaceholder.style.display = "none";
      avatarImg.onerror = () => {
        avatarImg.style.display = "none";
        avatarPlaceholder.style.display = "flex";
      };
    } else {
      avatarImg.style.display = "none";
      avatarPlaceholder.style.display = "flex";
    }
  }

  avatarInput.addEventListener("change", () => {
    const file = avatarInput.files?.[0];
    if (file) {
      showPreview(URL.createObjectURL(file));
      uploadStatus.textContent = `Selected: ${file.name}`;
      uploadStatus.style.display = "block";
    }
  });

  onAuthStateChanged(auth, async (user) => {
    if (!user) { window.location.href = "/signup"; return; }
    if (!user.emailVerified) { window.location.href = "/verify-email"; return; }

    const snap = await getDoc(doc(db, "users", user.uid));
    const data = snap.exists() ? snap.data() : {};

    nameInput.value      = data.displayName ?? user.displayName ?? "";
    roleInput.value      = data.role ?? "";
    bioInput.value       = data.bio ?? "";
    portfolioInput.value = data.portfolio ?? "";
    showPreview(data.photoURL ?? user.photoURL ?? "");

    loadingEl.style.display = "none";
    form.style.display = "flex";
  });

  async function uploadAvatar(uid: string, file: File): Promise<string> {
    const ext = file.name.split(".").pop();
    const storageRef = ref(storage, `avatars/${uid}.${ext}`);
    return new Promise((resolve, reject) => {
      const task = uploadBytesResumable(storageRef, file);
      task.on("state_changed",
        (snap) => {
          const pct = Math.round((snap.bytesTransferred / snap.totalBytes) * 100);
          uploadStatus.textContent = `Uploading… ${pct}%`;
          uploadStatus.style.display = "block";
        },
        reject,
        async () => resolve(await getDownloadURL(task.snapshot.ref))
      );
    });
  }

  document.getElementById("btn-logout")!.addEventListener("click", async () => {
    await signOut(auth);
    window.location.href = "/";
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    saveMsg.style.display = "none";
    saveError.style.display = "none";

    const user = auth.currentUser;
    if (!user) return;

    const name      = nameInput.value.trim();
    const role      = roleInput.value.trim();
    const bio       = bioInput.value.trim();
    const portfolio = portfolioInput.value.trim();
    const file      = avatarInput.files?.[0];

    try {
      let photoURL: string = auth.currentUser?.photoURL ?? "";
      if (file) {
        photoURL = await uploadAvatar(user.uid, file);
        uploadStatus.textContent = "Upload complete.";
      }

      await updateProfile(user, {
        displayName: name || null,
        photoURL: photoURL || null,
      });

      await setDoc(doc(db, "users", user.uid), {
        displayName: name,
        photoURL,
        role,
        bio,
        portfolio,
        email: user.email,
        updatedAt: new Date(),
      }, { merge: true });

      saveMsg.style.display = "block";
      setTimeout(() => { saveMsg.style.display = "none"; }, 3000);
    } catch (err: any) {
      saveError.textContent = err.message;
      saveError.style.display = "block";
    }
  });
</script>
