---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Sign Up" navLinks={false}>

  <div class="auth-wrap">

    <header class="auth-header">
      <h1 id="auth-title" class="auth-title">Create an Account</h1>
      <p class="auth-sub">
        Already have one?
        <a href="#" id="toggle-link" class="toggle-link">Log in instead</a>
      </p>
    </header>

    <form id="auth-form" class="auth-form">

      <div id="signup-fields">

        <div class="field">
          <label class="label" for="name">Display Name</label>
          <input id="name" type="text" class="input" placeholder="Your name" />
        </div>

        <div class="field">
          <label class="label">Profile Image</label>
          <div class="avatar-row">
            <img id="avatar-preview" src="" alt="" class="avatar-preview" style="display:none;" />
            <label class="file-btn" for="avatar">
              Choose image
              <input id="avatar" type="file" accept="image/*" style="display:none;" />
            </label>
          </div>
          <p id="upload-status" class="upload-status" style="display:none;"></p>
        </div>

        <div class="field">
          <label class="label" for="bio">About you</label>
          <textarea id="bio" class="input textarea" rows="3" placeholder="A short description about yourself…"></textarea>
        </div>

      </div>

      <div class="field">
        <label class="label" for="email">Email</label>
        <input id="email" type="email" class="input" placeholder="you@example.com" required autocomplete="email" />
      </div>

      <div class="field">
        <label class="label" for="password">Password</label>
        <input id="password" type="password" class="input" placeholder="••••••••" required autocomplete="current-password" />
      </div>

      <p id="auth-error" class="msg-err" style="display:none;"></p>

      <button id="submit-btn" type="submit" class="btn-save">Sign Up</button>

    </form>
  </div>

</Layout>

<style>
  .auth-wrap {
    width: 100%;
    max-width: 440px;
    margin: 2.5rem auto;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .auth-header { display: flex; flex-direction: column; gap: 0.3rem; }

  .auth-title {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #0a0a0a;
  }

  .auth-sub { font-size: 0.88rem; color: #888; }

  .toggle-link {
    color: #0a0a0a;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid #ccc;
    transition: border-color 0.15s;
  }
  .toggle-link:hover { border-color: #0a0a0a; }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .field { display: flex; flex-direction: column; gap: 0.45rem; }

  .label {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #555;
  }

  .input {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    padding: 0.7rem 0.9rem;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    font: inherit;
    font-size: 0.95rem;
    color: #111;
    background: #fafafa;
    transition: border-color 0.15s;
    outline: none;
  }
  .input:focus { border-color: #111; }
  .input::placeholder { color: #bbb; }
  .textarea { resize: vertical; min-height: 80px; }

  .avatar-row { display: flex; align-items: center; gap: 1rem; }

  .avatar-preview {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 1.5px solid #e5e5e5;
    flex-shrink: 0;
  }

  .file-btn {
    display: inline-block;
    padding: 0.6rem 1.1rem;
    border: 1.5px solid #ddd;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    color: #333;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .file-btn:hover { border-color: #111; background: #f4f4f4; }

  .upload-status { font-size: 0.82rem; color: #666; }

  .btn-save {
    padding: 0.78rem 2rem;
    background: #0a0a0a;
    color: #fff;
    border: none;
    border-radius: 8px;
    font: inherit;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
    align-self: flex-start;
  }
  .btn-save:hover { background: #333; }

  .msg-err { font-size: 0.88rem; color: #d94f4f; }
</style>

<script>
  import { auth, db, storage } from "../lib/firebase.ts";
  import {
    createUserWithEmailAndPassword,
    signInWithEmailAndPassword,
    updateProfile,
  } from "firebase/auth";
  import { doc, setDoc } from "firebase/firestore";
  import { ref, uploadBytesResumable, getDownloadURL } from "firebase/storage";

  let isLogin = false;

  const form         = document.getElementById("auth-form") as HTMLFormElement;
  const toggleLink   = document.getElementById("toggle-link")!;
  const signupFields = document.getElementById("signup-fields")!;
  const submitBtn    = document.getElementById("submit-btn")!;
  const authTitle    = document.getElementById("auth-title")!;
  const errorEl      = document.getElementById("auth-error")!;
  const avatarInput  = document.getElementById("avatar") as HTMLInputElement;
  const avatarPreview = document.getElementById("avatar-preview") as HTMLImageElement;
  const uploadStatus = document.getElementById("upload-status")!;

  avatarInput.addEventListener("change", () => {
    const file = avatarInput.files?.[0];
    if (file) {
      avatarPreview.src = URL.createObjectURL(file);
      avatarPreview.style.display = "block";
      uploadStatus.textContent = `Selected: ${file.name}`;
      uploadStatus.style.display = "block";
    }
  });

  toggleLink.addEventListener("click", (e) => {
    e.preventDefault();
    isLogin = !isLogin;
    signupFields.style.display = isLogin ? "none" : "flex";
    submitBtn.textContent      = isLogin ? "Log In" : "Sign Up";
    toggleLink.textContent     = isLogin ? "Sign up instead" : "Log in instead";
    authTitle.textContent      = isLogin ? "Log In" : "Create an Account";
    errorEl.style.display      = "none";
  });

  async function uploadAvatar(uid: string, file: File): Promise<string> {
    const ext = file.name.split(".").pop();
    const storageRef = ref(storage, `avatars/${uid}.${ext}`);
    return new Promise((resolve, reject) => {
      const task = uploadBytesResumable(storageRef, file);
      task.on("state_changed",
        (snap) => {
          const pct = Math.round((snap.bytesTransferred / snap.totalBytes) * 100);
          uploadStatus.textContent = `Uploading… ${pct}%`;
          uploadStatus.style.display = "block";
        },
        reject,
        async () => resolve(await getDownloadURL(task.snapshot.ref))
      );
    });
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.style.display = "none";

    const email    = (document.getElementById("email") as HTMLInputElement).value;
    const password = (document.getElementById("password") as HTMLInputElement).value;
    const name     = (document.getElementById("name") as HTMLInputElement).value;
    const bio      = (document.getElementById("bio") as HTMLTextAreaElement).value.trim();
    const file     = avatarInput.files?.[0];

    try {
      if (isLogin) {
        await signInWithEmailAndPassword(auth, email, password);
      } else {
        const { user } = await createUserWithEmailAndPassword(auth, email, password);
        let photoURL = "";
        if (file) photoURL = await uploadAvatar(user.uid, file);
        await updateProfile(user, { displayName: name || null, photoURL: photoURL || null });
        await setDoc(doc(db, "users", user.uid), {
          displayName: name || "",
          photoURL,
          bio,
          email: user.email,
          createdAt: new Date(),
        });
      }
      window.location.href = "/community";
    } catch (err: any) {
      errorEl.textContent = err.message;
      errorEl.style.display = "block";
    }
  });
</script>
