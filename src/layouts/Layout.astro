---
import { ClientRouter } from "astro:transitions";
import Navbar from "../components/Navbar.astro";
import GsapTextHeadline from "../components/GsapTextHeadline.astro";
import favicon from "../assets/favicon.png";
import ogImageAsset from "../assets/OG_Image.png";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  fullscreen?: boolean;
  lang?: string;
}

const { title, description, noindex = false, fullscreen = false, lang = "en" } = Astro.props;

const DEFAULT_DESCRIPTION =
  "VSCN — Visual Science Communication Network — brings together illustrators, scientists, designers, and storytellers dedicated to making knowledge visible.";

const metaDescription = description ?? DEFAULT_DESCRIPTION;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImageAsset.src, Astro.site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={favicon.src} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VSCN" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <ClientRouter />
  </head>
  <body>
    <div class="brand-ticker" transition:persist>
      <a href="/" class="brand-link">
        <GsapTextHeadline />
      </a>
    </div>
    <div class="page-wrap">
      <Navbar />
      {
        fullscreen ? (
          <slot />
        ) : (
          <main>
            <slot />
          </main>
        )
      }
    </div>
  </body>
</html>

<style>
  .page-wrap {
    padding-bottom: 80px;
  }

  .brand-ticker {
    display: block;
    width: 100%;
    overflow: hidden;
    flex-shrink: 0;
    box-sizing: border-box;
  }

  .brand-link {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .brand-link:visited {
    color: black;
  }

  :global(.brand-ticker .gsap-text-headline) {
    --gsap-text-headline-width: 900px;
  }

  @media (--bp-mobile) {
    .brand-ticker {
      padding-right: 5px;
      padding-left: 5px;
    }

    :global(.brand-ticker .gsap-text-headline) {
      --gsap-text-headline-width: calc(100vw - 10px);
    }
  }
</style>
