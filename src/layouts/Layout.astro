---
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import Navbar from "../components/Navbar.astro";
interface Props {
  title: string;
  navLinks?: boolean;
  fullscreen?: boolean;
}
const { title, navLinks = true, fullscreen = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ClientRouter />
    <Font cssVariable="--font-space-mono" preload />
    <style is:global>
      /* ── Design tokens ── */
      :root {
        --color-dark:    #0a0a0a;
        --color-bg:      #fafafa;
        --color-border:  #e0e0e0;
        --color-muted:   #888;
        --color-error:   #d94f4f;
        --color-success: #2a9d5c;
      }

      /* ── Reset ── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, sans-serif; line-height: 1.6; color: #111; background: var(--color-bg); overflow-x: hidden; }
      main { max-width: 900px; margin: 0 auto; padding: 1.5rem 1.25rem; }

      /* ── Font utility ── */
      .font-mono, .brand-track, .brand-ticker {
        font-family: var(--font-space-mono), monospace;
      }

      /* ── Form primitives ── */
      .field { display: flex; flex-direction: column; gap: 0.45rem; }

      .label {
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: #555;
      }

      .input {
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
        padding: 0.7rem 0.9rem;
        border: 1.5px solid var(--color-border);
        border-radius: 8px;
        font: inherit;
        font-size: 0.95rem;
        color: #111;
        background: var(--color-bg);
        transition: border-color 0.15s;
        outline: none;
      }
      .input:focus { border-color: #111; }
      .input::placeholder { color: #bbb; }
      .textarea { resize: vertical; min-height: 80px; }

      /* ── File input ── */
      .file-btn {
        display: inline-block;
        padding: 0.65rem 1.2rem;
        border: 1.5px solid #ddd;
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 600;
        color: #333;
        cursor: pointer;
        transition: border-color 0.15s, background 0.15s;
        width: fit-content;
      }
      .file-btn:hover { border-color: #111; background: #f4f4f4; }
      .upload-status { font-size: 0.82rem; color: #666; }

      /* ── Buttons ── */
      .btn-primary {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        background: var(--color-dark);
        color: #fff;
        text-decoration: none;
        border: none;
        border-radius: 8px;
        font: inherit;
        font-family: var(--font-space-mono), monospace;
        font-size: 0.85rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
      }
      .btn-primary:hover { background: #333; }
      .btn-primary:disabled { background: #999; cursor: not-allowed; }

      .btn-ghost {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        border: 1.5px solid #111;
        text-decoration: none;
        border-radius: 8px;
        font-family: var(--font-space-mono), monospace;
        font-size: 0.85rem;
        color: #111;
        transition: opacity 0.2s;
      }
      .btn-ghost:hover { opacity: 0.6; }

      .btn-save {
        padding: 0.78rem 2rem;
        background: var(--color-dark);
        color: #fff;
        border: none;
        border-radius: 8px;
        font: inherit;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
        align-self: flex-start;
      }
      .btn-save:hover { background: #333; }

      .btn-logout {
        padding: 0.75rem 1.5rem;
        background: transparent;
        color: var(--color-muted);
        border: 1.5px solid #ddd;
        border-radius: 8px;
        font: inherit;
        font-size: 0.95rem;
        cursor: pointer;
        transition: border-color 0.2s, color 0.2s;
      }
      .btn-logout:hover { border-color: #aaa; color: #333; }

      .btn-link {
        background: none;
        border: none;
        padding: 0;
        font: inherit;
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--color-dark);
        cursor: pointer;
        border-bottom: 1px solid #ccc;
        transition: border-color 0.15s;
      }
      .btn-link:hover { border-color: var(--color-dark); }
      .btn-link:disabled { color: #aaa; border-color: transparent; cursor: not-allowed; }

      /* ── Feedback messages ── */
      .msg-ok  { font-size: 0.88rem; color: var(--color-success); }
      .msg-err { font-size: 0.88rem; color: var(--color-error); }
    </style>
  </head>
  <body>
    <Navbar navLinks={navLinks} />
    {fullscreen ? <slot /> : <main><slot /></main>}
  </body>
</html>

