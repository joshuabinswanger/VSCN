---
import { ClientRouter } from "astro:transitions";
import Navbar from "../components/Navbar.astro";
import favicon from "../assets/favicon.png";
import ogImageAsset from "../assets/OG_Image.png";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  fullscreen?: boolean;
}

const { title, description, noindex = false, fullscreen = false } = Astro.props;

const DEFAULT_DESCRIPTION =
  "VSCN — Visual Science Communication Network — brings together illustrators, scientists, designers, and storytellers dedicated to making knowledge visible.";

const metaDescription = description ?? DEFAULT_DESCRIPTION;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImageAsset.src, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={favicon.src} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VSCN" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <ClientRouter />
  </head>
  <body>
    <div class="brand-ticker" transition:persist>
      <a href="/" class="brand-link">
        <div class="brand-track">
          <span>VSCN</span><span>VSCN</span><span>VSCN</span><span>VSCN</span>
          <span>VSCN</span><span>VSCN</span><span>VSCN</span><span>VSCN</span>
          <span>VSCN</span><span>VSCN</span><span>VSCN</span><span>VSCN</span>
          <span>VSCN</span><span>VSCN</span><span>VSCN</span><span>VSCN</span>
        </div>
      </a>
    </div>
    <div class="page-wrap">
      <Navbar />
      {
        fullscreen ? (
          <slot />
        ) : (
          <main>
            <slot />
          </main>
        )
      }
    </div>
  </body>
</html>

<style>
  .brand-ticker {
    display: block;
    width: 100%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .brand-link {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .brand-link:visited {
    color: black;
  }

  .brand-track {
    display: flex;
    gap: 0;
    white-space: nowrap;
    width: max-content;
    align-items: baseline;
    animation: nav-scroll 32s linear infinite;
    font-weight: 700;
    font-size: 8vh;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-dark);
  }

  .brand-track span {
    padding-right: 0;
    height: min-content;
  }

  @keyframes nav-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
