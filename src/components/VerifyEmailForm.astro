<div class="verify-wrap">

  <header class="verify-header">
    <h1 class="verify-title">Check your inbox</h1>
    <p class="verify-sub">
      We sent a verification link to <strong id="user-email"></strong>.
      Click it to activate your account.
    </p>
  </header>

  <div class="verify-body">
    <p id="status-msg" class="msg-err" style="display:none;"></p>

    <button id="btn-check" class="btn-primary">I've verified — continue</button>

    <div class="resend-row">
      <span class="resend-label">Didn't get it?</span>
      <button id="btn-resend" class="btn-link">Resend email</button>
    </div>

    <p id="resend-msg" class="msg-ok" style="display:none;">Email sent — check your inbox.</p>
  </div>

</div>

<style>
  .verify-wrap {
    width: 100%;
    max-width: 440px;
    margin: 3rem auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 560px) {
    .verify-wrap {
      background: #fff;
      border: 1.5px solid #ebebeb;
      border-radius: var(--radius-xl);
      padding: 2.5rem;
    }
  }

  .verify-header { display: flex; flex-direction: column; gap: 0.5rem; }

  .verify-title { font-size: 1.4rem; font-weight: 700; letter-spacing: -0.02em; color: var(--color-dark); }

  .verify-sub { font-size: 0.9rem; color: #666; line-height: 1.5; }

  .verify-body { display: flex; flex-direction: column; gap: 1.25rem; }

  .resend-row { display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem; }
  .resend-label { color: var(--color-muted); }
</style>

<script>
  import { auth } from "../lib/firebase.ts";
  import { onAuthStateChanged, sendEmailVerification } from "firebase/auth";

  let unsubscribeAuth: (() => void) | null = null;

  document.addEventListener("astro:page-load", () => {
    const btnCheck  = document.getElementById("btn-check") as HTMLButtonElement;
    if (!btnCheck) return;

    const userEmailEl = document.getElementById("user-email")!;
    const btnResend   = document.getElementById("btn-resend") as HTMLButtonElement;
    const statusMsg   = document.getElementById("status-msg")!;
    const resendMsg   = document.getElementById("resend-msg")!;

    let currentUser: import("firebase/auth").User | null = null;
    let resendCooldown = false;

    unsubscribeAuth?.();
    unsubscribeAuth = onAuthStateChanged(auth, (user) => {
      if (!user) { window.location.href = "/signup"; return; }
      if (user.emailVerified) { window.location.href = "/community"; return; }
      currentUser = user;
      userEmailEl.textContent = user.email ?? "";
    });

    btnCheck.addEventListener("click", async () => {
      if (!currentUser) return;
      btnCheck.disabled = true;
      btnCheck.textContent = "Checking…";
      try {
        await currentUser.reload();
        if (currentUser.emailVerified) {
          window.location.href = "/community";
        } else {
          statusMsg.textContent = "Email not verified yet. Check your inbox and click the link.";
          statusMsg.style.display = "block";
          btnCheck.disabled = false;
          btnCheck.textContent = "I've verified — continue";
        }
      } catch {
        statusMsg.textContent = "Something went wrong. Please try again.";
        statusMsg.style.display = "block";
        btnCheck.disabled = false;
        btnCheck.textContent = "I've verified — continue";
      }
    });

    btnResend.addEventListener("click", async () => {
      if (!currentUser || resendCooldown) return;
      resendCooldown = true;
      btnResend.disabled = true;
      resendMsg.style.display = "none";
      try {
        await sendEmailVerification(currentUser);
        resendMsg.style.display = "block";
      } catch {
        statusMsg.textContent = "Could not resend. Please wait a moment and try again.";
        statusMsg.style.display = "block";
      }
      setTimeout(() => {
        resendCooldown = false;
        btnResend.disabled = false;
      }, 30000);
    });
  });
</script>
