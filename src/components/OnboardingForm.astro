---
import { useTranslations } from "../i18n/utils";
import type { Lang } from "../i18n/utils";
import MemberCard from "./MemberCard.astro";
import TagSelector from "./TagSelector.astro";
import OpenToSelector from "./OpenToSelector.astro";

interface Props {
  lang?: Lang;
}
const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
const prefix = lang === "de" ? "/de" : "";
---

<div id="ob-loading" class="ob-loading">{t("profile.loading")}</div>

<div id="ob-verify-banner" class="verify-banner" style="display:none;">
  <p class="verify-banner-text">
    {t("profile.verifyBanner")}
    <button id="ob-resend-verify" type="button" class="btn-resend-verify"
      >{t("profile.verifyResend")}</button
    >
  </p>
  <p id="ob-verify-sent" class="verify-banner-sent" style="display:none;">
    {t("profile.verifySent")}
  </p>
</div>

<div id="onboarding-wrap" class="onboarding-wrap" data-lang={lang} style="display:none;">
  <div id="ob-progress" class="ob-progress">
    <div class="ob-progress-bar">
      <div id="ob-progress-fill" class="ob-progress-fill" style="width:25%"></div>
    </div>
    <span id="ob-progress-text" class="ob-progress-text">1 / 4</span>
  </div>

  <p id="ob-error" class="msg-err" style="display:none;"></p>

  <!-- Step 0: About you -->
  <div class="onboarding-step" data-step="0">
    <header class="ob-header">
      <h1 class="ob-title">{t("onboarding.step1.title")}</h1>
      <p class="ob-sub">{t("onboarding.step1.sub")}</p>
    </header>
    <div class="ob-fields">
      <div class="field">
        <label class="label" for="ob-name">{t("profile.label.name")}</label>
        <input id="ob-name" type="text" class="input" placeholder={t("profile.ph.name")} />
      </div>
      <div class="field">
        <label class="label" for="ob-role">{t("profile.label.role")}</label>
        <input id="ob-role" type="text" class="input" placeholder={t("profile.ph.role")} />
      </div>
      <div class="field">
        <label class="label" for="ob-portfolio">{t("profile.label.portfolio")}</label>
        <div class="input-prefix-wrap">
          <span class="input-prefix">https://</span>
          <input
            id="ob-portfolio"
            type="text"
            class="input input-prefixed"
            placeholder={t("profile.ph.portfolio")}
          />
        </div>
      </div>
      <div class="field">
        <label class="label" for="ob-social">{t("profile.label.social")}</label>
        <div class="input-prefix-wrap">
          <span class="input-prefix">https://</span>
          <input
            id="ob-social"
            type="text"
            class="input input-prefixed"
            placeholder={t("profile.ph.social")}
          />
        </div>
        <p class="field-note">{t("profile.note.social")}</p>
      </div>
      <div class="field">
        <label class="label" for="ob-phone">{t("profile.label.phone")}</label>
        <input
          id="ob-phone"
          type="tel"
          class="input"
          placeholder="+41 79 123 45 67"
          autocomplete="tel"
        />
        <p class="field-note">{t("profile.note.phone")}</p>
      </div>
    </div>
    <div class="ob-footer">
      <button id="ob-next-0" type="button" class="btn-solid">{t("onboarding.nav.next")}</button>
    </div>
  </div>

  <!-- Step 1: Community goals -->
  <div class="onboarding-step" data-step="1" style="display:none;">
    <header class="ob-header">
      <h1 class="ob-title">{t("onboarding.step2.title")}</h1>
      <p class="ob-sub">{t("onboarding.step2.sub")}</p>
    </header>
    <div class="ob-fields">
      <div class="field">
        <OpenToSelector lang={lang} />
      </div>
    </div>
    <div class="ob-footer">
      <button id="ob-next-1" type="button" class="btn-solid">{t("onboarding.nav.next")}</button>
    </div>
  </div>

  <!-- Step 2: Bridge -->
  <div class="onboarding-step ob-bridge" data-step="2" style="display:none;">
    <div class="ob-bridge-icon">✓</div>
    <h1 class="ob-title">{t("onboarding.bridge.title")}</h1>
    <p class="ob-sub">{t("onboarding.bridge.sub")}</p>
    <div class="ob-footer ob-footer--bridge">
      <button id="ob-continue-2" type="button" class="btn-solid"
        >{t("onboarding.bridge.continue")}</button
      >
      <button id="ob-skip-2" type="button" class="btn-link">{t("onboarding.nav.skip")}</button>
    </div>
  </div>

  <!-- Step 3: Tags -->
  <div class="onboarding-step" data-step="3" style="display:none;">
    <header class="ob-header">
      <h1 class="ob-title">{t("onboarding.step3.title")}</h1>
      <p class="ob-sub">{t("onboarding.step3.sub")}</p>
    </header>
    <div class="ob-fields">
      <div class="field">
        <label class="label" for="ob-tag-input">{t("profile.label.tags")}</label>
        <TagSelector lang={lang} maxTags={7} inputId="ob-tag-input" />
      </div>
    </div>
    <div class="ob-footer ob-footer--with-skip">
      <button id="ob-skip-3" type="button" class="btn-link">{t("onboarding.nav.skip")}</button>
      <button id="ob-next-3" type="button" class="btn-solid">{t("onboarding.nav.next")}</button>
    </div>
  </div>

  <!-- Step 4: Bio & Avatar -->
  <div class="onboarding-step" data-step="4" style="display:none;">
    <header class="ob-header">
      <h1 class="ob-title">{t("onboarding.step4.title")}</h1>
      <p class="ob-sub">{t("onboarding.step4.sub")}</p>
    </header>
    <div class="ob-fields">
      <div class="ob-avatar-row">
        <div id="ob-avatar-wrap" class="ob-avatar-wrap">
          <img id="ob-avatar-img" src="" alt="" class="ob-avatar-img" />
          <div id="ob-avatar-ph" class="ob-avatar-ph">?</div>
        </div>
        <div>
          <label class="btn-outline" for="ob-avatar-input">
            {t("profile.chooseImage")}
            <input id="ob-avatar-input" type="file" accept="image/*" style="display:none;" />
          </label>
          <p id="ob-upload-status" class="ob-upload-status" style="display:none;"></p>
        </div>
      </div>
      <div class="field">
        <label class="label" for="ob-bio">{t("profile.label.bio")}</label>
        <textarea id="ob-bio" rows="4" class="input textarea" placeholder={t("profile.ph.bio")}
        ></textarea>
        <p class="field-note">{t("profile.note.bio")}</p>
      </div>
    </div>
    <div class="ob-footer ob-footer--with-skip">
      <button id="ob-skip-4" type="button" class="btn-link">{t("onboarding.nav.skip")}</button>
      <button id="ob-finish" type="button" class="btn-solid">{t("onboarding.nav.finish")}</button>
    </div>
  </div>

  <!-- Step 5: Done -->
  <div class="onboarding-step ob-done" data-step="5" style="display:none;">
    <header class="ob-header ob-done-header">
      <h1 class="ob-title">{t("onboarding.done.title")}</h1>
      <p class="ob-sub">{t("onboarding.done.sub")}</p>
    </header>
    <div class="ob-done-card">
      <MemberCard preview lang={lang} />
    </div>
    <p class="ob-done-disclaimer">{t("onboarding.done.disclaimer")}</p>
    <div class="ob-footer ob-footer--done">
      <a href={`${prefix}/profile`} class="btn-outline">{t("onboarding.done.edit")}</a>
      <a href={`${prefix}/community`} class="btn-solid">{t("onboarding.done.goCommunity")}</a>
    </div>
  </div>
</div>

<style>
  .ob-loading {
    margin-top: 3rem;
    color: #999;
    font-size: 0.9rem;
  }

  .verify-banner {
    width: 100%;
    max-width: 500px;
    margin: clamp(1.5rem, 3vw, 2.5rem) auto 0;
    padding: 0.75rem 1rem;
    background: #fffbeb;
    border: 1.5px solid #f59e0b;
    border-radius: var(--radius-sm);
    box-sizing: border-box;
  }

  .verify-banner-text {
    margin: 0;
    font-size: 0.88rem;
    color: #92400e;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-resend-verify {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 600;
    color: #92400e;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .btn-resend-verify:hover {
    color: #78350f;
  }

  .verify-banner-sent {
    margin: 0.4rem 0 0;
    font-size: 0.82rem;
    color: #65a30d;
  }

  .onboarding-wrap {
    width: 100%;
    max-width: 500px;
    margin: clamp(2rem, 4vw, 4rem) auto;
    padding: 0 15px;
    box-sizing: border-box;

    @media (min-width: 560px) {
      background: #fff;
      border: 1.5px solid #ebebeb;
      border-radius: var(--radius-xl);
      padding: clamp(2rem, 4vw, 3rem);
    }
  }

  .ob-progress {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .ob-progress-bar {
    flex: 1;
    height: 3px;
    background: #eee;
    border-radius: 2px;
    overflow: hidden;
  }

  .ob-progress-fill {
    height: 100%;
    background: var(--color-dark);
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  .ob-progress-text {
    font-size: 0.78rem;
    color: var(--color-muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .ob-header {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.75rem;
  }

  .ob-title {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-dark);
  }

  .ob-sub {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .ob-fields {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .ob-footer {
    display: flex;
    justify-content: flex-end;
    padding-top: 1.75rem;
  }

  .ob-footer--with-skip {
    justify-content: space-between;
    align-items: center;
  }

  .ob-footer--bridge {
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding-top: 2rem;
  }

  /* Goal chips */
  .goal-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .goal-chip {
    font-family: inherit;
    font-size: 0.88rem;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    border: 1.5px solid var(--color-border);
    background: #fff;
    color: #555;
    cursor: pointer;
    transition:
      background 0.15s,
      border-color 0.15s,
      color 0.15s;
  }

  .goal-chip:hover {
    border-color: #999;
    color: #333;
  }

  button.goal-chip.goal-chip--selected {
    background: #111;
    border-color: #111;
    color: #fff;
  }

  button.goal-chip.goal-chip--selected:hover {
    background: #333;
    border-color: #333;
    color: #fff;
  }

  .goal-custom-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .goal-custom-list:empty {
    display: none;
  }

  :global(button.goal-custom-chip) {
    font-family: monospace;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.65rem;
    border-radius: var(--radius-sm);
    border: 1.5px solid #111;
    background: #111;
    color: #fff;
    font-size: 0.8rem;
    cursor: pointer;
  }

  :global(button.goal-custom-chip span) {
    color: inherit;
    opacity: 0.65;
  }

  /* Bridge step */
  .ob-bridge {
    text-align: center;
    padding: 1rem 0;
  }

  .ob-bridge-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #f0fdf4;
    border: 1.5px solid #86efac;
    color: #16a34a;
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
  }

  .ob-bridge .ob-sub {
    max-width: 320px;
    margin: 0.5rem auto 0;
  }

  /* Avatar row */
  .ob-avatar-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .ob-avatar-wrap {
    flex-shrink: 0;
    position: relative;
  }

  .ob-avatar-img,
  .ob-avatar-ph {
    width: 64px;
    height: 64px;
    border-radius: 50%;
  }

  .ob-avatar-img {
    display: none;
    object-fit: cover;
  }

  .ob-avatar-ph {
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    color: #bbb;
    border: 1.5px solid #e5e5e5;
  }

  .ob-avatar-wrap.has-image .ob-avatar-img {
    display: block;
  }

  .ob-avatar-wrap.has-image .ob-avatar-ph {
    display: none;
  }

  .ob-upload-status {
    font-size: 0.82rem;
    color: var(--color-muted);
    margin-top: 0.4rem;
  }

  /* Reuse ProfileForm field/tag styles */
  .input-prefix-wrap {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: border-color 0.15s;
    min-width: 0;
  }

  .input-prefix-wrap:focus-within {
    border-color: #111;
  }

  .input-prefix {
    padding: 8px 10px;
    background: #f5f5f5;
    color: var(--color-muted);
    font-size: 0.88rem;
    border-right: 1.5px solid var(--color-border);
    white-space: nowrap;
  }

  .input-prefixed {
    border: none;
    border-radius: 0;
    flex: 1;
    min-width: 0;
  }

  .input-prefixed:focus {
    border-color: transparent;
  }

  /* Done step (step 5) */
  .ob-done .ob-done-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .ob-done-card {
    width: 100%;
    margin-bottom: 1.25rem;
  }

  .ob-done-disclaimer {
    margin: 0 0 1.5rem;
    padding: 0.75rem 1rem;
    background: #fffbeb;
    border: 1.5px solid #fde68a;
    border-radius: var(--radius-sm);
    color: #92400e;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .ob-footer--done {
    justify-content: space-between;
    gap: 0.75rem;
    padding-top: 0.5rem;
  }

  .ob-footer--done .btn-outline,
  .ob-footer--done .btn-solid {
    text-decoration: none;
  }
</style>

<script>
  import { auth } from "../lib/firebase.ts";
  import { sendEmailVerification } from "firebase/auth";
  import { requireAuth } from "../lib/auth.ts";
  import { validateAvatar, resizeAvatar, normaliseUrl } from "../lib/validation.ts";
  import {
    getUser,
    updateUser,
    updateUserProfile,
    publishCurrentUserProfile,
  } from "../lib/firestore.ts";
  import { handleProfileUpdate, triggerRebuild } from "../lib/profile.ts";
  import { ui } from "../i18n/translations.ts";

  const STORAGE_KEY = "vscn:onboarding:state";

  let unsubscribeAuth: (() => void) | null = null;
  let prevNavLangHandler: ((e: Event) => void) | null = null;
  let prevPageHideHandler: ((e: Event) => void) | null = null;

  document.addEventListener("astro:page-load", () => {
    const wrap = document.getElementById("onboarding-wrap") as HTMLElement | null;
    if (!wrap) return;

    const lang = (wrap.dataset.lang ?? "en") as keyof typeof ui;
    const s = ui[lang] ?? ui.en;
    const prefix = lang === "de" ? "/de" : "";

    const loadingEl = document.getElementById("ob-loading");
    const errorEl = document.getElementById("ob-error")!;

    let currentStep = 0;

    // ── Helpers ───────────────────────────────────────────────────
    function setStep(n: number) {
      currentStep = n;
      document.querySelectorAll<HTMLElement>(".onboarding-step").forEach((el) => {
        el.style.display = el.dataset.step === String(n) ? "" : "none";
      });
      const progressEl = document.getElementById("ob-progress");
      const progressText = document.getElementById("ob-progress-text");
      const progressFill = document.getElementById("ob-progress-fill");
      const realSteps = [0, 1, 3, 4];
      const idx = realSteps.indexOf(n);
      const hideProgress = n === 2 || n === 5;
      if (progressEl) progressEl.style.display = hideProgress ? "none" : "";
      if (progressText && idx >= 0) progressText.textContent = `${idx + 1} / 4`;
      if (progressFill && idx >= 0) progressFill.style.width = `${(idx + 1) * 25}%`;
      errorEl.style.display = "none";
    }

    function setError(msg: string) {
      errorEl.textContent = msg;
      errorEl.style.display = msg ? "block" : "none";
    }

    function setBtnState(id: string, loading: boolean, idleText: string) {
      const btn = document.getElementById(id) as HTMLButtonElement | null;
      if (!btn) return;
      btn.disabled = loading;
      btn.textContent = loading ? s["onboarding.saving"] : idleText;
    }

    async function finishToPreview(opts: {
      bio?: string;
      avatarObjectUrl?: string | null;
      photoURL?: string;
    }) {
      const user = auth.currentUser;
      if (!user) return;

      // Unsubscribe the auth guard first so a stray onAuthStateChanged
      // re-fire (e.g. after updateProfile/getIdToken) can't redirect us
      // to /community once onboardingComplete is true.
      unsubscribeAuth?.();
      unsubscribeAuth = null;

      clearTransientState();

      try {
        // Republish a complete publicProfile from the private user doc.
        // Heals any wipe that may have happened from earlier partial saves.
        await publishCurrentUserProfile(user.uid);
      } catch {
        // non-critical
      }

      try {
        await updateUser(user.uid, { onboardingComplete: true });
      } catch {
        // non-critical
      }

      populatePreviewCard({
        displayName: getInputValue("ob-name").trim(),
        role: getInputValue("ob-role").trim(),
        portfolio: getInputValue("ob-portfolio").trim(),
        bio: opts.bio ?? "",
        photoURL: opts.photoURL ?? user.photoURL ?? "",
        avatarObjectUrl: opts.avatarObjectUrl ?? null,
      });
      setStep(5);
      await triggerRebuild();
    }

    function getInputValue(id: string): string {
      const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
      return el?.value ?? "";
    }

    function saveTransientState() {
      if (currentStep === 5) return;
      try {
        sessionStorage.setItem(
          STORAGE_KEY,
          JSON.stringify({
            step: currentStep,
            name: getInputValue("ob-name"),
            role: getInputValue("ob-role"),
            portfolio: getInputValue("ob-portfolio"),
            social: getInputValue("ob-social"),
            phone: getInputValue("ob-phone"),
            bio: getInputValue("ob-bio"),
            selectedGoals: [...selectedGoals],
            customGoals: [...customGoals],
            goalInput: getInputValue("ob-goal-input"),
            openTo: openToSelector?.value ?? [],
            tags: tagSelector?.value ?? [],
            tagInput: tagSelector?.inputValue ?? "",
          })
        );
      } catch {
        // sessionStorage unavailable — ignore
      }
    }

    function clearTransientState() {
      try {
        sessionStorage.removeItem(STORAGE_KEY);
      } catch {
        // ignore
      }
    }

    function readTransientState(): {
      step?: number;
      name?: string;
      role?: string;
      portfolio?: string;
      social?: string;
      phone?: string;
      bio?: string;
      selectedGoals?: string[];
      customGoals?: string[];
      goalInput?: string;
      openTo?: string[];
      tags?: string[];
      tagInput?: string;
    } | null {
      try {
        const raw = sessionStorage.getItem(STORAGE_KEY);
        if (!raw) return null;
        return JSON.parse(raw);
      } catch {
        return null;
      }
    }

    // ── Community goals ────────────────────────────────────────────
    const presetGoalKeys = new Set(["networking", "portfolio", "events", "scivis"]);
    const selectedGoals = new Set<string>();
    let customGoals: string[] = [];
    const customGoalList = document.getElementById("ob-goal-custom-list")!;

    const openToSelector = document.querySelector<
      HTMLElement & {
        value: string[];
      }
    >("open-to-selector");

    document.querySelectorAll<HTMLElement>("[data-goal]").forEach((el) => {
      el.addEventListener("click", () => {
        const goal = el.dataset.goal!;
        if (selectedGoals.has(goal)) {
          selectedGoals.delete(goal);
          el.classList.remove("goal-chip--selected");
        } else {
          selectedGoals.add(goal);
          el.classList.add("goal-chip--selected");
        }
      });
    });

    function renderCustomGoals() {
      customGoalList.innerHTML = "";
      customGoals.forEach((goal) => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "goal-custom-chip";
        btn.textContent = goal;
        const x = document.createElement("span");
        x.setAttribute("aria-hidden", "true");
        x.textContent = "×";
        btn.appendChild(x);
        btn.addEventListener("click", () => {
          customGoals = customGoals.filter((g) => g !== goal);
          renderCustomGoals();
        });
        customGoalList.appendChild(btn);
      });
    }

    const goalInput = document.getElementById("ob-goal-input") as HTMLInputElement;
    goalInput?.addEventListener("keydown", (e) => {
      if (e.key !== "Enter") return;
      e.preventDefault();
      const val = goalInput.value.trim();
      if (!val || customGoals.includes(val) || presetGoalKeys.has(val.toLowerCase())) return;
      customGoals = [...customGoals, val];
      goalInput.value = "";
      renderCustomGoals();
    });

    function getSelectedGoals(): string[] {
      return [...selectedGoals, ...customGoals];
    }

    // ── Tags (delegated to the <tag-selector> custom element) ─────
    const tagSelector = document.querySelector<
      HTMLElement & {
        value: string[];
        inputValue: string;
      }
    >("tag-selector");

    // ── Avatar (step 4) ────────────────────────────────────────────
    const avatarInput = document.getElementById("ob-avatar-input") as HTMLInputElement;
    const avatarImg = document.getElementById("ob-avatar-img") as HTMLImageElement;
    const avatarWrap = document.getElementById("ob-avatar-wrap") as HTMLElement;
    const uploadStatus = document.getElementById("ob-upload-status") as HTMLElement;
    let resizedAvatarBlob: Blob | null = null;

    avatarInput?.addEventListener("change", async () => {
      const file = avatarInput.files?.[0];
      if (!file) return;
      const validation = validateAvatar(file);
      if (!validation.ok) {
        uploadStatus.textContent = validation.error!;
        uploadStatus.style.display = "block";
        return;
      }
      uploadStatus.textContent = s["profile.upload.processing"];
      uploadStatus.style.display = "block";
      try {
        resizedAvatarBlob = await resizeAvatar(file);
        const url = URL.createObjectURL(resizedAvatarBlob);
        avatarImg.src = url;
        avatarWrap.classList.add("has-image");
        uploadStatus.textContent = `${s["profile.upload.selected"]}${file.name}`;
      } catch {
        uploadStatus.textContent = s["profile.upload.error"];
        resizedAvatarBlob = null;
      }
    });

    // ── Navigation buttons ─────────────────────────────────────────
    document.getElementById("ob-next-0")?.addEventListener("click", async () => {
      const user = auth.currentUser;
      if (!user) return;
      setBtnState("ob-next-0", true, s["onboarding.nav.next"]);
      try {
        const nameVal = getInputValue("ob-name").trim();
        const roleVal = getInputValue("ob-role").trim();
        const portfolioVal = getInputValue("ob-portfolio").trim();
        const socialVal = getInputValue("ob-social").trim();
        const phoneVal = getInputValue("ob-phone").trim();

        await handleProfileUpdate(user, {
          displayName: nameVal,
          role: roleVal,
          portfolio: portfolioVal,
          socialMedia: socialVal,
          phone: phoneVal,
          email: user.email!,
        });
      } finally {
        setBtnState("ob-next-0", false, s["onboarding.nav.next"]);
        setStep(1);
      }
    });

    document.getElementById("ob-next-1")?.addEventListener("click", async () => {
      const user = auth.currentUser;
      if (!user) return;
      setBtnState("ob-next-1", true, s["onboarding.nav.next"]);
      try {
        await updateUser(user.uid, {
          communityGoals: getSelectedGoals(),
          openTo: openToSelector?.value ?? [],
        }).catch(() => {});
      } finally {
        setBtnState("ob-next-1", false, s["onboarding.nav.next"]);
        setStep(2);
      }
    });

    document.getElementById("ob-continue-2")?.addEventListener("click", () => setStep(3));
    document.getElementById("ob-skip-2")?.addEventListener("click", () => finishToPreview({}));

    document.getElementById("ob-next-3")?.addEventListener("click", async () => {
      const user = auth.currentUser;
      if (!user) return;
      setBtnState("ob-next-3", true, s["onboarding.nav.next"]);
      try {
        const tagsValue = tagSelector?.value ?? [];
        await updateUserProfile(user.uid, {
          tags: tagsValue,
          updatedAt: new Date(),
        }).catch(() => {});
      } finally {
        setBtnState("ob-next-3", false, s["onboarding.nav.next"]);
        setStep(4);
      }
    });

    document.getElementById("ob-skip-3")?.addEventListener("click", () => finishToPreview({}));

    function populatePreviewCard(opts: {
      displayName: string;
      role: string;
      portfolio: string;
      bio: string;
      photoURL: string;
      avatarObjectUrl: string | null;
    }) {
      const previewName = document.getElementById("preview-name");
      const previewRole = document.getElementById("preview-role") as HTMLElement | null;
      const previewPortfolio = document.getElementById(
        "preview-portfolio"
      ) as HTMLAnchorElement | null;
      const previewBio = document.getElementById("preview-bio") as HTMLElement | null;
      const previewAvatarImg = document.getElementById(
        "preview-avatar-img"
      ) as HTMLImageElement | null;
      const previewAvatarPh = document.getElementById("preview-avatar-ph") as HTMLElement | null;

      const displayName = opts.displayName || "Anonymous";
      if (previewName) previewName.textContent = displayName;

      if (previewRole) {
        if (opts.role) {
          previewRole.textContent = opts.role;
          previewRole.style.display = "";
        } else {
          previewRole.style.display = "none";
        }
      }

      if (previewPortfolio) {
        const href = normaliseUrl(opts.portfolio);
        if (href) {
          previewPortfolio.href = href;
          previewPortfolio.textContent = opts.portfolio;
          previewPortfolio.style.display = "";
        } else {
          previewPortfolio.style.display = "none";
        }
      }

      if (previewBio) {
        if (opts.bio) {
          previewBio.textContent = opts.bio;
          previewBio.style.display = "";
        } else {
          previewBio.style.display = "none";
        }
      }

      const imgSrc = opts.avatarObjectUrl || opts.photoURL || "";
      if (previewAvatarImg && previewAvatarPh) {
        if (imgSrc) {
          previewAvatarImg.src = imgSrc;
          previewAvatarImg.alt = displayName;
          previewAvatarImg.style.display = "";
          previewAvatarPh.style.display = "none";
          previewAvatarImg.onerror = () => {
            previewAvatarImg.style.display = "none";
            previewAvatarPh.style.display = "";
            previewAvatarPh.textContent = displayName[0]?.toUpperCase() ?? "?";
          };
        } else {
          previewAvatarImg.style.display = "none";
          previewAvatarPh.style.display = "";
          previewAvatarPh.textContent = displayName[0]?.toUpperCase() ?? "?";
        }
      }
    }

    document.getElementById("ob-finish")?.addEventListener("click", async () => {
      const user = auth.currentUser;
      if (!user) return;
      setBtnState("ob-finish", true, s["onboarding.nav.finish"]);
      setError("");
      try {
        const bioVal = getInputValue("ob-bio").trim();
        let avatarObjectUrl: string | null = null;
        if (resizedAvatarBlob) {
          avatarObjectUrl = URL.createObjectURL(resizedAvatarBlob);
        }

        const { photoURL } = await handleProfileUpdate(
          user,
          {
            bio: bioVal,
            resizedAvatarBlob,
          },
          (pct) => {
            uploadStatus.textContent = `${s["profile.upload.uploading"]} ${pct}%`;
            uploadStatus.style.display = "block";
          }
        );

        await finishToPreview({ bio: bioVal, photoURL, avatarObjectUrl });
      } catch (err: unknown) {
        setError(err instanceof Error ? err.message : s["onboarding.error.save"]);
        setBtnState("ob-finish", false, s["onboarding.nav.finish"]);
      }
    });

    document.getElementById("ob-skip-4")?.addEventListener("click", () => finishToPreview({}));

    // ── Verify banner ──────────────────────────────────────────────
    const verifyBanner = document.getElementById("ob-verify-banner")!;
    const btnResend = document.getElementById("ob-resend-verify") as HTMLButtonElement;
    const verifySent = document.getElementById("ob-verify-sent")!;

    // ── Auth guard ─────────────────────────────────────────────────
    unsubscribeAuth?.();
    unsubscribeAuth = requireAuth(async (user) => {
      try {
        const data = await getUser(user.uid);
        if (data.onboardingComplete) {
          window.location.href = `${prefix}/community`;
          return;
        }

        // Pre-fill existing data
        const nameEl = document.getElementById("ob-name") as HTMLInputElement;
        const roleEl = document.getElementById("ob-role") as HTMLInputElement;
        const portfolioEl = document.getElementById("ob-portfolio") as HTMLInputElement;
        const socialEl = document.getElementById("ob-social") as HTMLInputElement;
        const phoneEl = document.getElementById("ob-phone") as HTMLInputElement;
        const bioEl = document.getElementById("ob-bio") as HTMLTextAreaElement;

        nameEl.value = data.displayName ?? user.displayName ?? "";
        roleEl.value = data.role ?? "";
        portfolioEl.value = data.portfolio ?? "";
        socialEl.value = data.socialMedia ?? "";
        phoneEl.value = data.phone ?? "";
        if (bioEl) bioEl.value = data.bio ?? "";

        if (Array.isArray(data.communityGoals)) {
          data.communityGoals.forEach((goal) => {
            if (presetGoalKeys.has(goal)) {
              selectedGoals.add(goal);
              document
                .querySelector<HTMLElement>(`[data-goal="${goal}"]`)
                ?.classList.add("goal-chip--selected");
            } else {
              customGoals.push(goal);
            }
          });
          renderCustomGoals();
        }

        if (openToSelector && Array.isArray(data.openTo)) {
          openToSelector.value = data.openTo.filter(Boolean);
        }

        const savedTags = Array.isArray(data.tags) ? data.tags.filter(Boolean).slice(0, 7) : [];
        if (tagSelector) tagSelector.value = savedTags;
      } catch {
        // Permission denied or network error — show form with empty fields
      }

      // Restore transient state (e.g. after a language switch)
      const restoreState = readTransientState();
      let restoredStep = 0;
      if (restoreState) {
        const setIfPresent = (id: string, val?: string) => {
          if (val == null) return;
          const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
          if (el) el.value = val;
        };
        setIfPresent("ob-name", restoreState.name);
        setIfPresent("ob-role", restoreState.role);
        setIfPresent("ob-portfolio", restoreState.portfolio);
        setIfPresent("ob-social", restoreState.social);
        setIfPresent("ob-phone", restoreState.phone);
        setIfPresent("ob-bio", restoreState.bio);
        setIfPresent("ob-goal-input", restoreState.goalInput);

        if (Array.isArray(restoreState.selectedGoals)) {
          restoreState.selectedGoals.forEach((goal) => {
            if (selectedGoals.has(goal)) return;
            selectedGoals.add(goal);
            document
              .querySelector<HTMLElement>(`[data-goal="${goal}"]`)
              ?.classList.add("goal-chip--selected");
          });
        }
        if (Array.isArray(restoreState.customGoals)) {
          restoreState.customGoals.forEach((goal) => {
            if (!customGoals.includes(goal)) customGoals.push(goal);
          });
          renderCustomGoals();
        }
        if (openToSelector && Array.isArray(restoreState.openTo)) {
          openToSelector.value = restoreState.openTo;
        }
        if (tagSelector && Array.isArray(restoreState.tags)) {
          const current = tagSelector.value;
          const merged = [...current];
          restoreState.tags.forEach((t) => {
            if (!merged.some((s) => s.toLowerCase() === t.toLowerCase())) merged.push(t);
          });
          tagSelector.value = merged.slice(0, 7);
        }
        if (tagSelector && typeof restoreState.tagInput === "string") {
          tagSelector.inputValue = restoreState.tagInput;
        }

        if (typeof restoreState.step === "number" && restoreState.step !== 5) {
          restoredStep = restoreState.step;
        }
        clearTransientState();
      }

      // Save state before navigating away (e.g. clicking the lang toggle).
      // Re-binding is safe because nav-lang is `transition:persist`-ed across
      // navigations, so remove any previous handler first.
      const navLang = document.getElementById("nav-lang");
      if (prevNavLangHandler) {
        navLang?.removeEventListener("click", prevNavLangHandler, { capture: true });
      }
      if (prevPageHideHandler) {
        window.removeEventListener("pagehide", prevPageHideHandler);
      }
      const onNavLangClick = () => saveTransientState();
      const onPageHide = () => saveTransientState();
      navLang?.addEventListener("click", onNavLangClick, { capture: true });
      window.addEventListener("pagehide", onPageHide);
      prevNavLangHandler = onNavLangClick;
      prevPageHideHandler = onPageHide;

      if (!user.emailVerified) {
        verifyBanner.style.display = "block";
        let cooldown = false;
        btnResend?.addEventListener("click", async () => {
          if (cooldown) return;
          cooldown = true;
          btnResend.disabled = true;
          try {
            await sendEmailVerification(user);
            verifySent.style.display = "block";
          } catch {
            // ignore
          }
          setTimeout(() => {
            cooldown = false;
            btnResend.disabled = false;
          }, 30000);
        });
      }

      if (loadingEl) loadingEl.style.display = "none";
      wrap.style.display = "block";
      setStep(restoredStep);
    });
  });
</script>
