---
interface Props {
  holdDuration?: number;
  replaceDuration?: number;
  collapseDuration?: number;
  ease?: string;
}

const baseText = "VSCNVSCNVSCNVSCN";
const {
  holdDuration = 1.65,
  replaceDuration = 1.15,
  collapseDuration = 0.75,
  ease = "expo.inOut",
} = Astro.props;
---

<div
  class="gsap-text-headline"
  data-gsap-text-headline
  data-base-text={baseText}
  data-hold-duration={holdDuration}
  data-replace-duration={replaceDuration}
  data-collapse-duration={collapseDuration}
  data-ease={ease}
  aria-label="Visual Science Communication Network"
>
  <span class="gsap-text-headline__text" data-headline-text>{baseText}</span>
</div>

<style>
  .gsap-text-headline {
    display: flex;
    justify-content: center;
    width: 100%;
    overflow: hidden;
    color: var(--color-dark);
    font-family: ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", Menlo, monospace;
    font-size: var(--gsap-text-headline-size, clamp(2.5rem, 10.4vw, 8rem));
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: 0;
    text-align: center;
    white-space: nowrap;
  }

  .gsap-text-headline__text {
    display: inline-block;
    width: var(--gsap-text-headline-width, 100vw);
    text-align: left;
    transform-style: preserve-3d;
  }

  :global(.gsap-text-headline__slot) {
    display: inline-block;
    position: relative;
    width: 1ch;
    height: 1em;
    overflow: hidden;
    vertical-align: top;
  }

  :global(.gsap-text-headline__column) {
    display: block;
    will-change: transform;
  }

  :global(.gsap-text-headline__char) {
    display: block;
    height: 1em;
    line-height: 1;
  }
</style>

<script>
  import gsap from "gsap";

  const timelines = new WeakMap<HTMLElement, gsap.core.Timeline>();
  const replayTimeouts = new WeakMap<HTMLElement, ReturnType<typeof setTimeout>>();
  const roots = new Set<HTMLElement>();
  const slotCounts = new WeakMap<HTMLElement, number>();

  const REPLAY_DELAY_MS = 60_000;

  const words = ["Visual", "Science", "Communication", "Network"];

  function measureChRatio(target: HTMLElement): number {
    const probe = document.createElement("span");
    const cs = getComputedStyle(target);
    probe.style.cssText =
      `position:absolute;visibility:hidden;white-space:pre;` +
      `font-family:${cs.fontFamily};font-weight:${cs.fontWeight};` +
      `letter-spacing:${cs.letterSpacing};font-size:100px;line-height:1;`;
    probe.textContent = "0";
    document.body.appendChild(probe);
    const w = probe.getBoundingClientRect().width;
    probe.remove();
    return w / 100;
  }

  function applyHeadlineSize(root: HTMLElement, slotCount: number) {
    const target = root.querySelector<HTMLElement>("[data-headline-text]");
    if (!target) return;
    const targetWidthPx = target.getBoundingClientRect().width;
    if (!targetWidthPx) return;
    const chRatio = measureChRatio(target);
    if (!chRatio) return;
    const fontSizePx = targetWidthPx / slotCount / chRatio;
    target.style.fontSize = `${fontSizePx}px`;
  }

  function buildColumnSequences(rows: string[], slotCount: number): string[][] {
    const sequences: string[][] = [];
    for (let col = 0; col < slotCount; col += 1) {
      const seq: string[] = [];
      rows.forEach((row) => {
        const ch = row[col] ?? " ";
        if (seq.length === 0 || seq[seq.length - 1] !== ch) seq.push(ch);
      });
      sequences.push(seq);
    }
    return sequences;
  }

  function renderCharacterColumns(target: HTMLElement, sequences: string[][]) {
    target.textContent = "";

    sequences.forEach((seq) => {
      const slot = document.createElement("span");
      const column = document.createElement("span");

      slot.className = "gsap-text-headline__slot";
      slot.setAttribute("aria-hidden", "true");
      column.className = "gsap-text-headline__column";

      seq.forEach((value) => {
        const char = document.createElement("span");
        char.className = "gsap-text-headline__char";
        setCharacter(char, value);
        column.appendChild(char);
      });

      slot.appendChild(column);
      target.appendChild(slot);
    });
  }

  function setCharacter(span: HTMLElement, character: string) {
    span.textContent = character === " " ? "\u00a0" : character;
  }

  function transitionText(
    timeline: gsap.core.Timeline,
    target: HTMLElement,
    rows: string[],
    rowIndex: number,
    columnPositions: number[],
    duration: number,
    ease: string,
    slotCount: number
  ) {
    const allColumns = Array.from(
      target.querySelectorAll<HTMLElement>(".gsap-text-headline__column")
    ).slice(0, slotCount);

    const changing: HTMLElement[] = [];
    const targetYs: number[] = [];
    const prevRow = rows[rowIndex - 1] ?? "";
    const nextRow = rows[rowIndex] ?? "";
    for (let col = 0; col < slotCount; col += 1) {
      const prev = prevRow[col] ?? " ";
      const next = nextRow[col] ?? " ";
      if (prev !== next) {
        columnPositions[col] += 1;
        changing.push(allColumns[col]);
        targetYs.push(-columnPositions[col]);
      }
    }

    if (changing.length === 0) {
      timeline.to({}, { duration });
      return;
    }

    timeline.to(changing, {
      duration,
      y: (i: number) => `${targetYs[i]}em`,
      stagger: 0.026,
      ease,
    });
  }

  function resetColumns(timeline: gsap.core.Timeline, target: HTMLElement, slotCount: number) {
    const columns = Array.from(
      target.querySelectorAll<HTMLElement>(".gsap-text-headline__column")
    ).slice(0, slotCount);

    timeline.set(columns, { y: 0 });
  }

  function destroyHeadline(root: HTMLElement) {
    const t = replayTimeouts.get(root);
    if (t !== undefined) {
      clearTimeout(t);
      replayTimeouts.delete(root);
    }
    const timeline = timelines.get(root);
    if (timeline) {
      timeline.kill();
      timelines.delete(root);
    }
    roots.delete(root);
    slotCounts.delete(root);
  }

  function resizeAllHeadlines() {
    roots.forEach((root) => {
      const slotCount = slotCounts.get(root);
      if (slotCount) applyHeadlineSize(root, slotCount);
    });
  }

  let resizeRaf = 0;
  function onResize() {
    if (resizeRaf) cancelAnimationFrame(resizeRaf);
    resizeRaf = requestAnimationFrame(() => {
      resizeRaf = 0;
      resizeAllHeadlines();
    });
  }

  function initHeadline(root: HTMLElement) {
    destroyHeadline(root);

    const target = root.querySelector<HTMLElement>("[data-headline-text]");
    if (!target) return;

    const baseText = root.dataset.baseText ?? "VSCNVSCNVSCNVSCN";
    const holdDuration = Number(root.dataset.holdDuration ?? 1.65);
    const replaceDuration = Number(root.dataset.replaceDuration ?? 1.15);
    const collapseDuration = Number(root.dataset.collapseDuration ?? 0.75);
    const ease = root.dataset.ease ?? "expo.inOut";
    const slotCount = baseText.length;
    const padToSlot = (s: string) => (s + " ".repeat(slotCount)).slice(0, slotCount);
    const rows = [baseText, ...words.map(padToSlot), baseText];
    const finalBaseRowIndex = rows.length - 1;
    const sequences = buildColumnSequences(rows, slotCount);

    slotCounts.set(root, slotCount);
    applyHeadlineSize(root, slotCount);
    renderCharacterColumns(target, sequences);

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      target.textContent = baseText;
      roots.add(root);
      return;
    }

    const columnPositions = new Array<number>(slotCount).fill(0);
    const timeline = gsap.timeline({
      repeat: 0,
      onComplete: () => {
        const t = setTimeout(() => {
          if (roots.has(root)) initHeadline(root);
        }, REPLAY_DELAY_MS);
        replayTimeouts.set(root, t);
      },
    });

    timeline.to({}, { duration: holdDuration });

    words.forEach((_, index) => {
      transitionText(
        timeline,
        target,
        rows,
        index + 1,
        columnPositions,
        replaceDuration,
        ease,
        slotCount
      );

      if (index < words.length - 1) {
        timeline.to({}, { duration: holdDuration });
      }
    });

    timeline.to({}, { duration: holdDuration });
    transitionText(
      timeline,
      target,
      rows,
      finalBaseRowIndex,
      columnPositions,
      collapseDuration,
      ease,
      slotCount
    );
    resetColumns(timeline, target, slotCount);
    timeline.to({}, { duration: 0.3 });

    timeline.timeScale(1.75);

    timelines.set(root, timeline);
    roots.add(root);
  }

  function initHeadlines() {
    document.querySelectorAll<HTMLElement>("[data-gsap-text-headline]").forEach(initHeadline);
    if (document.fonts?.ready) {
      document.fonts.ready.then(resizeAllHeadlines);
    }
  }

  document.addEventListener("astro:page-load", initHeadlines);
  document.addEventListener("astro:before-swap", () => {
    Array.from(roots).forEach(destroyHeadline);
  });
  window.addEventListener("resize", onResize);

  if (document.readyState !== "loading") {
    initHeadlines();
  } else {
    document.addEventListener("DOMContentLoaded", initHeadlines, { once: true });
  }
</script>
