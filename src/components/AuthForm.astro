---
import { useTranslations } from "../i18n/utils.ts";
import type { Lang } from "../i18n/utils.ts";

interface Props {
  lang?: Lang;
  initialMode?: 'login' | 'signup';
}

const { lang = 'en', initialMode = 'signup' } = Astro.props;
const t = useTranslations(lang);
---

<div class="auth-wrap" data-lang={lang} data-initial-mode={initialMode}>
  <header class="auth-header">
    <h1 id="auth-title" class="auth-title">{t('auth.title.signup')}</h1>
  </header>

  <form id="auth-form" class="auth-form">
    <div class="field">
      <label class="label" for="email">Email</label>
      <input
        id="email"
        type="email"
        class="input"
        placeholder="you@example.com"
        required
        autocomplete="email"
      />
    </div>

    <div class="field">
      <div class="field-label-row">
        <label class="label" for="password">Password</label>
        <button type="button" id="forgot-link" class="btn-link forgot-btn" style="display:none;"
          >{t('auth.forgot')}</button
        >
      </div>
      <input
        id="password"
        type="password"
        class="input"
        placeholder="••••••••"
        required
        autocomplete="current-password"
      />
    </div>
    <p id="auth-error" class="msg-err" style="display:none;"></p>

    <div class="auth-footer">
      <p class="auth-sub already-have">
        {t('auth.alreadyHave')}
        <a href="#" id="toggle-link" class="toggle-link">{t('auth.toggle.toLogin')}</a>
      </p>
      <button id="submit-btn" type="submit" class="btn-solid auth-submit-button">{t('auth.submit.signup')}</button>
    </div>
  </form>

  <div id="forgot-section" style="display:none;">
    <div class="field">
      <label class="label" for="forgot-email">Email</label>
      <input
        id="forgot-email"
        type="email"
        class="input"
        placeholder="you@example.com"
        autocomplete="email"
      />
    </div>
    <p id="forgot-error" class="msg-err" style="display:none;"></p>
    <p id="forgot-success" class="msg-ok" style="display:none;">
      {t('auth.reset.success')}
    </p>
    <div class="auth-footer">
      <button id="forgot-submit" type="button" class="btn-solid auth-submit-button">
        {t('auth.reset.send')}
      </button>
    </div>
    <div class="forgot-back-row">
      <button id="forgot-back" type="button" class="btn-link">{t('auth.reset.back')}</button>
    </div>
  </div>
</div>

<style>
  .auth-wrap {
    width: 100%;
    max-width: 560px;
    margin: clamp(2rem, 4vw, 4rem) auto;
    display: grid;
    grid-auto-rows: min-content;
    gap: 1.5rem;
    padding: 0 15px;
    box-sizing: border-box;
    overflow: hidden;

    @media (--bp-desktop) {
      padding: 0;
    }
  }

  .auth-header {
    display: grid;
    gap: 0.3rem;
  }

  .auth-title {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-dark);
  }

  .auth-sub {
    font-size: 0.88rem;
    color: var(--color-muted);
    margin-top: -5px;
  }

  .toggle-link {
    color: var(--color-dark);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid #ccc;
    transition: border-color 0.15s;
  }
  .toggle-link:hover {
    border-color: var(--color-dark);
  }

  .auth-form {
    display: grid;
    grid-auto-rows: min-content;
    gap: 1.5rem;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
    margin-bottom: 25vh;
  }

  .field-label-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .forgot-btn {
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--color-muted);
    border-bottom-color: transparent;
  }

  .forgot-btn:hover {
    color: var(--color-dark);
    border-bottom-color: var(--color-dark);
  }

  #forgot-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 25vh;
  }

  .forgot-back-row {
    display: flex;
    justify-content: flex-end;
  }

  .auth-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 25px;
  }

  .already-have {
    margin-top: 0;
  }

  @media (max-width: 520px) {
    .auth-footer {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
    }

    .auth-submit-button {
      width: 100%;
    }
  }
</style>

<script>
  import { auth } from "../lib/firebase.ts";
  import {
    createUserWithEmailAndPassword,
    onAuthStateChanged,
    signInWithEmailAndPassword,
    sendEmailVerification,
    sendPasswordResetEmail,
  } from "firebase/auth";
  import { friendlyError } from "../lib/auth.ts";
  import { createUser } from "../lib/firestore.ts";
  import { ui } from "../i18n/translations.ts";

  let isLogin = false;
  let lastSubmit = 0;
  let isSubmitting = false;
  let unsubscribeAuth: (() => void) | null = null;

  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("auth-form") as HTMLFormElement;
    if (!form) return;

    const wrap = document.querySelector<HTMLElement>(".auth-wrap[data-lang]");
    const lang = (wrap?.dataset.lang ?? "en") as "en" | "de";
    const prefix = lang === "de" ? "/de" : "";
    const s = ui[lang];

    const toggleLink = document.getElementById("toggle-link")!;
    const submitBtn = document.getElementById("submit-btn")!;
    const authTitle = document.getElementById("auth-title")!;
    const authSub = document.querySelector<HTMLElement>(".auth-sub")!;
    const errorEl = document.getElementById("auth-error")!;
    const forgotLink = document.getElementById("forgot-link") as HTMLButtonElement;
    const forgotSection = document.getElementById("forgot-section")!;
    const forgotEmailInput = document.getElementById("forgot-email") as HTMLInputElement;
    const forgotSubmit = document.getElementById("forgot-submit") as HTMLButtonElement;
    const forgotBack = document.getElementById("forgot-back") as HTMLButtonElement;
    const forgotError = document.getElementById("forgot-error")!;
    const forgotSuccess = document.getElementById("forgot-success")!;

    unsubscribeAuth?.();
    unsubscribeAuth = onAuthStateChanged(auth, (user) => {
      if (!user) return;
      if (isSubmitting) return;
      window.location.href = `${prefix}/community`;
    });

    function showForgotView() {
      form.style.display = "none";
      forgotSection.style.display = "flex";
      authTitle.textContent = s["auth.title.reset"];
      authSub.style.display = "none";
      forgotEmailInput.value = (document.getElementById("email") as HTMLInputElement).value;
      forgotError.style.display = "none";
      forgotSuccess.style.display = "none";
      forgotSubmit.disabled = false;
      forgotSubmit.textContent = s["auth.reset.send"];
    }

    function showLoginView() {
      forgotSection.style.display = "none";
      form.style.display = "grid";
      authTitle.textContent = s["auth.title.login"];
      authSub.style.display = "";
    }

    function updateView() {
      submitBtn.textContent = isLogin ? s["auth.submit.login"] : s["auth.submit.signup"];
      toggleLink.textContent = isLogin ? s["auth.toggle.toSignup"] : s["auth.toggle.toLogin"];
      authTitle.textContent = isLogin ? s["auth.title.login"] : s["auth.title.signup"];
      forgotLink.style.display = isLogin ? "inline" : "none";
      
      const alreadyHaveEl = document.querySelector('.already-have') as HTMLElement;
      if (alreadyHaveEl) {
        alreadyHaveEl.firstChild!.textContent = isLogin ? (s["auth.noAccount"] || "Don't have an account? ") : (s["auth.alreadyHave"] || "Already have one? ");
      }
    }

    // Reset state on each page load
    isLogin = (wrap as HTMLElement).dataset.initialMode === 'login';
    updateView();
    forgotSection.style.display = "none";
    form.style.display = "grid";
    authSub.style.display = "";

    forgotLink.addEventListener("click", () => showForgotView());

    forgotBack.addEventListener("click", () => showLoginView());

    forgotSubmit.addEventListener("click", async () => {
      const email = forgotEmailInput.value.trim();
      forgotError.style.display = "none";
      forgotSuccess.style.display = "none";

      if (!email) {
        forgotError.textContent = s["auth.error.enterEmail"];
        forgotError.style.display = "block";
        return;
      }

      forgotSubmit.disabled = true;
      forgotSubmit.textContent = s["auth.reset.sending"];

      try {
        await sendPasswordResetEmail(auth, email);
        forgotSuccess.style.display = "block";
        forgotSubmit.textContent = s["auth.reset.sent"];
      } catch {
        forgotError.textContent = s["auth.error.resetFailed"];
        forgotError.style.display = "block";
        forgotSubmit.disabled = false;
        forgotSubmit.textContent = s["auth.reset.send"];
      }
    });

    toggleLink.addEventListener("click", (e) => {
      e.preventDefault();
      isLogin = !isLogin;
      updateView();
      errorEl.style.display = "none";
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorEl.style.display = "none";

      const now = Date.now();
      if (now - lastSubmit < 5000) {
        errorEl.textContent = s["auth.error.wait"];
        errorEl.style.display = "block";
        return;
      }
      lastSubmit = now;

      const email = (document.getElementById("email") as HTMLInputElement).value;
      const password = (document.getElementById("password") as HTMLInputElement).value;

      try {
        isSubmitting = true;
        if (isLogin) {
          await signInWithEmailAndPassword(auth, email, password);
          window.location.href = `${prefix}/profile`;
        } else {
          const { user } = await createUserWithEmailAndPassword(auth, email, password);
          await createUser(user.uid, {
            email: user.email!,
            createdAt: new Date(),
          });
          await sendEmailVerification(user);
          window.location.href = `${prefix}/onboarding`;
        }
      } catch (err: unknown) {
        isSubmitting = false;
        const code =
          typeof err === "object" && err !== null && "code" in err
            ? String((err as { code: unknown }).code)
            : "";
        errorEl.textContent = code
          ? friendlyError(code)
          : s["auth.error.generic"];
        errorEl.style.display = "block";
      }
    });
  });
</script>
