<div class="auth-wrap">
  <header class="auth-header">
    <h1 id="auth-title" class="auth-title">Create an Account</h1>
  </header>

  <form id="auth-form" class="auth-form">
    <div class="field">
      <label class="label" for="email">Email</label>
      <input
        id="email"
        type="email"
        class="input"
        placeholder="you@example.com"
        required
        autocomplete="email"
      />
    </div>

    <div class="field">
      <div class="field-label-row">
        <label class="label" for="password">Password</label>
        <button type="button" id="forgot-link" class="btn-link forgot-btn" style="display:none;"
          >Forgot?</button
        >
      </div>
      <input
        id="password"
        type="password"
        class="input"
        placeholder="••••••••"
        required
        autocomplete="current-password"
      />
    </div>
    <p id="auth-error" class="msg-err" style="display:none;"></p>

    <div class="auth-footer">
      <p class="auth-sub already-have">
        Already have one?
        <a href="#" id="toggle-link" class="toggle-link">Log in instead</a>
      </p>
      <button id="submit-btn" type="submit" class="btn-solid auth-submit-button">Sign Up</button>
    </div>
  </form>

  <div id="forgot-section" style="display:none;">
    <div class="field">
      <label class="label" for="forgot-email">Email</label>
      <input
        id="forgot-email"
        type="email"
        class="input"
        placeholder="you@example.com"
        autocomplete="email"
      />
    </div>
    <p id="forgot-error" class="msg-err" style="display:none;"></p>
    <p id="forgot-success" class="msg-ok" style="display:none;">
      Check your inbox for a reset link.
    </p>
    <div class="auth-footer">
      <button id="forgot-submit" type="button" class="btn-solid auth-submit-button">
        Send reset link
      </button>
    </div>
    <div class="forgot-back-row">
      <button id="forgot-back" type="button" class="btn-link">← Back to log in</button>
    </div>
  </div>
</div>

<style>
  .auth-wrap {
    width: 100%;
    max-width: 560px;
    margin: clamp(2rem, 4vw, 4rem) auto;
    display: grid;
    grid-auto-rows: min-content;
    gap: 1.5rem;
    padding: 0 15px;
    box-sizing: border-box;
    overflow: hidden;

    @media (--bp-desktop) {
      padding: 0;
    }
  }

  .auth-header {
    display: grid;
    gap: 0.3rem;
  }

  .auth-title {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-dark);
  }

  .auth-sub {
    font-size: 0.88rem;
    color: var(--color-muted);
    margin-top: -5px;
  }

  .toggle-link {
    color: var(--color-dark);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid #ccc;
    transition: border-color 0.15s;
  }
  .toggle-link:hover {
    border-color: var(--color-dark);
  }

  .auth-form {
    display: grid;
    grid-auto-rows: min-content;
    gap: 1.5rem;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
    margin-bottom: 25vh;
  }

  .field-label-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .forgot-btn {
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--color-muted);
    border-bottom-color: transparent;
  }

  .forgot-btn:hover {
    color: var(--color-dark);
    border-bottom-color: var(--color-dark);
  }

  #forgot-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 25vh;
  }

  .forgot-back-row {
    display: flex;
    justify-content: flex-end;
  }

  .auth-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 25px;
  }

  .already-have {
    margin-top: 0;
  }

  @media (max-width: 520px) {
    .auth-footer {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
    }

    .auth-submit-button {
      width: 100%;
    }
  }
</style>

<script>
  import { auth } from "../lib/firebase.ts";
  import {
    createUserWithEmailAndPassword,
    onAuthStateChanged,
    signInWithEmailAndPassword,
    sendEmailVerification,
    sendPasswordResetEmail,
  } from "firebase/auth";
  import { friendlyError } from "../lib/auth.ts";
  import { createUser } from "../lib/firestore.ts";

  let isLogin = false;
  let lastSubmit = 0;
  let isSubmitting = false;
  let unsubscribeAuth: (() => void) | null = null;

  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("auth-form") as HTMLFormElement;
    if (!form) return;

    const toggleLink = document.getElementById("toggle-link")!;
    const submitBtn = document.getElementById("submit-btn")!;
    const authTitle = document.getElementById("auth-title")!;
    const authSub = document.querySelector<HTMLElement>(".auth-sub")!;
    const errorEl = document.getElementById("auth-error")!;
    const forgotLink = document.getElementById("forgot-link") as HTMLButtonElement;
    const forgotSection = document.getElementById("forgot-section")!;
    const forgotEmailInput = document.getElementById("forgot-email") as HTMLInputElement;
    const forgotSubmit = document.getElementById("forgot-submit") as HTMLButtonElement;
    const forgotBack = document.getElementById("forgot-back") as HTMLButtonElement;
    const forgotError = document.getElementById("forgot-error")!;
    const forgotSuccess = document.getElementById("forgot-success")!;

    unsubscribeAuth?.();
    unsubscribeAuth = onAuthStateChanged(auth, (user) => {
      if (!user) return;
      if (isSubmitting) return;
      window.location.href = user.emailVerified ? "/community" : "/verify-email";
    });

    function showForgotView() {
      form.style.display = "none";
      forgotSection.style.display = "flex";
      authTitle.textContent = "Reset Password";
      authSub.style.display = "none";
      forgotEmailInput.value = (document.getElementById("email") as HTMLInputElement).value;
      forgotError.style.display = "none";
      forgotSuccess.style.display = "none";
      forgotSubmit.disabled = false;
      forgotSubmit.textContent = "Send reset link";
    }

    function showLoginView() {
      forgotSection.style.display = "none";
      form.style.display = "grid";
      authTitle.textContent = "Log In";
      authSub.style.display = "";
    }

    // Reset state on each page load
    isLogin = false;
    submitBtn.textContent = "Sign Up";
    authTitle.textContent = "Create an Account";
    toggleLink.textContent = "Log in instead";
    forgotLink.style.display = "none";
    forgotSection.style.display = "none";
    form.style.display = "grid";
    authSub.style.display = "";

    forgotLink.addEventListener("click", () => showForgotView());

    forgotBack.addEventListener("click", () => showLoginView());

    forgotSubmit.addEventListener("click", async () => {
      const email = forgotEmailInput.value.trim();
      forgotError.style.display = "none";
      forgotSuccess.style.display = "none";

      if (!email) {
        forgotError.textContent = "Please enter your email address.";
        forgotError.style.display = "block";
        return;
      }

      forgotSubmit.disabled = true;
      forgotSubmit.textContent = "Sending…";

      try {
        await sendPasswordResetEmail(auth, email);
        forgotSuccess.style.display = "block";
        forgotSubmit.textContent = "Sent";
      } catch {
        forgotError.textContent =
          "Could not send reset email. Please check the address and try again.";
        forgotError.style.display = "block";
        forgotSubmit.disabled = false;
        forgotSubmit.textContent = "Send reset link";
      }
    });

    toggleLink.addEventListener("click", (e) => {
      e.preventDefault();
      isLogin = !isLogin;
      submitBtn.textContent = isLogin ? "Log In" : "Sign Up";
      toggleLink.textContent = isLogin ? "Sign up instead" : "Log in instead";
      authTitle.textContent = isLogin ? "Log In" : "Create an Account";
      forgotLink.style.display = isLogin ? "inline" : "none";
      errorEl.style.display = "none";
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorEl.style.display = "none";

      const now = Date.now();
      if (now - lastSubmit < 5000) {
        errorEl.textContent = "Please wait a moment before trying again.";
        errorEl.style.display = "block";
        return;
      }
      lastSubmit = now;

      const email = (document.getElementById("email") as HTMLInputElement).value;
      const password = (document.getElementById("password") as HTMLInputElement).value;

      try {
        isSubmitting = true;
        if (isLogin) {
          const { user } = await signInWithEmailAndPassword(auth, email, password);
          window.location.href = user.emailVerified ? "/profile" : "/verify-email";
        } else {
          const { user } = await createUserWithEmailAndPassword(auth, email, password);
          await createUser(user.uid, {
            email: user.email!,
            createdAt: new Date(),
          });
          await sendEmailVerification(user);
          window.location.href = "/verify-email";
        }
      } catch (err: unknown) {
        isSubmitting = false;
        const code =
          typeof err === "object" && err !== null && "code" in err
            ? String((err as { code: unknown }).code)
            : "";
        errorEl.textContent = code
          ? friendlyError(code)
          : "Something went wrong. Please try again.";
        errorEl.style.display = "block";
      }
    });
  });
</script>
