---
import "../styles/global.css";
---

<nav transition:persist>
  <div class="nav-links">
    <a href="/info" class="nav-link">INFO</a>
    <a href="/community" class="nav-link nav-center">COMMUNITY</a>
    <a href="/signup" class="nav-link nav-right" id="nav-join">LOGIN</a>
    <a href="/profile" class="nav-link nav-right" id="nav-profile" style="display:none;">PROFILE</a>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--color-bg);
    line-height: 1;
  }

  /* ── Nav links row ── */
  .nav-links {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: 10px 15px;
    max-width: 1200px;
    box-sizing: border-box;
    margin: auto;
  }

  .nav-link {
    position: relative;
    justify-self: start;
    font-family: "Archivo", sans-serif;
    font-size: var(--font-size-base);
    font-weight: 600;
    text-decoration: none;
    color: var(--color-dark);
    transition: color 0.15s;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    right: 0;
    height: 1.5px;
    background: var(--color-dark);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-link:hover {
    color: var(--color-muted);
  }

  .nav-link--active::after {
    transform: scaleX(1);
  }

  /* Center item */
  .nav-center {
    justify-self: center;
    text-align: center;
  }

  /* Right item */
  .nav-right {
    justify-self: end;
    text-align: right;
  }
</style>

<script>
  import { auth } from "../lib/firebase.ts";
  import { onAuthStateChanged } from "firebase/auth";

  let unsubscribeAuth: (() => void) | null = null;

  function normalisePath(path: string): string {
    return path.replace(/\/+$/, "") || "/";
  }

  function setActiveLink() {
    const path = normalisePath(window.location.pathname);
    document.querySelectorAll<HTMLAnchorElement>(".nav-link").forEach((link) => {
      const isActive = normalisePath(link.pathname) === path;
      link.classList.toggle("nav-link--active", isActive);
      if (isActive) {
        link.setAttribute("aria-current", "page");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  }

  document.addEventListener("astro:page-load", () => {
    setActiveLink();

    const navJoin = document.getElementById("nav-join");
    const navProfile = document.getElementById("nav-profile");
    if (!navJoin || !navProfile) return;

    unsubscribeAuth?.();
    unsubscribeAuth = onAuthStateChanged(auth, (user) => {
      navJoin.style.display = user ? "none" : "block";
      navProfile.style.display = user ? "block" : "none";
      setActiveLink();
    });
  });
</script>
