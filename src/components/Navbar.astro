---
import "../styles/global.css";
---

<nav transition:persist>
  <div class="brand-ticker">
    <a href="/" class="brand-link">
      <div class="brand-track">
        <span>VSCN</span><span>VSCN</span><span>VSCN</span><span>VSCN</span>
        <span>VSCN</span><span>VSCN</span><span>VSCN</span><span>VSCN</span>
        <span>VSCN</span><span>VSCN</span><span>VSCN</span><span>VSCN</span>
        <span>VSCN</span><span>VSCN</span><span>VSCN</span><span>VSCN</span>
      </div>
    </a>
  </div>

  <div class="nav-links">
    <a href="/info" class="nav-link">Info</a>
    <a href="/community" class="nav-link nav-center">Community</a>
    <a href="/signup" class="nav-link nav-right" id="nav-join">Join</a>
    <a href="/profile" class="nav-link nav-right" id="nav-profile" style="display:none;">Profile</a>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--color-bg);
    overflow: hidden;
    line-height: 1;
  }

  .brand-ticker {
    display: block;
    width: 100%;
    overflow: hidden;
    height: 8vh;
  }

  .brand-link {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .brand-link:visited {
    color: black;
  }

  .brand-track {
    display: flex;
    gap: 0;
    white-space: nowrap;
    width: max-content;
    align-items: baseline;
    animation: nav-scroll 32s linear infinite;
    font-weight: 700;
    font-size: 8vh;
    letter-spacing: -0.03em;
    color: var(--color-dark);
  }

  .brand-track span {
    padding-right: 0;
    height: min-content;
  }

  @keyframes nav-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  /* ── Nav links row ── */
  .nav-links {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: 10px 5px;
    max-width: 720px;
    margin: auto;
  }

  .nav-link {
    font-size: var(--font-size-base);
    font-weight: 400;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition:
      color 0.15s,
      font-weight 0.15s;
    .nav-link:hover {
      color: #000;
    }
  }

  .nav-link--active {
    font-weight: 700;
    color: var(--color-dark);
  }

  /* Left item: default (justify-self: start) */
  /* Center item */
  .nav-center {
    justify-self: center;
    text-align: center;
  }

  /* Right item */
  .nav-right {
    justify-self: end;
    text-align: right;
  }
</style>

<script>
  import { auth } from "../lib/firebase.ts";
  import { onAuthStateChanged } from "firebase/auth";

  let unsubscribeAuth: (() => void) | null = null;

  function normalisePath(path: string): string {
    return path.replace(/\/+$/, "") || "/";
  }

  function setActiveLink() {
    const path = normalisePath(window.location.pathname);
    document.querySelectorAll<HTMLAnchorElement>(".nav-link").forEach((link) => {
      const isActive = normalisePath(link.pathname) === path;
      link.classList.toggle("nav-link--active", isActive);
      if (isActive) {
        link.setAttribute("aria-current", "page");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  }

  document.addEventListener("astro:page-load", () => {
    setActiveLink();

    const navJoin = document.getElementById("nav-join");
    const navProfile = document.getElementById("nav-profile");
    if (!navJoin || !navProfile) return;

    unsubscribeAuth?.();
    unsubscribeAuth = onAuthStateChanged(auth, (user) => {
      navJoin.style.display = user ? "none" : "block";
      navProfile.style.display = user ? "block" : "none";
      setActiveLink();
    });
  });
</script>
