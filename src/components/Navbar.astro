---
import "../styles/global.css";
---

<nav transition:persist="navbar">
  <div class="nav-links">
    <a href="/info" class="nav-link" id="nav-info">INFO</a>
    <a href="/community" class="nav-link nav-center" id="nav-community">COMMUNITY</a>
    <div class="nav-right-group">
      <a href="/signup" class="nav-link" id="nav-join">LOGIN</a>
      <a href="/profile" class="nav-link" id="nav-profile" style="display:none;">PROFILE</a>
    </div>
  </div>
</nav>

<a href="/de" class="lang-toggle" id="nav-lang" transition:persist="lang-toggle">
  <span class="lang-cur">EN</span><span class="lang-sep"> / </span><span class="lang-tgt">DE</span>
</a>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--color-bg);
    line-height: 1;
  }

  .nav-links {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: 10px 15px;
    width: 100%;
    max-width: 900px;
    box-sizing: border-box;
    margin: auto;
  }

  .nav-link {
    position: relative;
    justify-self: start;
    font-family: "Archivo", sans-serif;
    font-size: var(--font-size-base);
    font-weight: 600;
    text-decoration: none;
    color: var(--color-dark);
    transition: color 0.15s;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    right: 0;
    height: 1.5px;
    background: var(--color-dark);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-link:hover {
    color: var(--color-muted);
  }

  .nav-link--active::after {
    transform: scaleX(1);
  }

  .nav-center {
    justify-self: center;
    text-align: center;
  }

  .nav-right-group {
    display: flex;
    gap: 1.25rem;
    justify-self: end;
    align-items: center;
  }

  .lang-toggle {
    position: fixed;
    bottom: 20px;
    right: 30px;
    z-index: 20;
    font-family: "Archivo", sans-serif;
    font-size: var(--font-size-base);
    text-decoration: none;
  }

  .lang-toggle :global(.lang-sep) {
    color: var(--color-muted);
  }

  .lang-toggle :global(.lang-cur) {
    color: var(--color-dark);
    font-weight: 600;
  }

  .lang-toggle :global(.lang-tgt) {
    color: var(--color-muted);
    font-weight: 400;
    transition: color 0.15s;
  }

  .lang-toggle:hover :global(.lang-tgt) {
    color: var(--color-dark);
  }
</style>

<script>
  import { auth } from "../lib/firebase.ts";
  import { onAuthStateChanged } from "firebase/auth";

  type Lang = "en" | "de";

  const navLabels: Record<
    Lang,
    { info: string; community: string; login: string; profile: string }
  > = {
    en: { info: "INFO", community: "COMMUNITY", login: "LOGIN", profile: "PROFILE" },
    de: { info: "INFO", community: "COMMUNITY", login: "ANMELDEN", profile: "PROFIL" },
  };

  let unsubscribeAuth: (() => void) | null = null;

  function normalisePath(path: string): string {
    return path.replace(/\/+$/, "") || "/";
  }

  function setActiveLink() {
    const path = normalisePath(window.location.pathname);
    document.querySelectorAll<HTMLAnchorElement>(".nav-link").forEach((link) => {
      if (link.id === "nav-lang") return;
      const isActive = normalisePath(link.pathname) === path;
      link.classList.toggle("nav-link--active", isActive);
      if (isActive) {
        link.setAttribute("aria-current", "page");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  }

  // Update nav links and language toggle for the given language + current path.
  // Called both in astro:before-swap (with new page values) and astro:page-load.
  function updateNavLinks(lang: Lang, currentPath: string) {
    const prefix = lang === "de" ? "/de" : "";
    const labels = navLabels[lang];
    const normPath = normalisePath(currentPath);

    const navInfo = document.getElementById("nav-info") as HTMLAnchorElement | null;
    const navCommunity = document.getElementById("nav-community") as HTMLAnchorElement | null;
    const navJoin = document.getElementById("nav-join") as HTMLAnchorElement | null;
    const navProfile = document.getElementById("nav-profile") as HTMLAnchorElement | null;
    const navLang = document.getElementById("nav-lang") as HTMLAnchorElement | null;

    if (navInfo) {
      navInfo.href = `${prefix}/info`;
      navInfo.textContent = labels.info;
    }
    if (navCommunity) {
      navCommunity.href = `${prefix}/community`;
      navCommunity.textContent = labels.community;
    }
    if (navJoin) {
      navJoin.href = `${prefix}/login`;
      navJoin.textContent = labels.login;
    }
    if (navProfile) {
      navProfile.href = `${prefix}/profile`;
      navProfile.textContent = labels.profile;
    }

    if (navLang) {
      if (lang === "de") {
        const enPath = normalisePath(normPath.replace(/^\/de/, "")) || "/";
        navLang.href = enPath;
        navLang.innerHTML =
          '<span class="lang-tgt">EN</span><span class="lang-sep"> / </span><span class="lang-cur">DE</span>';
      } else {
        navLang.href = "/de" + normPath;
        navLang.innerHTML =
          '<span class="lang-cur">EN</span><span class="lang-sep"> / </span><span class="lang-tgt">DE</span>';
      }
    }
  }

  // Pre-update the nav BEFORE the DOM swap so there is no flash of
  // wrong-language links during the View Transition animation.
  document.addEventListener("astro:before-swap", (e) => {
    const event = e as unknown as { newDocument?: Document };
    const newDoc = event.newDocument;
    if (!newDoc) return;
    const newLang = (newDoc.documentElement?.lang ?? "en") as Lang;
    const newPath = newDoc.URL
      ? normalisePath(new URL(newDoc.URL).pathname)
      : normalisePath(window.location.pathname);
    updateNavLinks(newLang === "de" ? "de" : "en", newPath);
  });

  // Handle initial page load and post-navigation cleanup (active link, auth).
  document.addEventListener("astro:page-load", () => {
    const lang = (document.documentElement.lang ?? "en") as Lang;
    updateNavLinks(lang === "de" ? "de" : "en", window.location.pathname);
    setActiveLink();

    const navJoin = document.getElementById("nav-join");
    const navProfile = document.getElementById("nav-profile");
    if (!navJoin || !navProfile) return;

    unsubscribeAuth?.();
    unsubscribeAuth = onAuthStateChanged(auth, (user) => {
      navJoin.style.display = user ? "none" : "block";
      navProfile.style.display = user ? "block" : "none";
      setActiveLink();
    });
  });
</script>
