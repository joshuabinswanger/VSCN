---
import { useTranslations } from "../i18n/utils.ts";
import type { Lang } from "../i18n/utils.ts";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
---

<div class="info-page">
  <section class="info-section">
    <p>{t("info.intro")}</p>
    <p>{t("info.p2")}</p>
  </section>

  <section class="info-section">
    <h2 class="info-heading">{t("info.h2.building")}</h2>
    <ul class="info-list">
      <li>{t("info.li.1")}</li>
      <li>{t("info.li.2")}</li>
      <li>{t("info.li.3")}</li>
      <li>{t("info.li.4")}</li>
    </ul>
  </section>

  <section class="info-section">
    <h2 class="info-heading">{t("info.h2.started")}</h2>
    <p class="info-contact">
      {t("info.p4")}
      <a href="mailto:info@vscn.ch"><!--email_off-->info@vscn.ch<!--/email_off--></a>
    </p>
  </section>

  <section id="info-signup-cta" class="info-signup-cta" style="display:none;">
    <a href={lang === "de" ? "/de/signup" : "/signup"} class="btn-solid">{t("signup.cta.info")}</a>
  </section>
</div>

<style>
  .info-page {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 2rem;
    padding-bottom: 8rem;
    margin: 0 15px;

    @media (--bp-desktop) {
      padding-top: 4rem;

      margin: 0 0px;
    }
  }

  .info-header {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .info-title {
    font-family: "Archivo", sans-serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-dark);
    line-height: 1.1;
  }

  .info-sub {
    font-size: 0.88rem;
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }

  .info-section {
    display: flex;
    flex-direction: column;
    padding-bottom: 1rem;
  }

  .info-heading {
    font-family: "Archivo", sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-dark);
  }

  .info-section p {
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    color: #333;
    line-height: 1.85;
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-left: 1.25rem;
  }

  .info-list li {
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    color: #333;
    line-height: 1.6;
  }

  .info-contact {
    display: block;
  }

  .info-contact a {
    color: var(--color-dark);
    border-bottom: 0;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .info-contact a:hover,
  .info-contact a:focus-visible {
    opacity: 0.5;
  }

  .info-signup-cta {
    padding-top: 4rem;
    display: flex;
    justify-content: left;
  }
</style>

<script>
  import { auth } from "../lib/firebase.ts";
  import { onAuthStateChanged } from "firebase/auth";

  document.addEventListener("astro:page-load", () => {
    const cta = document.getElementById("info-signup-cta");
    if (!cta) return;

    onAuthStateChanged(auth, (user) => {
      cta.style.display = user ? "none" : "flex";
    });
  });
</script>
