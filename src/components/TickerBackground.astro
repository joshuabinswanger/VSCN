---
// Fullscreen scrolling VSCN ticker background.
// Wrap your page content in a <slot /> on top of this.
---

<div class="ticker-bg" transition:animate="none">
  <div class="ticker-rows">
    {[60, 68, 76, 84, 92, 100, 108, 116].map((speed) => (
      <div class="ticker-row">
        <div class="ticker-track" style={`animation-duration: ${speed}s`}>
          <span>VSCN</span><span>VSCN</span><span>VSCN</span><span>VSCN</span>
        </div>
      </div>
    ))}
  </div>

  <div class="ticker-gradient" />

  <div class="ticker-content">
    <slot />
  </div>
</div>

<style>
  .ticker-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  /* ── Rows ── */
  .ticker-rows {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
  }

  .ticker-row {
    flex: 1;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .ticker-track {
    display: flex;
    white-space: nowrap;
    width: max-content;
    animation: ticker-scroll linear infinite;
  }

  .ticker-track span {
    font-family: "Archivo", sans-serif;
    font-size: 12vh;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-dark);
    user-select: none;
  }

  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Gradient overlay ── */
  .ticker-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(250,250,250,0.15) 0%,
      rgba(250,250,250,0.55) 35%,
      rgba(250,250,250,0.85) 65%,
      var(--color-bg) 100%
    );
    pointer-events: none;
  }

  /* ── Slot content sits above everything ── */
  .ticker-content {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  @media (max-width: 600px) {
    .ticker-track span { font-size: 8vh; }
  }
</style>

<script>
  function fillTickers() {
    document.querySelectorAll<HTMLElement>(".ticker-track").forEach((track) => {
      // Clone existing spans in batches until track covers 3× viewport width.
      // -50% animation needs ≥ 2× — the extra buffer eliminates any edge-case gap.
      while (track.scrollWidth < window.innerWidth * 3) {
        const spans = Array.from(track.querySelectorAll("span"));
        spans.forEach((s) => track.appendChild(s.cloneNode(true)));
      }
    });
  }

  document.addEventListener("astro:page-load", fillTickers);

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(fillTickers, 200);
  });
</script>
