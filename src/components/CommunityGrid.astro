---
import type { PublicProfileDoc } from "../lib/firestore.ts";
import MemberCard from "./MemberCard.astro";
import { useTranslations } from "../i18n/utils.ts";
import type { Lang } from "../i18n/utils.ts";

interface Props {
  members: (PublicProfileDoc & { uid: string })[];
  lang?: Lang;
}

const { members, lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const memberLabel = members.length === 1 ? t('community.member') : t('community.members');
---

<div class="community-wrapper" data-lang={lang}>
  <div class="page-header">
    <h1 class="page-title">
      <span class="member-count">
        {members.length} {memberLabel}
      </span>
    </h1>
  </div>

  <div id="member-grid" class="member-grid">
    {members.length === 0 && <p class="state-msg">{t('community.empty')}</p>}
    {members.map((m) => <MemberCard member={m} lang={lang} />)}
  </div>

  <div id="community-signup-cta" class="community-signup-cta" style="display:none;">
    <a href={lang === 'de' ? '/de/signup' : '/signup'} class="btn-solid">{t('signup.cta.community')}</a>
  </div>
</div>

<style>
  .community-wrapper {
    padding-bottom: 5rem;
  }
  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    display: flex;
    align-items: baseline;
    gap: 15px;
    flex-wrap: wrap;
    font-family: "Archivo", sans-serif;
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-dark);
  }

  .member-count {
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0;
    color: #bbb;
  }

  .state-msg {
    color: #999;
    font-size: 0.9rem;
  }

  .member-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1rem;
    width: 100%;
    align-items: start;
  }

  @media (--bp-desktop), (--bp-desktop-wide) {
    .member-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      align-items: start;
      gap: 3rem;
    }
  }

  @media (width <= 1050px) {
    .member-grid {
      grid-template-columns: repeat(2, minmax(0, 330px));
      gap: 2rem;
    }
  }

  @media (--bp-mobile) {
    .member-grid {
      grid-template-columns: minmax(0, 400px);
    }
  }

  .community-signup-cta {
    padding-top: 5rem;
    display: flex;
    justify-content: center;
  }
</style>

<script>
  import { auth } from "../lib/firebase.ts";
  import { onAuthStateChanged } from "firebase/auth";

  document.addEventListener("astro:page-load", () => {
    const cta = document.getElementById("community-signup-cta");
    if (cta) {
      onAuthStateChanged(auth, (user) => {
        cta.style.display = user ? "none" : "flex";
      });
    }
  });
</script>
