<div class="community-wrapper">
  <div class="page-header">
    <h1 class="page-title">
      <span id="member-count" class="member-count" aria-live="polite"></span>
    </h1>
  </div>

  <div id="member-grid" class="member-grid" aria-live="polite">
    <p class="state-msg">Loading members...</p>
  </div>
</div>
<style>
  .community-wrapper {
    padding-bottom: 5rem;
  }
  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    display: flex;
    align-items: baseline;
    gap: 15px;
    flex-wrap: wrap;
    font-family: var(--font-space-mono, "Space Mono", monospace);
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-dark);
  }

  .member-count {
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0;
    color: #bbb;
  }

  .member-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1rem;
    width: 100%;
    align-items: start;
  }

  @media (--bp-desktop), (--bp-desktop-wide) {
    .member-grid {
      grid-template-columns: repeat(3, minmax(330px, 1fr));
      align-items: start;
    }
  }

  @media (width <= 1050px) {
    .member-grid {
      grid-template-columns: repeat(2, minmax(330px, 1fr));
    }
  }

  @media (--bp-mobile) {
    .member-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  :global(.state-msg) {
    color: #999;
    font-size: 0.9rem;
  }

  :global(.member-card) {
    display: grid;
    width: 85vw;
    min-width: 0;
    box-sizing: border-box;
    grid-template-columns: min-content minmax(0, 1fr) 16px;
    align-items: center;
    gap: 5px 20px;
    padding: 10px 15px 10px 20px;
    border: 1.5px solid #e8e8e8;
    border-radius: var(--radius-sm);
    background: #ffffff;
    transition:
      border-color 0.2s,
      filter 0.2s;
    text-align: center;
    align-self: start;

    @media (--bp-desktop) {
      grid-template-columns: min-content minmax(0, 1fr);
      padding: 15px 25px 15px 15px;
      gap: 5px 25px;
      width: 330px;
    }
  }

  :global(.member-card:hover) {
    border-color: var(--color-border);
  }

  @media (--bp-desktop), (--bp-desktop-wide) {
    :global(.member-card:hover),
    :global(.member-card:focus-within) {
      filter: drop-shadow(0 4px 5px rgba(0, 0, 0, 0.07));
    }

    :global(.member-card:has(.member-bio):hover),
    :global(.member-card:has(.member-bio):focus-within) {
      border-bottom-right-radius: 0;
      border-bottom-left-radius: 0;
    }
  }

  :global(.member-avatar-wrap) {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.member-avatar) {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    align-items: center;
    justify-content: center;
    border: 1.5px solid #e5e5e5;
  }

  :global(.member-avatar--placeholder) {
    background: #f0f0f0;
    display: flex;
    font-size: 1.8rem;
    color: #bbb;
  }

  :global(.member-info) {
    display: grid;
    grid-template-rows: min-content min-content min-content;
    text-align: left;
    align-items: start;
    gap: 0.2rem;
    width: 100%;
    min-width: 0;
  }

  :global(.member-name) {
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-dark);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  :global(.member-role) {
    font-size: 0.78rem;
    color: var(--color-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  :global(.member-portfolio) {
    display: inline-block;
    margin-top: 0.4rem;
    color: black;
    text-decoration: underline;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
    transition: color 0.15s;
  }

  :global(.member-portfolio:hover) {
    color: #000;
  }

  :global(.member-bio-toggle) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 24px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    transition:
      color 0.15s,
      transform 0.15s;
  }

  :global(.member-bio-toggle:hover) {
    color: #333;
  }

  :global(.member-bio-arrow) {
    display: block;
    width: 12px;
    height: 12px;
  }

  :global(.member-card.is-expanded .member-bio-toggle) {
    transform: rotate(180deg);
  }

  :global(.member-bio) {
    display: none;
    grid-column: 1 / -1;
    margin: 10px 0 0;
    padding-top: 0;

    color: #444;
    font-size: var(--font-size-base);
    line-height: 1.6;
    text-align: left;
    min-width: 0;
    max-width: calc(85vw - 40px);
  }

  :global(.member-card.is-expanded .member-bio) {
    display: block;
  }

  @media (--bp-desktop), (--bp-desktop-wide) {
    :global(.member-card) {
      position: relative;
    }

    :global(.member-bio-toggle) {
      display: none;
    }

    :global(.member-bio) {
      position: absolute;
      top: 100%;
      left: -16.5px;
      z-index: 5;
      display: none;
      width: 330px;
      box-sizing: border-box;
      margin: 0;
      padding: 25px;
      border: 1.5px solid var(--color-border);
      border-top: 0;
      border-radius: 0 0 var(--radius-sm) var(--radius-sm);
      background: #ffffff;
    }

    :global(.member-card:hover .member-bio),
    :global(.member-card:focus-within .member-bio) {
      display: block;
    }
  }
</style>

<script>
  import { getMembers, type PublicProfileDoc } from "../lib/firestore.ts";
  import { normaliseUrl } from "../lib/validation.ts";
  import downArrowUrl from "../assets/downarrow.svg";

  type Member = PublicProfileDoc & { uid: string };

  const desktopQuery = window.matchMedia("(width >= 1120px)");
  let hasDesktopQueryListener = false;

  function text(value: string): Text {
    return document.createTextNode(value);
  }

  function createStateMessage(message: string): HTMLParagraphElement {
    const element = document.createElement("p");
    element.className = "state-msg";
    element.append(text(message));
    return element;
  }

  function collapseMobileBioPanels() {
    document.querySelectorAll(".member-card.is-expanded").forEach((card) => {
      card.classList.remove("is-expanded");
    });
    document.querySelectorAll<HTMLButtonElement>(".member-bio-toggle").forEach((button) => {
      button.setAttribute("aria-expanded", "false");
    });
  }

  function createMemberCard(member: Member): HTMLElement {
    const card = document.createElement("article");
    card.className = "member-card";

    const avatarWrap = document.createElement("div");
    avatarWrap.className = "member-avatar-wrap";

    const displayName = member.displayName || "Anonymous";

    if (member.photoURL) {
      const img = document.createElement("img");
      img.className = "member-avatar";
      img.src = member.photoURL;
      img.alt = displayName;
      avatarWrap.append(img);
    } else {
      const placeholder = document.createElement("div");
      placeholder.className = "member-avatar member-avatar--placeholder";
      placeholder.append(text(displayName[0]?.toUpperCase() ?? "?"));
      avatarWrap.append(placeholder);
    }

    const info = document.createElement("div");
    info.className = "member-info";

    const name = document.createElement("div");
    name.className = "member-name";
    name.append(text(displayName));
    info.append(name);

    if (member.role) {
      const role = document.createElement("div");
      role.className = "member-role";
      role.append(text(member.role));
      info.append(role);
    }

    const href = normaliseUrl(member.portfolio ?? "");
    if (href) {
      const portfolio = document.createElement("a");
      portfolio.className = "member-portfolio";
      portfolio.href = href;
      portfolio.target = "_blank";
      portfolio.rel = "noopener noreferrer";
      portfolio.append(text(member.portfolio));
      info.append(portfolio);
    }

    if (member.bio) {
      const toggle = document.createElement("button");
      const bioId = `member-bio-${member.uid}`;
      toggle.className = "member-bio-toggle";
      toggle.type = "button";
      toggle.setAttribute("aria-expanded", "false");
      toggle.setAttribute("aria-controls", bioId);
      toggle.setAttribute("aria-label", `Show bio for ${displayName}`);

      const arrow = document.createElement("img");
      arrow.className = "member-bio-arrow";
      arrow.src = downArrowUrl.src;
      arrow.alt = "";
      arrow.setAttribute("aria-hidden", "true");
      toggle.append(arrow);

      const bio = document.createElement("p");
      bio.id = bioId;
      bio.className = "member-bio";
      bio.append(text(member.bio));

      toggle.addEventListener("click", () => {
        const expanded = card.classList.toggle("is-expanded");
        toggle.setAttribute("aria-expanded", String(expanded));
        toggle.setAttribute("aria-label", `${expanded ? "Hide" : "Show"} bio for ${displayName}`);
      });

      card.append(avatarWrap, info, toggle, bio);
      return card;
    }

    const spacer = document.createElement("div");
    spacer.setAttribute("aria-hidden", "true");
    card.append(avatarWrap, info, spacer);
    return card;
  }

  document.addEventListener("astro:page-load", async () => {
    const grid = document.getElementById("member-grid");
    const count = document.getElementById("member-count");
    if (!grid || !count) return;

    if (!hasDesktopQueryListener) {
      desktopQuery.addEventListener("change", (event) => {
        if (!event.matches) collapseMobileBioPanels();
      });
      hasDesktopQueryListener = true;
    }

    try {
      const members = await getMembers();
      grid.replaceChildren();

      if (members.length === 0) {
        grid.replaceChildren(createStateMessage("No members yet."));
        count.textContent = "";
        return;
      }

      count.textContent = `${members.length} member${members.length === 1 ? "" : "s"}`;
      grid.append(...members.map(createMemberCard));
    } catch (err) {
      console.error(err);
      grid.replaceChildren(createStateMessage("Could not load members."));
      count.textContent = "";
    }
  });
</script>
