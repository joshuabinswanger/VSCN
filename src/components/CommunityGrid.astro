---
import type { PublicProfileDoc } from "../lib/firestore.ts";
import MemberCard from "./MemberCard.astro";

interface Props {
  members: (PublicProfileDoc & { uid: string })[];
}

const { members } = Astro.props;
---

<div class="community-wrapper">
  <div class="page-header">
    <h1 class="page-title">
      <span class="member-count">
        {members.length} member{members.length !== 1 ? "s" : ""}
      </span>
    </h1>
  </div>

  <div id="member-grid" class="member-grid">
    {members.length === 0 && <p class="state-msg">No members yet.</p>}
    {members.map((m) => <MemberCard member={m} />)}
  </div>
</div>

<style>
  .community-wrapper {
    padding-bottom: 5rem;
  }
  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    display: flex;
    align-items: baseline;
    gap: 15px;
    flex-wrap: wrap;
    font-family: "Archivo", sans-serif;
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-dark);
  }

  .member-count {
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0;
    color: #bbb;
  }

  .state-msg {
    color: #999;
    font-size: 0.9rem;
  }

  .member-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1rem;
    width: 100%;
    align-items: start;
  }

  @media (--bp-desktop), (--bp-desktop-wide) {
    .member-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      align-items: start;
      gap: 3rem;
    }
  }

  @media (width <= 1050px) {
    .member-grid {
      grid-template-columns: repeat(2, minmax(0, 330px));
      gap: 2rem;
    }
  }

  @media (--bp-mobile) {
    .member-grid {
      grid-template-columns: minmax(0, 400px);
    }
  }
</style>

<script>
  const desktopQuery = window.matchMedia("(width >= 1120px)");
  let hasDesktopQueryListener = false;

  function collapseMobileBioPanels() {
    document.querySelectorAll(".member-card-wrap.is-expanded").forEach((wrap) => {
      wrap.classList.remove("is-expanded");
    });
    document.querySelectorAll<HTMLButtonElement>(".member-bio-toggle").forEach((button) => {
      button.setAttribute("aria-expanded", "false");
    });
  }

  function wireBioToggles() {
    document.querySelectorAll<HTMLButtonElement>(".member-bio-toggle").forEach((toggle) => {
      toggle.addEventListener("click", () => {
        const wrap = toggle.closest(".member-card-wrap")!;
        const expanded = wrap.classList.toggle("is-expanded");
        toggle.setAttribute("aria-expanded", String(expanded));
        const name = wrap.querySelector(".member-name")?.textContent ?? "";
        toggle.setAttribute("aria-label", `${expanded ? "Hide" : "Show"} bio for ${name}`);
      });
    });
  }

  document.addEventListener("astro:page-load", () => {
    if (!hasDesktopQueryListener) {
      desktopQuery.addEventListener("change", (event) => {
        if (!event.matches) collapseMobileBioPanels();
      });
      hasDesktopQueryListener = true;
    }
    wireBioToggles();
  });
</script>
