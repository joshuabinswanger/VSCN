---
import type { PublicProfileDoc } from "../lib/firestore.ts";
import { normaliseUrl } from "../lib/validation.ts";
import downArrowUrl from "../assets/downarrow.svg";

interface Props {
  members: (PublicProfileDoc & { uid: string })[];
}

const { members } = Astro.props;
---

<div class="community-wrapper">
  <div class="page-header">
    <h1 class="page-title">
      <span class="member-count">
        {members.length} member{members.length !== 1 ? "s" : ""}
      </span>
    </h1>
  </div>

  <div id="member-grid" class="member-grid">
    {members.length === 0 && <p class="state-msg">No members yet.</p>}
    {members.map((m) => {
      const displayName = m.displayName || "Anonymous";
      const portfolioHref = normaliseUrl(m.portfolio ?? "");
      const bioId = `member-bio-${m.uid}`;
      return (
        <article class="member-card">
          <div class="member-avatar-wrap">
            {m.photoURL ? (
              <img class="member-avatar" src={m.photoURL} alt={displayName} />
            ) : (
              <div class="member-avatar member-avatar--placeholder">
                {displayName[0]?.toUpperCase() ?? "?"}
              </div>
            )}
          </div>

          <div class="member-info">
            <div class="member-name">{displayName}</div>
            {m.role && <div class="member-role">{m.role}</div>}
            {portfolioHref && (
              <a
                class="member-portfolio"
                href={portfolioHref}
                target="_blank"
                rel="noopener noreferrer"
              >
                {m.portfolio}
              </a>
            )}
          </div>

          {m.bio ? (
            <>
              <button
                class="member-bio-toggle"
                type="button"
                aria-expanded="false"
                aria-controls={bioId}
                aria-label={`Show bio for ${displayName}`}
              >
                <img
                  class="member-bio-arrow"
                  src={downArrowUrl.src}
                  alt=""
                  aria-hidden="true"
                />
              </button>
              <p id={bioId} class="member-bio">{m.bio}</p>
            </>
          ) : (
            <div aria-hidden="true" />
          )}
        </article>
      );
    })}
  </div>
</div>

<style>
  .community-wrapper {
    padding-bottom: 5rem;
  }
  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    display: flex;
    align-items: baseline;
    gap: 15px;
    flex-wrap: wrap;
    font-family: var(--font-space-mono, "Space Mono", monospace);
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-dark);
  }

  .member-count {
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0;
    color: #bbb;
  }

  .member-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1rem;
    width: 100%;
    align-items: start;
  }

  @media (--bp-desktop), (--bp-desktop-wide) {
    .member-grid {
      grid-template-columns: repeat(3, minmax(330px, 1fr));
      align-items: start;
    }
  }

  @media (width <= 1050px) {
    .member-grid {
      grid-template-columns: repeat(2, minmax(330px, 1fr));
    }
  }

  @media (--bp-mobile) {
    .member-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>

<style is:global>
  @import "../styles/member-card.css";
</style>

<script>
  const desktopQuery = window.matchMedia("(width >= 1120px)");
  let hasDesktopQueryListener = false;

  function collapseMobileBioPanels() {
    document.querySelectorAll(".member-card.is-expanded").forEach((card) => {
      card.classList.remove("is-expanded");
    });
    document.querySelectorAll<HTMLButtonElement>(".member-bio-toggle").forEach((button) => {
      button.setAttribute("aria-expanded", "false");
    });
  }

  function wireBioToggles() {
    document.querySelectorAll<HTMLButtonElement>(".member-bio-toggle").forEach((toggle) => {
      toggle.addEventListener("click", () => {
        const card = toggle.closest(".member-card")!;
        const expanded = card.classList.toggle("is-expanded");
        toggle.setAttribute("aria-expanded", String(expanded));
        const name = card.querySelector(".member-name")?.textContent ?? "";
        toggle.setAttribute("aria-label", `${expanded ? "Hide" : "Show"} bio for ${name}`);
      });
    });
  }

  document.addEventListener("astro:page-load", () => {
    if (!hasDesktopQueryListener) {
      desktopQuery.addEventListener("change", (event) => {
        if (!event.matches) collapseMobileBioPanels();
      });
      hasDesktopQueryListener = true;
    }
    wireBioToggles();
  });
</script>
