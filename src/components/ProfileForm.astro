---

---

<div id="loading" class="loading-state">Loading profile…</div>

<form id="profile-form" class="profile-form">
  <div class="avatar-wrap">
    <div class="avatar-image">
      <img id="avatar-preview" src="" alt="" class="avatar-img" />
      <div id="avatar-placeholder" class="avatar-placeholder">?</div>
    </div>
    <label class="btn-outline choose-img" for="avatar">
      Choose image
      <input id="avatar" type="file" accept="image/*" style="display:none;" />
    </label>
    <p id="upload-status" class="upload-status" style="display:none;"></p>
  </div>

  <div class="field">
    <label class="label" for="name">Display Name</label>
    <input id="name" type="text" class="input" placeholder="Your name" />
  </div>

  <div class="field">
    <label class="label" for="role">Role</label>
    <input
      id="role"
      type="text"
      class="input"
      placeholder="e.g. Science Illustrator, Researcher, Data Journalist…"
    />
  </div>

  <div class="field">
    <label class="label" for="bio">About you</label>
    <textarea
      id="bio"
      rows="4"
      class="input textarea"
      placeholder="A short description of your work, interests, or background…"></textarea>
    <p class="field-note">Maximum 35 words.</p>
  </div>

  <div class="field">
    <label class="label" for="portfolio">Portfolio / Website</label>
    <div class="input-prefix-wrap">
      <span class="input-prefix">https://</span>
      <input id="portfolio" type="text" class="input input-prefixed" placeholder="yoursite.com" />
    </div>
  </div>

  <div class="field">
    <label class="label" for="social-media">Social Media</label>
    <div class="input-prefix-wrap">
      <span class="input-prefix">https://</span>
      <input
        id="social-media"
        type="text"
        class="input input-prefixed"
        placeholder="linkedin.com/in/yourname"
      />
    </div>
    <p class="field-note">LinkedIn, Instagram, X, Bluesky, etc.</p>
  </div>

  <fieldset class="field field-open-to">
    <legend class="label">I'm here to…</legend>
    <label class="checkbox-label">
      <input type="checkbox" name="open-to" value="offering" />
      Offer services
    </label>
    <label class="checkbox-label">
      <input type="checkbox" name="open-to" value="seeking" />
      Find services
    </label>
    <label class="checkbox-label">
      <input type="checkbox" name="open-to" value="networking" />
      Network &amp; collaborate
    </label>
  </fieldset>

  <div class="field">
    <label class="label" for="tag-input">Tags</label>
    <div class="tag-input-row">
      <input
        id="tag-input"
        type="text"
        class="input"
        placeholder="Add a tag and press Enter"
        maxlength="50"
      />
    </div>
    <p class="field-note">Up to 7 tags. Press Enter to add a new tag.</p>
    <div id="selected-tags" class="tag-list" aria-live="polite"></div>
    <button
      id="tag-suggestions-toggle"
      class="tag-suggestions-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="tag-suggestion-panel"
    >
      Browse tags
    </button>
    <div id="tag-suggestion-panel" class="tag-suggestion-panel" aria-label="Tags" hidden>
      <div id="tag-suggestion-list" class="tag-suggestion-list"></div>
    </div>
  </div>

  <div class="field">
    <label class="label" for="phone">Phone Number</label>
    <input id="phone" type="tel" class="input" placeholder="+41 79 123 45 67" autocomplete="tel" />
    <p class="field-note">
      Hidden from the community page. Used only to help create a VSCN chat group.
    </p>
  </div>

  <div class="preview-section">
    <p class="label">Community card preview</p>
    <article id="preview-card" class="member-card member-card--preview">
      <div class="member-avatar-wrap">
        <img id="preview-avatar-img" class="member-avatar" src="" alt="" style="display:none" />
        <div id="preview-avatar-ph" class="member-avatar member-avatar--placeholder">?</div>
      </div>
      <div class="member-info">
        <div id="preview-name" class="member-name"></div>
        <div id="preview-role" class="member-role" style="display:none"></div>
        <a
          id="preview-portfolio"
          class="member-portfolio"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          style="display:none"></a>
      </div>
      <div aria-hidden="true"></div>
      <p id="preview-bio" class="member-bio" style="display:none"></p>
    </article>
  </div>

  <div class="form-footer">
    <p id="save-msg" class="msg-ok" style="display:none;">
      Changes saved. Your community card will update within a few minutes.
    </p>
    <p id="save-error" class="msg-err" style="display:none;"></p>
    <div class="footer-actions">
      <button id="btn-logout" type="button" class="btn-outline">Log Out</button>
      <button type="submit" class="btn-solid profile-save-button">Save Changes</button>
    </div>
  </div>

  <div class="danger-zone">
    <div id="delete-idle">
      <button type="button" id="btn-delete-start" class="btn-danger-link">Delete account</button>
    </div>

    <div id="delete-confirm" style="display:none;">
      <p class="danger-text">
        This will permanently delete your account, profile, and avatar. This cannot be undone.
      </p>
      <div class="danger-actions">
        <button type="button" id="btn-delete-cancel" class="btn-link">Cancel</button>
        <button type="button" id="btn-delete-confirm" class="btn-danger">Delete my account</button>
      </div>
    </div>

    <div id="delete-reauth" style="display:none;">
      <p class="danger-text">Please enter your password to confirm.</p>
      <input
        id="reauth-password"
        type="password"
        class="input"
        placeholder="••••••••"
        autocomplete="current-password"
      />
      <p id="reauth-error" class="msg-err" style="display:none;"></p>
      <div class="danger-actions">
        <button type="button" id="btn-reauth-cancel" class="btn-link">Cancel</button>
        <button type="button" id="btn-reauth-confirm" class="btn-danger">Confirm delete</button>
      </div>
    </div>
  </div>
</form>

<style>
  .loading-state {
    margin-top: 3rem;
    color: #999;
    font-size: 0.9rem;
  }

  .profile-form {
    display: none;
    grid-auto-rows: min-content;
    gap: 1.5rem;
    width: 100%;
    max-width: 560px;
    margin: clamp(2rem, 4vw, 4rem) auto;
    padding: 0 15px;
    box-sizing: border-box;
    overflow: hidden;

    @media (--bp-desktop) {
      padding: 0;
    }
  }

  .profile-form.is-loaded {
    display: grid;
  }

  .avatar-wrap {
    position: relative;
    display: grid;
    grid-template-columns: min-content 1fr 1fr;
    justify-items: start;
    align-items: center;
    gap: 25px;
    flex-shrink: 0;
  }

  .avatar-img,
  .avatar-placeholder {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
  }

  /* default: show placeholder, hide image */
  .avatar-img {
    display: none;
  }

  /* has-image: show image, hide placeholder */
  .avatar-wrap.has-image .avatar-img {
    display: block;
  }
  .avatar-wrap.has-image .avatar-placeholder {
    display: none;
  }

  .avatar-placeholder {
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: #bbb;
    border: 1.5px solid #e5e5e5;
  }
  .choose-img {
    width: fit-content;
  }

  .form-title {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-dark);
  }
  .form-sub {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-top: 0.2rem;
  }

  .divider {
    border: none;
    border-top: 1px solid #eee;
    margin: 0;
  }

  .field-note {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--color-muted);
  }

  .tag-input-row {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-list:not(:empty) {
    margin-top: 0.5rem;
  }

  .tag-suggestions-toggle {
    width: fit-content;
    margin-top: 0.4rem;
    padding: 0;
    border: none;
    background: transparent;
    color: #333;
    font: inherit;
    font-size: 0.82rem;
    font-weight: 700;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .tag-suggestion-panel {
    margin-top: 0.6rem;
  }

  .tag-suggestion-panel[hidden] {
    display: none;
  }

  .tag-suggestion-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
  }

  :global(.tag-chip) {
    font-family: monospace;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.7rem;
    border-radius: var(--radius-sm);
    border: 1.5px solid #111;
    background: #111;
    color: #fff;
    font-size: 0.83rem;
    font-weight: 500;
    line-height: 1.25;
    cursor: pointer;
    transition:
      background 0.15s,
      border-color 0.15s;
  }

  :global(.tag-chip:hover) {
    background: #333;
    border-color: #333;
  }

  :global(.tag-chip span) {
    opacity: 0.65;
    font-size: 0.95rem;
    line-height: 1;
  }

  :global(.tag-suggestion-chip) {
    font-family: monospace;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 0.6rem;
    min-height: 2.2rem;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--color-border);
    color: var(--color-muted);
    background: #fff;
    font-size: 0.83rem;
    line-height: 1.25;
    text-align: center;
    cursor: pointer;
    transition:
      background 0.15s,
      border-color 0.15s;
  }

  :global(.tag-suggestion-chip:hover) {
    border-color: #999;
    color: #999;
    background: #f5f5f5;
  }

  .input-prefix-wrap {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: border-color 0.15s;
    min-width: 0;
  }
  .input-prefix-wrap:focus-within {
    border-color: #111;
  }

  .input-prefix {
    padding: 8px 10px;
    background: #f5f5f5;
    color: var(--color-muted);
    font-size: 0.88rem;
    border-right: 1.5px solid var(--color-border);
    white-space: nowrap;
  }

  .input-prefixed {
    border: none;
    border-radius: 0;
    flex: 1;
    min-width: 0;
  }
  .input-prefixed:focus {
    border-color: transparent;
  }

  .preview-section {
    padding-top: 0.5rem;
  }

  .preview-section .label {
    display: block;
    margin-bottom: 0.75rem;
  }

  /* In preview context: always show bio inline, hide toggle */
  :global(.member-card--preview) {
    width: auto !important;
    max-width: 360px;
  }

  :global(.member-card--preview .member-bio-toggle) {
    display: none !important;
  }

  :global(.member-card--preview .member-bio) {
    display: block !important;
    position: static !important;
    width: auto !important;
    border: none !important;
    padding: 0 !important;
    margin-top: 10px !important;
  }

  .form-footer {
    padding-top: 25px;
  }

  .footer-actions {
    display: grid;
    gap: 15px;
    grid-template-columns: auto auto;
    justify-content: space-between;
  }

  .profile-save-button {
    margin-left: auto;
  }

  .danger-zone {
    padding-top: 2rem;
    border-top: 1px solid #f0f0f0;
  }

  .danger-text {
    font-size: 0.88rem;
    color: var(--color-muted);
    margin: 0 0 1rem;
    line-height: 1.5;
  }

  .danger-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .btn-danger-link {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    font-size: 0.88rem;
    color: #bbb;
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .btn-danger-link:hover {
    color: var(--color-error);
    border-bottom-color: var(--color-error);
  }

  .btn-danger {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.25rem;
    background: var(--color-error);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font: inherit;
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-danger:hover {
    background: #b91c1c;
  }

  .btn-danger:disabled {
    background: #999;
    cursor: not-allowed;
  }

  .field-open-to {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .field-open-to legend {
    margin-bottom: 0.5rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.95rem;
    color: #333;
    cursor: pointer;
  }

  .checkbox-label input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--color-dark);
    cursor: pointer;
    flex-shrink: 0;
  }

  @media (max-width: 520px) {
    .avatar-wrap {
      grid-template-columns: min-content 1fr;
    }

    .upload-status {
      grid-column: 1 / -1;
    }

    .footer-actions {
      grid-template-columns: 1fr;
      justify-content: stretch;
    }

    .profile-save-button {
      width: 100%;
      margin-left: 0;
    }

    .footer-actions .btn-outline {
      width: 100%;
    }

    .tag-suggestion-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>

<style is:global>
  @import "../styles/member-card.css";
</style>

<script>
  import { auth } from "../lib/firebase.ts";
  import {
    updateProfile,
    signOut,
    reauthenticateWithCredential,
    EmailAuthProvider,
  } from "firebase/auth";
  import { requireVerifiedAuth } from "../lib/auth.ts";
  import { uploadAvatar, deleteAvatar } from "../lib/storage.ts";
  import {
    getUser,
    updateUserProfile,
    deleteUserData,
    getTags,
    getOrCreateTag,
  } from "../lib/firestore.ts";
  import { validateBio, validateAvatar, resizeAvatar, normaliseUrl } from "../lib/validation.ts";

  let unsubscribeAuth: (() => void) | null = null;

  function updatePreview(
    name: string,
    role: string,
    bio: string,
    portfolio: string,
    photoURL: string
  ) {
    const previewName = document.getElementById("preview-name")!;
    const previewRole = document.getElementById("preview-role") as HTMLElement;
    const previewPortfolio = document.getElementById("preview-portfolio") as HTMLAnchorElement;
    const previewBio = document.getElementById("preview-bio") as HTMLElement;
    const previewAvatarImg = document.getElementById("preview-avatar-img") as HTMLImageElement;
    const previewAvatarPh = document.getElementById("preview-avatar-ph") as HTMLElement;

    const displayName = name || "Your name";
    previewName.textContent = displayName;

    if (role) {
      previewRole.textContent = role;
      previewRole.style.display = "";
    } else {
      previewRole.style.display = "none";
    }

    const href = normaliseUrl(portfolio);
    if (href) {
      previewPortfolio.href = href;
      previewPortfolio.textContent = portfolio;
      previewPortfolio.style.display = "";
    } else {
      previewPortfolio.style.display = "none";
    }

    if (bio) {
      previewBio.textContent = bio;
      previewBio.style.display = "";
    } else {
      previewBio.style.display = "none";
    }

    if (photoURL) {
      previewAvatarImg.src = photoURL;
      previewAvatarImg.alt = displayName;
      previewAvatarImg.style.display = "";
      previewAvatarPh.style.display = "none";
      previewAvatarImg.onerror = () => {
        previewAvatarImg.style.display = "none";
        previewAvatarPh.style.display = "";
        previewAvatarPh.textContent = displayName[0]?.toUpperCase() ?? "?";
      };
    } else {
      previewAvatarImg.style.display = "none";
      previewAvatarPh.style.display = "";
      previewAvatarPh.textContent = displayName[0]?.toUpperCase() ?? "?";
    }
  }

  document.addEventListener("astro:page-load", () => {
    const loadingEl = document.getElementById("loading");
    const form = document.getElementById("profile-form") as HTMLFormElement;
    if (!form) return;

    const nameInput = document.getElementById("name") as HTMLInputElement;
    const roleInput = document.getElementById("role") as HTMLInputElement;
    const bioInput = document.getElementById("bio") as HTMLTextAreaElement;
    const portfolioInput = document.getElementById("portfolio") as HTMLInputElement;
    const socialMediaInput = document.getElementById("social-media") as HTMLInputElement;
    const openToCheckboxes = document.querySelectorAll<HTMLInputElement>('input[name="open-to"]');
    const tagInput = document.getElementById("tag-input") as HTMLInputElement;
    const selectedTagsContainer = document.getElementById("selected-tags") as HTMLElement;
    const tagSuggestionsToggle = document.getElementById(
      "tag-suggestions-toggle"
    ) as HTMLButtonElement;
    const tagSuggestionPanel = document.getElementById("tag-suggestion-panel") as HTMLElement;
    const tagSuggestionList = document.getElementById("tag-suggestion-list") as HTMLElement;
    const phoneInput = document.getElementById("phone") as HTMLInputElement;
    const avatarInput = document.getElementById("avatar") as HTMLInputElement;
    const avatarImg = document.getElementById("avatar-preview") as HTMLImageElement;
    const uploadStatus = document.getElementById("upload-status")!;
    const saveMsg = document.getElementById("save-msg")!;
    const saveError = document.getElementById("save-error")!;

    const avatarWrap = avatarImg.closest<HTMLElement>(".avatar-wrap")!;

    let currentPhotoURL = "";
    let resizedAvatarBlob: Blob | null = null;
    let tags: string[] = [];
    let registryTags: Set<string> = new Set();
    let panelOpen = false;
    let autocompleteMatch: string | null = null;

    function setTagSuggestionsVisibility(isVisible: boolean) {
      panelOpen = isVisible;
      tagSuggestionPanel.hidden = !isVisible;
      tagSuggestionsToggle.setAttribute("aria-expanded", String(isVisible));
      tagSuggestionsToggle.textContent = isVisible ? "Hide tags" : "Browse tags";
    }

    tagSuggestionsToggle.addEventListener("click", () => {
      setTagSuggestionsVisibility(!panelOpen);
    });

    async function loadRegistryTags() {
      try {
        const tagDocs = await getTags();
        registryTags = new Set(tagDocs.map((t) => t.label));
        updateSuggestions("");
      } catch (err) {
        console.warn("Failed to load tag registry", err);
      }
    }

    function updateSuggestions(input: string) {
      renderTagSuggestions(input);
    }

    function normalizeTag(value: string): string {
      return value.trim().replace(/^#+/, "").replace(/\s+/g, " ");
    }

    function renderTags() {
      selectedTagsContainer.innerHTML = "";
      tags.forEach((tag) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className = "tag-chip";
        button.dataset.tag = tag;
        button.textContent = tag;

        const remove = document.createElement("span");
        remove.setAttribute("aria-hidden", "true");
        remove.textContent = "×";
        button.appendChild(remove);

        selectedTagsContainer.appendChild(button);
      });
    }

    function renderTagSuggestions(filter = "") {
      tagSuggestionList.innerHTML = "";
      const availableTags = Array.from(registryTags)
        .filter((tag) => !tags.some((selected) => selected.toLowerCase() === tag.toLowerCase()))
        .filter((tag) => !filter || tag.toLowerCase().includes(filter.toLowerCase()))
        .sort();

      availableTags.forEach((tag) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className = "tag-suggestion-chip";
        button.dataset.tag = tag;
        button.textContent = tag;
        tagSuggestionList.appendChild(button);
      });
    }

    async function addTag(value: string, userId: string): Promise<boolean> {
      const normalized = normalizeTag(value);
      if (!normalized || normalized.length > 50) return false;
      if (tags.length >= 7) return false;
      if (tags.some((existing) => existing.toLowerCase() === normalized.toLowerCase()))
        return false;

      try {
        await getOrCreateTag(normalized, userId);
        tags = [...tags, normalized];
        registryTags.add(normalized);
        renderTags();
        renderTagSuggestions();
        return true;
      } catch (err) {
        console.error("Failed to create tag", err);
        return false;
      }
    }

    tagInput.addEventListener("keydown", async (event) => {
      if (event.key === "Backspace" || event.key === "Delete") {
        if (autocompleteMatch) {
          event.preventDefault();
          const typed = tagInput.value.substring(0, tagInput.selectionStart ?? 0);
          autocompleteMatch = null;
          tagInput.value = typed;
          updateSuggestions(typed);
        }
        return;
      }
      if (event.key !== "Enter") return;
      event.preventDefault();
      const value = autocompleteMatch ?? tagInput.value;
      autocompleteMatch = null;
      if (!value.trim()) return;
      const user = auth.currentUser;
      if (!user) return;
      if (!(await addTag(value, user.uid))) {
        saveError.textContent = "Tags must be unique, 1–50 characters, and no more than 7 tags.";
        saveError.style.display = "block";
      } else {
        saveError.style.display = "none";
        tagInput.value = "";
        updateSuggestions("");
      }
    });

    tagInput.addEventListener("input", () => {
      const raw = tagInput.value;
      updateSuggestions(raw);
      const match = Array.from(registryTags)
        .filter((t) => !tags.some((s) => s.toLowerCase() === t.toLowerCase()))
        .find((t) => raw.length > 0 && t.toLowerCase().startsWith(raw.toLowerCase()));
      if (match) {
        autocompleteMatch = match;
        tagInput.value = match;
        tagInput.setSelectionRange(raw.length, match.length);
      } else {
        autocompleteMatch = null;
      }
    });

    tagSuggestionPanel.addEventListener("click", async (event) => {
      const button = (event.target as HTMLElement).closest(
        "button.tag-suggestion-chip"
      ) as HTMLButtonElement | null;
      if (!button) return;
      const tag = button.dataset.tag;
      const user = auth.currentUser;
      if (!tag || !user) return;

      if (await addTag(tag, user.uid)) {
        saveError.style.display = "none";
        tagInput.value = "";
        updateSuggestions("");
      }
    });

    selectedTagsContainer.addEventListener("click", (event) => {
      const button = (event.target as HTMLElement).closest(
        "button.tag-chip"
      ) as HTMLButtonElement | null;
      if (!button) return;
      const tag = button.dataset.tag;
      if (!tag) return;
      tags = tags.filter((existing) => existing !== tag);
      renderTags();
      updateSuggestions(tagInput.value);
    });

    function showPreview(url: string) {
      currentPhotoURL = url;
      avatarImg.src = url;
      avatarWrap.classList.toggle("has-image", !!url);
      avatarImg.onerror = () => {
        avatarWrap.classList.remove("has-image");
      };
      syncPreview();
    }

    function syncPreview() {
      updatePreview(
        nameInput.value.trim(),
        roleInput.value.trim(),
        bioInput.value.trim(),
        portfolioInput.value.trim(),
        currentPhotoURL
      );
    }

    nameInput.addEventListener("input", syncPreview);
    roleInput.addEventListener("input", syncPreview);
    bioInput.addEventListener("input", syncPreview);
    portfolioInput.addEventListener("input", syncPreview);

    avatarInput.addEventListener("change", async () => {
      const file = avatarInput.files?.[0];
      if (!file) return;

      const validation = validateAvatar(file);
      if (!validation.ok) {
        uploadStatus.textContent = validation.error!;
        uploadStatus.style.display = "block";
        resizedAvatarBlob = null;
        avatarInput.value = "";
        return;
      }

      uploadStatus.textContent = "Processing…";
      uploadStatus.style.display = "block";
      try {
        resizedAvatarBlob = await resizeAvatar(file);
        const previewUrl = URL.createObjectURL(resizedAvatarBlob);
        showPreview(previewUrl);
        uploadStatus.textContent = `Selected: ${file.name}`;
      } catch {
        uploadStatus.textContent = "Could not process image.";
        resizedAvatarBlob = null;
      }
    });

    unsubscribeAuth?.();
    unsubscribeAuth = requireVerifiedAuth(async (user) => {
      await loadRegistryTags();
      const data = await getUser(user.uid);

      nameInput.value = data.displayName ?? user.displayName ?? "";
      roleInput.value = data.role ?? "";
      bioInput.value = data.bio ?? "";
      portfolioInput.value = data.portfolio ?? "";
      socialMediaInput.value = data.socialMedia ?? "";
      const savedOpenTo = data.openTo ?? [];
      openToCheckboxes.forEach((cb) => {
        cb.checked = savedOpenTo.includes(cb.value);
      });
      tags = Array.isArray(data.tags) ? data.tags.filter(Boolean).slice(0, 7) : [];
      renderTags();
      phoneInput.value = data.phone ?? "";
      showPreview(data.photoURL ?? user.photoURL ?? "");

      if (loadingEl) loadingEl.style.display = "none";
      form.classList.add("is-loaded");
    });

    document.getElementById("btn-logout")!.addEventListener("click", async () => {
      await signOut(auth);
      window.location.href = "/";
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      saveMsg.style.display = "none";
      saveError.style.display = "none";

      const user = auth.currentUser;
      if (!user) return;

      const name = nameInput.value.trim();
      const role = roleInput.value.trim();
      const bio = bioInput.value.trim();
      const portfolio = portfolioInput.value.trim();
      const socialMedia = socialMediaInput.value.trim();
      const openTo = Array.from(openToCheckboxes)
        .filter((cb) => cb.checked)
        .map((cb) => cb.value);
      const phone = phoneInput.value.trim();
      const tagsPayload = tags;
      const bioResult = validateBio(bio);

      if (!bioResult.ok) {
        saveError.textContent = bioResult.error!;
        saveError.style.display = "block";
        return;
      }

      try {
        let photoURL: string = auth.currentUser?.photoURL ?? "";
        if (resizedAvatarBlob) {
          const avatarFile = new File([resizedAvatarBlob], "avatar.jpg", { type: "image/jpeg" });
          photoURL = await uploadAvatar(user.uid, avatarFile, (pct) => {
            uploadStatus.textContent = `Uploading… ${pct}%`;
            uploadStatus.style.display = "block";
          });
          uploadStatus.textContent = "Upload complete.";
        }

        await updateProfile(user, {
          displayName: name || null,
          photoURL: photoURL || null,
        });

        await user.getIdToken(true);
        await updateUserProfile(user.uid, {
          displayName: name,
          photoURL,
          role,
          bio,
          portfolio,
          socialMedia,
          openTo,
          tags: tagsPayload,
          phone,
          email: user.email!,
          updatedAt: new Date(),
        });

        // Trigger community page rebuild
        const ghToken = import.meta.env.PUBLIC_GITHUB_REBUILD_TOKEN;
        const ghOwner = import.meta.env.PUBLIC_GITHUB_OWNER;
        const ghRepo = import.meta.env.PUBLIC_GITHUB_REPO;
        if (ghToken && ghOwner && ghRepo) {
          try {
            const res = await fetch(
              `https://api.github.com/repos/${ghOwner}/${ghRepo}/actions/workflows/firebase-hosting-merge.yml/dispatches`,
              {
                method: "POST",
                headers: {
                  Authorization: `Bearer ${ghToken}`,
                  Accept: "application/vnd.github+json",
                  "X-GitHub-Api-Version": "2022-11-28",
                },
                body: JSON.stringify({ ref: "main" }),
              }
            );
            if (!res.ok) {
              const body = await res.text();
              console.error(`Rebuild trigger failed: ${res.status}`, body);
            }
          } catch (rebuildErr) {
            console.error("Rebuild trigger error:", rebuildErr);
          }
        } else {
          console.warn(
            "Rebuild skipped: missing PUBLIC_GITHUB_REBUILD_TOKEN / OWNER / REPO env vars"
          );
        }

        saveMsg.style.display = "block";
      } catch (err: unknown) {
        saveError.textContent = err instanceof Error ? err.message : "Could not save changes.";
        saveError.style.display = "block";
      }
    });

    // ── Delete account ──────────────────────────────────────────────
    const deleteIdle = document.getElementById("delete-idle")!;
    const deleteConfirm = document.getElementById("delete-confirm")!;
    const deleteReauth = document.getElementById("delete-reauth")!;
    const reauthInput = document.getElementById("reauth-password") as HTMLInputElement;
    const reauthError = document.getElementById("reauth-error")!;

    function showDeleteView(view: "idle" | "confirm" | "reauth") {
      deleteIdle.style.display = view === "idle" ? "block" : "none";
      deleteConfirm.style.display = view === "confirm" ? "block" : "none";
      deleteReauth.style.display = view === "reauth" ? "block" : "none";
    }

    async function performDelete() {
      const user = auth.currentUser;
      if (!user) return;
      const photoURL = user.photoURL ?? "";
      await deleteUserData(user.uid);
      await deleteAvatar(photoURL);
      await user.delete();
      window.location.href = "/";
    }

    document.getElementById("btn-delete-start")!.addEventListener("click", () => {
      showDeleteView("confirm");
    });

    document.getElementById("btn-delete-cancel")!.addEventListener("click", () => {
      showDeleteView("idle");
    });

    document.getElementById("btn-delete-confirm")!.addEventListener("click", async () => {
      const btn = document.getElementById("btn-delete-confirm") as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = "Deleting…";
      try {
        await performDelete();
      } catch (err: unknown) {
        const code =
          typeof err === "object" && err !== null && "code" in err
            ? String((err as { code: unknown }).code)
            : "";
        if (code === "auth/requires-recent-login") {
          showDeleteView("reauth");
        } else {
          btn.disabled = false;
          btn.textContent = "Delete my account";
        }
      }
    });

    document.getElementById("btn-reauth-cancel")!.addEventListener("click", () => {
      reauthInput.value = "";
      reauthError.style.display = "none";
      showDeleteView("idle");
    });

    document.getElementById("btn-reauth-confirm")!.addEventListener("click", async () => {
      const user = auth.currentUser;
      if (!user || !user.email) return;
      const btn = document.getElementById("btn-reauth-confirm") as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = "Confirming…";
      reauthError.style.display = "none";
      try {
        const credential = EmailAuthProvider.credential(user.email, reauthInput.value);
        await reauthenticateWithCredential(user, credential);
        await performDelete();
      } catch {
        reauthError.textContent = "Incorrect password. Please try again.";
        reauthError.style.display = "block";
        btn.disabled = false;
        btn.textContent = "Confirm delete";
      }
    });
  });
</script>
