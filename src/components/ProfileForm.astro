---
import MemberCard from "./MemberCard.astro";
import OpenToSelector from "./OpenToSelector.astro";
import TagSelector from "./TagSelector.astro";
import { useTranslations } from "../i18n/utils";
import type { Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}
const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
---

<div id="loading" class="loading-state">{t("profile.loading")}</div>

<form id="profile-form" class="profile-form" data-lang={lang}>
  <div class="avatar-wrap">
    <div class="avatar-image">
      <img id="avatar-preview" src="" alt="" class="avatar-img" />
      <div id="avatar-placeholder" class="avatar-placeholder">?</div>
    </div>
    <label class="btn-outline choose-img" for="avatar">
      {t("profile.chooseImage")}
      <input id="avatar" type="file" accept="image/*" style="display:none;" />
    </label>
    <p id="upload-status" class="upload-status" style="display:none;"></p>
  </div>

  <div class="field">
    <label class="label" for="name">{t("profile.label.name")}</label>
    <input id="name" type="text" class="input" placeholder={t("profile.ph.name")} />
  </div>

  <div class="field">
    <label class="label" for="role">{t("profile.label.role")}</label>
    <input id="role" type="text" class="input" placeholder={t("profile.ph.role")} />
  </div>

  <div class="field">
    <label class="label" for="bio">{t("profile.label.bio")}</label>
    <textarea id="bio" rows="4" class="input textarea" placeholder={t("profile.ph.bio")}></textarea>
    <p class="field-note">{t("profile.note.bio")}</p>
  </div>

  <div class="field">
    <label class="label" for="portfolio">{t("profile.label.portfolio")}</label>
    <div class="input-prefix-wrap">
      <span class="input-prefix">https://</span>
      <input
        id="portfolio"
        type="text"
        class="input input-prefixed"
        placeholder={t("profile.ph.portfolio")}
      />
    </div>
  </div>

  <div class="field">
    <label class="label" for="social-media">{t("profile.label.social")}</label>
    <div class="input-prefix-wrap">
      <span class="input-prefix">https://</span>
      <input
        id="social-media"
        type="text"
        class="input input-prefixed"
        placeholder={t("profile.ph.social")}
      />
    </div>
    <p class="field-note">{t("profile.note.social")}</p>
  </div>

  <OpenToSelector lang={lang} />

  <fieldset class="target-audience-field">
    <legend class="label">{t("profile.primaryAudience.legend")}</legend>
    <div class="target-audience-options">
      <label class="target-audience-option">
        <input type="checkbox" name="primary-audience" value="science" />
        <span>{t("profile.primaryAudience.science")}</span>
      </label>
      <label class="target-audience-option">
        <input type="checkbox" name="primary-audience" value="public" />
        <span>{t("profile.primaryAudience.public")}</span>
      </label>
      <label class="target-audience-option">
        <input type="checkbox" name="primary-audience" value="policy-makers" />
        <span>{t("profile.primaryAudience.policyMakers")}</span>
      </label>
      <label class="target-audience-option">
        <input type="checkbox" name="primary-audience" value="education" />
        <span>{t("profile.primaryAudience.education")}</span>
      </label>
    </div>
  </fieldset>

  <div class="field">
    <label class="label" for="tag-input">{t("profile.label.tags")}</label>
    <TagSelector lang={lang} maxTags={7} inputId="tag-input" />
  </div>

  <div class="field">
    <label class="label" for="phone">{t("profile.label.phone")}</label>
    <input id="phone" type="tel" class="input" placeholder="+41 79 123 45 67" autocomplete="tel" />
    <p class="field-note">
      {t("profile.note.phone")}
    </p>
  </div>

  <div class="preview-section">
    <p class="label">{t("profile.cardPreview")}</p>
    <MemberCard preview lang={lang} />
  </div>

  <div class="form-footer">
    <p id="save-msg" class="msg-ok" style="display:none;">
      {t("profile.saveMsg")}
    </p>
    <p id="save-error" class="msg-err" style="display:none;"></p>
    <div class="footer-actions">
      <button id="btn-logout" type="button" class="btn-outline">{t("profile.logout")}</button>
      <button type="submit" class="btn-solid profile-save-button">{t("profile.save")}</button>
    </div>
  </div>

  <div class="danger-zone">
    <div id="delete-idle">
      <button type="button" id="btn-delete-start" class="btn-danger-link"
        >{t("profile.delete.idle")}</button
      >
    </div>

    <div id="delete-confirm" style="display:none;">
      <p class="danger-text">
        {t("profile.delete.text")}
      </p>
      <div class="danger-actions">
        <button type="button" id="btn-delete-cancel" class="btn-link"
          >{t("profile.delete.cancel")}</button
        >
        <button type="button" id="btn-delete-confirm" class="btn-danger"
          >{t("profile.delete.confirm")}</button
        >
      </div>
    </div>

    <div id="delete-reauth" style="display:none;">
      <p class="danger-text">{t("profile.reauth.text")}</p>
      <input
        id="reauth-password"
        type="password"
        class="input"
        placeholder="••••••••"
        autocomplete="current-password"
      />
      <p id="reauth-error" class="msg-err" style="display:none;"></p>
      <div class="danger-actions">
        <button type="button" id="btn-reauth-cancel" class="btn-link"
          >{t("profile.reauth.cancel")}</button
        >
        <button type="button" id="btn-reauth-confirm" class="btn-danger"
          >{t("profile.reauth.confirm")}</button
        >
      </div>
    </div>
  </div>
</form>

<div id="verify-banner" class="verify-banner" style="display:none;">
  <p class="verify-banner-text">
    {t("profile.verifyBanner")}
    <button id="btn-resend-verify" type="button" class="btn-resend-verify"
      >{t("profile.verifyResend")}</button
    >
  </p>
  <p id="verify-banner-sent" class="verify-banner-sent" style="display:none;">
    {t("profile.verifySent")}
  </p>
</div>

<style>
  .loading-state {
    margin-top: 3rem;
    color: #999;
    font-size: 0.9rem;
  }

  .verify-banner {
    width: 100%;
    max-width: 560px;
    margin: 0 auto clamp(1.5rem, 3vw, 2.5rem);
    padding: 0.75rem 1rem;
    background: #fffbeb;
    border: 1.5px solid #f59e0b;
    border-radius: var(--radius-sm);
    box-sizing: border-box;

    @media (--bp-desktop) {
      padding: 0.75rem 1rem;
    }
  }

  .verify-banner-text {
    margin: 0;
    font-size: 0.88rem;
    color: #92400e;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-resend-verify {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 600;
    color: #92400e;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .btn-resend-verify:hover {
    color: #78350f;
  }

  .verify-banner-sent {
    margin: 0.4rem 0 0;
    font-size: 0.82rem;
    color: #65a30d;
  }

  .profile-form {
    display: none;
    grid-auto-rows: min-content;
    gap: 2rem;
    width: 100%;
    max-width: 560px;
    margin: clamp(2rem, 4vw, 4rem) auto;
    padding: 0 15px;
    box-sizing: border-box;
    overflow: hidden;

    @media (--bp-desktop) {
      padding: 0;
      gap: 2.5rem;
    }
  }

  .profile-form.is-loaded {
    display: grid;
  }

  .avatar-wrap {
    position: relative;
    display: grid;
    grid-template-columns: min-content 1fr 1fr;
    justify-items: start;
    align-items: center;
    gap: 25px;
    flex-shrink: 0;
  }

  .avatar-img,
  .avatar-placeholder {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
  }

  /* default: show placeholder, hide image */
  .avatar-img {
    display: none;
  }

  /* has-image: show image, hide placeholder */
  .avatar-wrap.has-image .avatar-img {
    display: block;
  }
  .avatar-wrap.has-image .avatar-placeholder {
    display: none;
  }

  .avatar-placeholder {
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: #bbb;
    border: 1.5px solid #e5e5e5;
  }
  .choose-img {
    width: fit-content;
  }

  .form-title {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-dark);
  }
  .form-sub {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-top: 0.2rem;
  }

  .divider {
    border: none;
    border-top: 1px solid #eee;
    margin: 0;
  }

  .field-note {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--color-muted);
  }

  .input-prefix-wrap {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: border-color 0.15s;
    min-width: 0;
  }
  .input-prefix-wrap:focus-within {
    border-color: #111;
  }

  .input-prefix {
    padding: 8px 10px;
    background: #f5f5f5;
    color: var(--color-muted);
    font-size: 0.88rem;
    border-right: 1.5px solid var(--color-border);
    white-space: nowrap;
  }

  .input-prefixed {
    border: none;
    border-radius: 0;
    flex: 1;
    min-width: 0;
  }
  .input-prefixed:focus {
    border-color: transparent;
  }

  .preview-section {
    padding-top: 0.5rem;
    padding-bottom: 7rem;
  }

  .preview-section .label {
    display: block;
    margin-bottom: 0.75rem;
  }

  .form-footer {
    padding-top: 25px;
  }

  .footer-actions {
    display: grid;
    gap: 15px;
    grid-template-columns: auto auto;
    justify-content: space-between;
  }

  .profile-save-button {
    margin-left: auto;
  }

  .danger-zone {
    padding-top: 2rem;
    border-top: 1px solid #f0f0f0;
  }

  .danger-text {
    font-size: 0.88rem;
    color: var(--color-muted);
    margin: 0 0 1rem;
    line-height: 1.5;
  }

  .danger-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .btn-danger-link {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    font-size: 0.88rem;
    color: #bbb;
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .btn-danger-link:hover {
    color: var(--color-error);
    border-bottom-color: var(--color-error);
  }

  .btn-danger {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.25rem;
    background: var(--color-error);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font: inherit;
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-danger:hover {
    background: #b91c1c;
  }

  .btn-danger:disabled {
    background: #999;
    cursor: not-allowed;
  }

  .field-open-to {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .field-open-to legend {
    margin-bottom: 0.5rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.95rem;
    color: #333;
    cursor: pointer;
  }

  .checkbox-label input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--color-dark);
    cursor: pointer;
    flex-shrink: 0;
  }

  .target-audience-field {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .target-audience-options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .target-audience-option {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.75rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: #fff;
    color: #333;
    font-size: 0.9rem;
    line-height: 1.2;
    cursor: pointer;
    transition:
      border-color 0.15s,
      background 0.15s;
  }

  .target-audience-option:hover {
    border-color: #999;
    background: #f5f5f5;
  }

  .target-audience-option:has(input:checked) {
    border-color: var(--color-dark);
    background: var(--color-dark);
    color: #fff;
  }

  .target-audience-option input {
    width: 14px;
    height: 14px;
    accent-color: var(--color-dark);
    cursor: pointer;
  }

  @media (max-width: 520px) {
    .avatar-wrap {
      grid-template-columns: min-content 1fr;
    }

    .upload-status {
      grid-column: 1 / -1;
    }

    .footer-actions {
      grid-template-columns: 1fr;
      justify-content: stretch;
    }

    .profile-save-button {
      width: 100%;
      margin-left: 0;
    }

    .footer-actions .btn-outline {
      width: 100%;
    }
  }
</style>

<script>
  import { auth } from "../lib/firebase.ts";
  import {
    signOut,
    reauthenticateWithCredential,
    EmailAuthProvider,
    sendEmailVerification,
  } from "firebase/auth";
  import { requireAuth } from "../lib/auth.ts";
  import { deleteAvatar } from "../lib/storage.ts";
  import { getUser, deleteUserData } from "../lib/firestore.ts";
  import { validateAvatar, resizeAvatar, normaliseUrl } from "../lib/validation.ts";
  import { handleProfileUpdate, triggerRebuild } from "../lib/profile.ts";
  import { ui } from "../i18n/translations.ts";

  let unsubscribeAuth: (() => void) | null = null;

  function updatePreview(
    name: string,
    role: string,
    bio: string,
    portfolio: string,
    socialMedia: string,
    photoURL: string,
    defaultName = "Your name",
    showBioLabel = "Show bio for"
  ) {
    const previewName = document.getElementById("preview-name")!;
    const previewRole = document.getElementById("preview-role") as HTMLElement;
    const previewLinks = document.getElementById("preview-links") as HTMLElement;
    const previewPortfolio = document.getElementById("preview-portfolio") as HTMLAnchorElement;
    const previewLinksSep = document.getElementById("preview-links-sep") as HTMLElement;
    const previewSocial = document.getElementById("preview-social") as HTMLAnchorElement;
    const previewBio = document.getElementById("preview-bio") as HTMLElement;
    const previewBioToggle = document.getElementById("preview-bio-toggle") as HTMLButtonElement;
    const previewAvatarImg = document.getElementById("preview-avatar-img") as HTMLImageElement;
    const previewAvatarPh = document.getElementById("preview-avatar-ph") as HTMLElement;

    const displayName = name || defaultName;
    previewName.textContent = displayName;

    if (role) {
      previewRole.textContent = role;
      previewRole.hidden = false;
    } else {
      previewRole.hidden = true;
    }

    const href = normaliseUrl(portfolio);
    if (href) {
      previewPortfolio.href = href;
      previewPortfolio.textContent = portfolio;
      previewPortfolio.hidden = false;
    } else {
      previewPortfolio.hidden = true;
    }

    const socialHref = normaliseUrl(socialMedia);
    if (socialHref) {
      previewSocial.href = socialHref;
      previewSocial.hidden = false;
    } else {
      previewSocial.hidden = true;
    }

    previewLinksSep.hidden = !href || !socialHref;
    previewLinks.hidden = !href && !socialHref;

    if (bio) {
      previewBio.textContent = bio;
      previewBio.hidden = false;
      previewBioToggle.hidden = false;
      previewBioToggle.setAttribute("aria-label", `${showBioLabel} ${displayName}`);
    } else {
      previewBio.hidden = true;
      previewBioToggle.hidden = true;
      previewBioToggle.closest(".member-card-wrap")?.classList.remove("is-expanded");
      previewBioToggle.setAttribute("aria-expanded", "false");
    }

    if (photoURL) {
      previewAvatarImg.src = photoURL;
      previewAvatarImg.alt = displayName;
      previewAvatarImg.hidden = false;
      previewAvatarPh.hidden = true;
      previewAvatarImg.onerror = () => {
        previewAvatarImg.hidden = true;
        previewAvatarPh.hidden = false;
        previewAvatarPh.textContent = displayName[0]?.toUpperCase() ?? "?";
      };
    } else {
      previewAvatarImg.hidden = true;
      previewAvatarPh.hidden = false;
      previewAvatarPh.textContent = displayName[0]?.toUpperCase() ?? "?";
    }
  }

  document.addEventListener("astro:page-load", () => {
    const loadingEl = document.getElementById("loading");
    const form = document.getElementById("profile-form") as HTMLFormElement;
    if (!form) return;

    const lang = (form.dataset.lang ?? "en") as keyof typeof ui;
    const s = ui[lang] ?? ui.en;
    const prefix = lang === "de" ? "/de" : "";

    const nameInput = document.getElementById("name") as HTMLInputElement;
    const roleInput = document.getElementById("role") as HTMLInputElement;
    const bioInput = document.getElementById("bio") as HTMLTextAreaElement;
    const portfolioInput = document.getElementById("portfolio") as HTMLInputElement;
    const socialMediaInput = document.getElementById("social-media") as HTMLInputElement;
    const phoneInput = document.getElementById("phone") as HTMLInputElement;
    const primaryAudienceInputs = Array.from(
      document.querySelectorAll<HTMLInputElement>('input[name="primary-audience"]')
    );
    const avatarInput = document.getElementById("avatar") as HTMLInputElement;
    const avatarImg = document.getElementById("avatar-preview") as HTMLImageElement;
    const uploadStatus = document.getElementById("upload-status")!;
    const saveMsg = document.getElementById("save-msg")!;
    const saveError = document.getElementById("save-error")!;

    const avatarWrap = avatarImg.closest<HTMLElement>(".avatar-wrap")!;

    // Tag selection is handled by the <tag-selector> custom element.
    const tagSelector = document.querySelector<
      HTMLElement & {
        value: string[];
        inputValue: string;
      }
    >("tag-selector");
    const openToSelector = document.querySelector<
      HTMLElement & {
        value: string[];
      }
    >("open-to-selector");

    let currentPhotoURL = "";
    let resizedAvatarBlob: Blob | null = null;

    function getSelectedPrimaryAudiences() {
      return primaryAudienceInputs.filter((input) => input.checked).map((input) => input.value);
    }

    function setSelectedPrimaryAudiences(value: unknown) {
      const selected = Array.isArray(value) ? value.filter(Boolean).map(String) : [];
      primaryAudienceInputs.forEach((input) => {
        input.checked = selected.includes(input.value);
      });
    }

    function showPreview(url: string) {
      currentPhotoURL = url;
      avatarImg.src = url;
      avatarWrap.classList.toggle("has-image", !!url);
      avatarImg.onerror = () => {
        avatarWrap.classList.remove("has-image");
      };
      syncPreview();
    }

    function syncPreview() {
      updatePreview(
        nameInput.value.trim(),
        roleInput.value.trim(),
        bioInput.value.trim(),
        portfolioInput.value.trim(),
        socialMediaInput.value.trim(),
        currentPhotoURL,
        s["profile.preview.defaultName"],
        s["member.showBio"]
      );
    }

    nameInput.addEventListener("input", syncPreview);
    roleInput.addEventListener("input", syncPreview);
    bioInput.addEventListener("input", syncPreview);
    portfolioInput.addEventListener("input", syncPreview);
    socialMediaInput.addEventListener("input", syncPreview);

    avatarInput.addEventListener("change", async () => {
      const file = avatarInput.files?.[0];
      if (!file) return;

      const validation = validateAvatar(file);
      if (!validation.ok) {
        uploadStatus.textContent = validation.error!;
        uploadStatus.style.display = "block";
        resizedAvatarBlob = null;
        avatarInput.value = "";
        return;
      }

      uploadStatus.textContent = s["profile.upload.processing"];
      uploadStatus.style.display = "block";
      try {
        resizedAvatarBlob = await resizeAvatar(file);
        const previewUrl = URL.createObjectURL(resizedAvatarBlob);
        showPreview(previewUrl);
        uploadStatus.textContent = `${s["profile.upload.selected"]}${file.name}`;
      } catch {
        uploadStatus.textContent = s["profile.upload.error"];
        resizedAvatarBlob = null;
      }
    });

    unsubscribeAuth?.();
    unsubscribeAuth = requireAuth(async (user) => {
      const verifyBanner = document.getElementById("verify-banner")!;
      const btnResendVerify = document.getElementById("btn-resend-verify") as HTMLButtonElement;
      const verifyBannerSent = document.getElementById("verify-banner-sent")!;

      if (!user.emailVerified) {
        verifyBanner.style.display = "block";
        let resendCooldown = false;
        btnResendVerify.addEventListener("click", async () => {
          if (resendCooldown) return;
          resendCooldown = true;
          btnResendVerify.disabled = true;
          try {
            await sendEmailVerification(user);
            verifyBannerSent.style.display = "block";
          } catch {
            // silently fail — user can try again after cooldown
          }
          setTimeout(() => {
            resendCooldown = false;
            btnResendVerify.disabled = false;
          }, 30000);
        });
      }

      const data = await getUser(user.uid);

      nameInput.value = data.displayName ?? user.displayName ?? "";
      roleInput.value = data.role ?? "";
      bioInput.value = data.bio ?? "";
      portfolioInput.value = data.portfolio ?? "";
      socialMediaInput.value = data.socialMedia ?? "";
      if (openToSelector) {
        openToSelector.value = Array.isArray(data.openTo) ? data.openTo.filter(Boolean) : [];
      }
      if (tagSelector) {
        tagSelector.value = Array.isArray(data.tags) ? data.tags.filter(Boolean).slice(0, 7) : [];
      }
      setSelectedPrimaryAudiences(data.primaryAudiences ?? []);
      phoneInput.value = data.phone ?? "";
      showPreview(data.photoURL ?? user.photoURL ?? "");

      if (loadingEl) loadingEl.style.display = "none";
      form.classList.add("is-loaded");
    });

    document.getElementById("btn-logout")!.addEventListener("click", async () => {
      await signOut(auth);
      window.location.href = prefix || "/";
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      saveMsg.style.display = "none";
      saveError.style.display = "none";

      const user = auth.currentUser;
      if (!user) return;

      try {
        const { photoURL } = await handleProfileUpdate(
          user,
          {
            displayName: nameInput.value.trim(),
            role: roleInput.value.trim(),
            bio: bioInput.value.trim(),
            portfolio: portfolioInput.value.trim(),
            socialMedia: socialMediaInput.value.trim(),
            openTo: openToSelector?.value ?? [],
            primaryAudiences: getSelectedPrimaryAudiences(),
            tags: tagSelector?.value ?? [],
            phone: phoneInput.value.trim(),
            email: user.email!,
            resizedAvatarBlob,
          },
          (pct) => {
            uploadStatus.textContent = `${s["profile.upload.uploading"]} ${pct}%`;
            uploadStatus.style.display = "block";
          }
        );

        if (resizedAvatarBlob) {
          uploadStatus.textContent = s["profile.upload.complete"];
          currentPhotoURL = photoURL;
        }

        await triggerRebuild();
        saveMsg.style.display = "block";
      } catch (err: unknown) {
        saveError.textContent = err instanceof Error ? err.message : s["profile.save.error"];
        saveError.style.display = "block";
      }
    });

    // ── Delete account ──────────────────────────────────────────────
    const deleteIdle = document.getElementById("delete-idle")!;
    const deleteConfirm = document.getElementById("delete-confirm")!;
    const deleteReauth = document.getElementById("delete-reauth")!;
    const reauthInput = document.getElementById("reauth-password") as HTMLInputElement;
    const reauthError = document.getElementById("reauth-error")!;

    function showDeleteView(view: "idle" | "confirm" | "reauth") {
      deleteIdle.style.display = view === "idle" ? "block" : "none";
      deleteConfirm.style.display = view === "confirm" ? "block" : "none";
      deleteReauth.style.display = view === "reauth" ? "block" : "none";
    }

    async function performDelete() {
      const user = auth.currentUser;
      if (!user) return;
      const photoURL = user.photoURL ?? "";
      await deleteUserData(user.uid);
      await deleteAvatar(photoURL);
      await user.delete();
      window.location.href = prefix || "/";
    }

    document.getElementById("btn-delete-start")!.addEventListener("click", () => {
      showDeleteView("confirm");
    });

    document.getElementById("btn-delete-cancel")!.addEventListener("click", () => {
      showDeleteView("idle");
    });

    document.getElementById("btn-delete-confirm")!.addEventListener("click", async () => {
      const btn = document.getElementById("btn-delete-confirm") as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = s["profile.delete.deleting"];
      try {
        await performDelete();
      } catch (err: unknown) {
        const code =
          typeof err === "object" && err !== null && "code" in err
            ? String((err as { code: unknown }).code)
            : "";
        if (code === "auth/requires-recent-login") {
          showDeleteView("reauth");
        } else {
          btn.disabled = false;
          btn.textContent = s["profile.delete.confirm"];
        }
      }
    });

    document.getElementById("btn-reauth-cancel")!.addEventListener("click", () => {
      reauthInput.value = "";
      reauthError.style.display = "none";
      showDeleteView("idle");
    });

    document.getElementById("btn-reauth-confirm")!.addEventListener("click", async () => {
      const user = auth.currentUser;
      if (!user || !user.email) return;
      const btn = document.getElementById("btn-reauth-confirm") as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = s["profile.reauth.confirming"];
      reauthError.style.display = "none";
      try {
        const credential = EmailAuthProvider.credential(user.email, reauthInput.value);
        await reauthenticateWithCredential(user, credential);
        await performDelete();
      } catch {
        reauthError.textContent = s["profile.reauth.error"];
        reauthError.style.display = "block";
        btn.disabled = false;
        btn.textContent = s["profile.reauth.confirm"];
      }
    });
  });
</script>
