---
import type { PublicProfileDoc } from "../lib/firestore.ts";
import { normaliseUrl } from "../lib/validation.ts";
import downArrowUrl from "../assets/downarrow.svg";
import { useTranslations } from "../i18n/utils.ts";
import type { Lang } from "../i18n/utils.ts";

function stripStorageToken(url: string): string {
  if (!url) return url;
  try {
    const u = new URL(url);
    if (u.hostname === "firebasestorage.googleapis.com") {
      u.searchParams.delete("token");
      return u.toString();
    }
  } catch {
    // not a valid URL — return as-is
  }
  return url;
}

interface Props {
  member?: PublicProfileDoc & { uid: string };
  preview?: boolean;
  lang?: Lang;
}

const { member: m, preview = false, lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const displayName = m?.displayName || "Anonymous";
const portfolioHref = normaliseUrl(m?.portfolio ?? "");
const socialHref = normaliseUrl(m?.socialMedia ?? "");
const bioId = preview ? "preview-bio" : m ? `member-bio-${m.uid}` : undefined;
const avatarSrc = stripStorageToken(m?.photoURL ?? "");
---

<div class:list={["member-card-wrap", preview && "member-card-wrap--preview"]}>
  <article id={preview ? "preview-card" : undefined} class:list={["member-card", preview && "member-card--preview"]}>
    <div class="member-avatar-wrap">
      {preview ? (
        <>
          <img
            id="preview-avatar-img"
            class="member-avatar"
            src=""
            alt=""
            width="80"
            height="80"
            hidden
          />
          <div id="preview-avatar-ph" class="member-avatar member-avatar--placeholder">
            ?
          </div>
        </>
      ) : avatarSrc ? (
        <img
          class="member-avatar"
          src={avatarSrc}
          alt={displayName}
          width="80"
          height="80"
          loading="lazy"
        />
      ) : (
        <div class="member-avatar member-avatar--placeholder">
          {displayName[0]?.toUpperCase() ?? "?"}
        </div>
      )}
    </div>

    <div class="member-info">
      <div id={preview ? "preview-name" : undefined} class="member-name">{displayName}</div>
      {preview ? (
        <div id="preview-role" class="member-role" hidden />
      ) : (
        m?.role && <div class="member-role">{m.role}</div>
      )}
      {preview ? (
        <div id="preview-links" class="member-links" hidden>
          <a
            id="preview-portfolio"
            class="member-portfolio"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            hidden
          />
          <span id="preview-links-sep" class="member-links-sep" aria-hidden="true" hidden>
            |
          </span>
          <a
            id="preview-social"
            class="member-social"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            hidden
          >
            social
          </a>
        </div>
      ) : (
        (portfolioHref || socialHref) && (
          <div class="member-links">
            {portfolioHref && (
              <a
                class="member-portfolio"
                href={portfolioHref}
                target="_blank"
                rel="noopener noreferrer"
              >
                {(() => {
                  const p = (m?.portfolio ?? "").replace(/^www\./i, "");
                  const limit = socialHref ? 13 : 17;
                  return p.length > limit ? "portfolio" : p;
                })()}
              </a>
            )}
            {portfolioHref && socialHref && (
              <span class="member-links-sep" aria-hidden="true">
                |
              </span>
            )}
            {socialHref && (
              <a
                class="member-social"
                href={socialHref}
                target="_blank"
                rel="noopener noreferrer"
              >
                social
              </a>
            )}
          </div>
        )
      )}
    </div>

    {preview || m?.bio ? (
      <button
        id={preview ? "preview-bio-toggle" : undefined}
        class="member-bio-toggle"
        type="button"
        aria-expanded="false"
        aria-controls={bioId}
        aria-label={`${t('member.showBio')} ${displayName}`}
        hidden={preview}
      >
        <img class="member-bio-arrow" src={downArrowUrl.src} alt="" aria-hidden="true" />
      </button>
    ) : (
      <div aria-hidden="true" />
    )}
  </article>
  {(preview || m?.bio) && (
    <p id={bioId} class="member-bio" hidden={preview}>
      {m?.bio}
    </p>
  )}
</div>

<style is:global>
  .member-card {
    display: grid;
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    grid-template-columns: min-content minmax(0, 1fr) 16px;
    align-items: center;
    gap: 5px 20px;
    padding: 10px 15px 10px 20px;
    border: 1.5px solid #e8e8e8;
    border-radius: var(--radius-sm);
    background: #ffffff;
    transition:
      border-color 0.2s,
      filter 0.2s,
      border-bottom-right-radius 0.18s ease,
      border-bottom-left-radius 0.18s ease;
    text-align: center;
    align-self: start;

    @media (--bp-desktop) {
      grid-template-columns: min-content minmax(0, 1fr);
      padding: 15px 25px 15px 15px;
      gap: 5px 25px;
    }
  }

  .member-card:hover {
    border-color: var(--color-border);
  }

  @media (--bp-desktop), (--bp-desktop-wide) {
    .member-card-wrap:hover .member-card,
    .member-card-wrap:focus-within .member-card {
      filter: drop-shadow(0 4px 5px rgba(0, 0, 0, 0.07));
    }

    .member-card-wrap:has(.member-bio:not([hidden])):hover .member-card,
    .member-card-wrap:has(.member-bio:not([hidden])):focus-within .member-card {
      border-bottom-right-radius: 0;
      border-bottom-left-radius: 0;
    }
  }

  .member-card-wrap--preview {
    max-width: 360px;
  }

  .member-card-wrap [hidden] {
    display: none !important;
  }

  .member-avatar-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .member-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    align-items: center;
    justify-content: center;
    border: 1.5px solid #e5e5e5;
  }

  .member-avatar--placeholder {
    background: #f0f0f0;
    display: flex;
    font-size: 1.8rem;
    color: #bbb;
  }

  .member-info {
    display: grid;
    grid-template-rows: min-content min-content min-content;
    text-align: left;
    align-self: center;
    gap: 0.2rem;
    width: min-content;
    min-width: 0;
    padding-left: 20px;
  }

  @media (--bp-desktop) {
    .member-info {
      padding-left: 5px;
    }
  }
  .member-name {
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-dark);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    width: min-content;
  }

  .member-role {
    font-size: 0.78rem;
    color: var(--color-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 24ch;
    width: min-content;
  }

  .member-links {
    display: flex;
    align-items: baseline;
    flex-wrap: nowrap;
    gap: 0.35rem;
    margin-top: 0.4rem;
    min-width: 0;
    width: max-content;
  }

  .member-links-sep {
    color: #ccc;
    font-size: 0.78rem;
    flex-shrink: 0;
  }

  .member-portfolio,
  .member-social {
    color: black;
    text-decoration: underline;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
    transition: color 0.15s;
  }

  .member-portfolio:hover,
  .member-social:hover {
    color: #000;
  }

  .member-bio-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 24px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    transition:
      color 0.15s,
      transform 0.15s;
  }

  .member-bio-toggle:hover {
    color: #333;
  }

  .member-bio-arrow {
    display: block;
    width: 12px;
    height: 12px;
  }

  .member-card-wrap.is-expanded .member-bio-toggle {
    transform: rotate(180deg);
  }

  .member-bio {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    margin: -1.5px 0 0 0;
    padding: 0 15px 0 20px;
    border: 1.5px solid #e8e8e8;
    border-top: 0;
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
    background: #ffffff;
    transition:
      max-height 0.3s ease,
      opacity 0.2s ease,
      padding-top 0.2s ease,
      padding-bottom 0.2s ease;
    color: #444;
    font-size: var(--font-size-base);
    line-height: 1.6;
    text-align: left;
  }

  .member-card-wrap.is-expanded .member-card {
    border-bottom-right-radius: 0;
    border-bottom-left-radius: 0;
  }

  .member-card-wrap.is-expanded .member-bio:not([hidden]) {
    max-height: 200px;
    opacity: 1;
    padding-top: 8px;
    padding-bottom: 8px;
  }

  @media (--bp-desktop), (--bp-desktop-wide) {
    .member-card-wrap {
      position: relative;
    }

    .member-bio-toggle {
      display: none;
    }

    /* Desktop: fade + slide from above */
    .member-bio {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      z-index: 5;
      overflow: visible;
      max-height: none;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-6px);
      transition:
        opacity 0.18s ease,
        transform 0.18s ease,
        visibility 0.18s;
      box-sizing: border-box;
      margin: -1.5px 0 0 0;
      padding: 25px;
      border: 1.5px solid var(--color-border);
      border-top: 0;
      border-radius: 0 0 var(--radius-sm) var(--radius-sm);
      background: #ffffff;
    }

    .member-card-wrap:hover .member-bio:not([hidden]),
    .member-card-wrap:focus-within .member-bio:not([hidden]) {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .member-grid .member-card-wrap:hover {
      z-index: 10;
    }
  }
</style>

<script>
  import { ui } from "../i18n/translations.ts";

  const desktopQuery = window.matchMedia("(width >= 1120px)");
  let hasDesktopQueryListener = false;

  function collapseMobileBioPanels() {
    document.querySelectorAll(".member-card-wrap.is-expanded").forEach((wrap) => {
      wrap.classList.remove("is-expanded");
    });
    document.querySelectorAll<HTMLButtonElement>(".member-bio-toggle").forEach((button) => {
      button.setAttribute("aria-expanded", "false");
    });
  }

  function getCardLanguage(toggle: HTMLButtonElement): "en" | "de" {
    const scoped = toggle.closest<HTMLElement>("[data-lang]")?.dataset.lang;
    const pageLang = document.documentElement.lang;
    return scoped === "de" || pageLang === "de" ? "de" : "en";
  }

  function wireBioToggles() {
    document.querySelectorAll<HTMLButtonElement>(".member-bio-toggle").forEach((toggle) => {
      if (toggle.dataset.bioToggleWired === "true") return;
      toggle.dataset.bioToggleWired = "true";
      toggle.addEventListener("click", () => {
        const wrap = toggle.closest(".member-card-wrap");
        if (!wrap) return;
        const expanded = wrap.classList.toggle("is-expanded");
        toggle.setAttribute("aria-expanded", String(expanded));
        const name = wrap.querySelector(".member-name")?.textContent ?? "";
        const strings = ui[getCardLanguage(toggle)];
        const label = expanded ? strings["member.hideBio"] : strings["member.showBio"];
        toggle.setAttribute("aria-label", `${label} ${name}`);
      });
    });
  }

  document.addEventListener("astro:page-load", () => {
    if (!hasDesktopQueryListener) {
      desktopQuery.addEventListener("change", (event) => {
        if (!event.matches) collapseMobileBioPanels();
      });
      hasDesktopQueryListener = true;
    }
    wireBioToggles();
  });
</script>
