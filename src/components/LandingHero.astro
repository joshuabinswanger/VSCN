---
import { useTranslations } from "../i18n/utils.ts";
import type { Lang } from "../i18n/utils.ts";

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<div class="wrapper" data-lang={lang}>
  <div class="content">
    <p class="desc">
      <strong>VSCN</strong>{t('hero.tagline')}<br /><br />{t('hero.invite')}
    </p>
    <div class="actions">
      <a id="hero-cta" href="/signup" class="btn-solid btn-join">{t('hero.cta.join')}</a>
    </div>
  </div>
</div>

<style>
  .wrapper {
    display: grid;
    grid-template-columns: 1fr;
    justify-items: center;
    align-items: center;
    padding-top: 145px;
  }
  .content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 1.5rem;
    padding: clamp(2rem, 6vw, 7rem);
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem 2.25rem;
    max-width: 520px;
    width: 100%;
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1.5px solid rgba(0, 0, 0, 0.07);
    border-radius: var(--radius-xl);
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.06);
  }

  .desc {
    max-width: 680px;
    font-weight: 400;
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    color: #111;
    line-height: 1.8;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  @media (--bp-desktop) {
    .content {
      align-items: center;
      padding: 1.5rem;
      width: fit-content;
    }

    .actions {
      align-self: flex-start;
    }
  }
</style>

<script>
  import { onAuthStateChanged } from "firebase/auth";
  import { auth } from "../lib/firebase.ts";
  import { ui } from "../i18n/translations.ts";

  let unsubscribeAuth: (() => void) | null = null;

  document.addEventListener("astro:page-load", () => {
    const cta = document.getElementById("hero-cta") as HTMLAnchorElement | null;
    if (!cta) return;

    const wrapper = document.querySelector<HTMLElement>(".wrapper[data-lang]");
    const lang = (wrapper?.dataset.lang ?? "en") as "en" | "de";
    const prefix = lang === "de" ? "/de" : "";
    const strings = ui[lang];

    unsubscribeAuth?.();
    unsubscribeAuth = onAuthStateChanged(auth, (user) => {
      cta.href = user ? `${prefix}/community` : `${prefix}/signup`;
      cta.textContent = user ? strings["hero.cta.community"] : strings["hero.cta.join"];
    });
  });
</script>
