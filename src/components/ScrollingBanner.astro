<div class="scrolling-banner" aria-label="Visual Science Communication Network">
  <div class="scrolling-banner__track" aria-hidden="true">
    <span class="scrolling-banner__item"
      >Visual Science Communication Network&ensp;&mdash;&ensp;VSCN&thinsp;&mdash;&thinsp;</span
    >
    <span class="scrolling-banner__item"
      >Visual Science Communication Network&ensp;&mdash;&ensp;VSCN&thinsp;&mdash;&thinsp;</span
    >
  </div>
</div>

<style>
  .scrolling-banner {
    width: 100%;
    overflow: hidden;
    white-space: nowrap;
  }

  .scrolling-banner__track {
    display: inline-flex;
    animation: scroll-banner 80s linear 1s infinite;
    font-family: "Archivo", sans-serif;
    font-size: clamp(2.5rem, 10.4vw, 8rem);
    font-weight: 800;
    line-height: 0.95;
    color: var(--color-dark);
    white-space: nowrap;
  }

  .scrolling-banner__item {
    display: inline-block;
  }

  @keyframes scroll-banner {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (--bp-mobile) {
    .scrolling-banner__track {
      animation-duration: 40s;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scrolling-banner__track {
      animation-play-state: paused;
    }
  }
</style>
