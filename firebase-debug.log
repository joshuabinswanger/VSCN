[debug] [2026-05-16T11:36:11.815Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/vscn-39508/rulesets {"name":"projects/vscn-39508/rulesets/ac0d19a0-a035-4250-8a25-00707495413a","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    match /tags/{slug} {\n      // Public tag registry. Readable by everyone.\n      allow read: if true;\n\n      allow create, update: if request.auth != null\n                            && request.auth.token.email_verified == true\n                            && validTag(request.resource.data);\n\n      allow delete: if false;\n    }\n\n    match /openTo/{id} {\n      // Public registry of 'Open To' options.\n      allow read: if true;\n      allow write: if false;\n    }\n\n    match /publicProfiles/{uid} {\n      // Public directory data only. Never store phone numbers or emails here.\n      allow read: if true;\n\n      allow create, update: if request.auth != null\n                            && request.auth.uid == uid\n                            && validPublicProfile(request.resource.data);\n\n      allow delete: if request.auth != null && request.auth.uid == uid;\n    }\n\n    match /users/{uid} {\n      // Private owner profile data. Contains email and phone.\n      allow read: if request.auth != null && request.auth.uid == uid;\n\n      allow create, update: if request.auth != null\n                            && request.auth.uid == uid\n                            && validPrivateUser(request.resource.data, request.auth);\n\n      allow delete: if request.auth != null && request.auth.uid == uid;\n    }\n\n    match /onboardingRequests/{uid} {\n      // Private onboarding feedback. Users can only access their own request.\n      allow get: if request.auth != null && request.auth.uid == uid;\n      allow list: if false;\n\n      allow create, update: if request.auth != null\n                            && request.auth.uid == uid\n                            && validOnboardingRequest(request.resource.data, request.auth);\n\n      allow delete: if false;\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n\nfunction validPublicProfile(data) {\n  let allowedKeys = ['displayName', 'photoURL', 'role', 'bio', 'portfolio', 'socialMedia', 'openTo', 'primaryAudiences', 'tags', 'active', 'createdAt', 'updatedAt'];\n\n  return data.keys().hasOnly(allowedKeys)\n    && validPublicFields(data);\n}\n\nfunction validPrivateUser(data, auth) {\n  let allowedKeys = ['displayName', 'photoURL', 'role', 'bio', 'portfolio', 'socialMedia', 'openTo', 'primaryAudiences', 'tags', 'phone', 'email', 'communityGoals', 'onboardingComplete', 'createdAt', 'updatedAt'];\n\n  return data.keys().hasOnly(allowedKeys)\n    && validPublicFields(data)\n    && (!('phone' in data) || (data.phone is string && data.phone.size() <= 40))\n    && (!('email' in data) || data.email == auth.token.email)\n    && (!('communityGoals' in data) || data.communityGoals is list)\n    && (!('onboardingComplete' in data) || data.onboardingComplete is bool);\n}\n\nfunction validPublicFields(data) {\n  return (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))\n    && (!('bio' in data) || (data.bio is string\n                             && data.bio.size() <= 500\n                             && validBioWordCount(data.bio)))\n    && (!('role' in data) || (data.role is string && data.role.size() <= 100))\n    && (!('portfolio' in data) || (data.portfolio is string && data.portfolio.size() <= 200))\n    && (!('socialMedia' in data) || (data.socialMedia is string && data.socialMedia.size() <= 200))\n    && (!('openTo' in data) || (data.openTo is list && data.openTo.size() <= 5))\n    && (!('primaryAudiences' in data) || validPrimaryAudiences(data.primaryAudiences))\n    && (!('tags' in data) || (data.tags is list && data.tags.size() <= 7))\n    && (!('active' in data) || data.active is bool)\n    && (!('photoURL' in data) || data.photoURL == ''\n        || data.photoURL.matches('https://firebasestorage\\\\.googleapis\\\\.com/v0/b/vscn-39508\\\\.firebasestorage\\\\.app/.*')\n        || data.photoURL.matches('https://storage\\\\.googleapis\\\\.com/vscn-39508\\\\.firebasestorage\\\\.app/.*'))\n    && (!('createdAt' in data) || data.createdAt is timestamp)\n    && (!('updatedAt' in data) || data.updatedAt is timestamp);\n}\n\nfunction validPrimaryAudiences(value) {\n  return value is list\n    && value.size() <= 4\n    && (value.size() < 1 || validPrimaryAudienceValue(value[0]))\n    && (value.size() < 2 || validPrimaryAudienceValue(value[1]))\n    && (value.size() < 3 || validPrimaryAudienceValue(value[2]))\n    && (value.size() < 4 || validPrimaryAudienceValue(value[3]));\n}\n\nfunction validPrimaryAudienceValue(value) {\n  return value is string\n    && (value == 'science'\n        || value == 'public'\n        || value == 'policy-makers'\n        || value == 'education');\n}\n\nfunction validOnboardingRequest(data, auth) {\n  let allowedKeys = ['userId', 'message', 'lang', 'email', 'displayName', 'createdAt', 'updatedAt'];\n\n  return data.keys().hasOnly(allowedKeys)\n    && data.userId == auth.uid\n    && data.message is string\n    && data.message.size() > 0\n    && data.message.size() <= 1000\n    && data.lang is string\n    && (data.lang == 'en' || data.lang == 'de')\n    && (!('email' in data) || data.email == auth.token.email)\n    && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))\n    && (!('createdAt' in data) || data.createdAt is timestamp)\n    && (!('updatedAt' in data) || data.updatedAt is timestamp);\n}\n\nfunction validBioWordCount(bio) {\n  // Keep this regex in sync with MAX_BIO_WORDS in src/lib/validation.ts.\n  return bio.size() == 0 || bio.matches('^\\\\s*\\\\S+(\\\\s+\\\\S+){0,34}\\\\s*$');\n}\n\nfunction validTag(data) {\n  return data.label is string\n    && data.label.size() > 0\n    && data.label.size() <= 50\n    && data.createdAt is timestamp\n    && data.createdBy is string\n    && (!('active' in data) || data.active is bool)\n    && (!('group' in data) || data.group is string)\n    && (!('updatedAt' in data) || data.updatedAt is timestamp);\n}\n","name":"firestore.rules"}]},"createTime":"2026-05-16T11:36:12.066319Z","metadata":{"services":["cloud.firestore"]}}
