# Copy this file to .env and fill in your Firebase project values.
# Find these in: Firebase Console → Project Settings → Your Apps → SDK setup

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=
PUBLIC_FIREBASE_RECAPTCHA_SITE_KEY=

# Server-only: Firebase Admin service account JSON (one line, no newlines).
# Generate in: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT=
