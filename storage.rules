rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /avatars/{filename} {
      // Anyone can read avatars (needed to display them in the community page)
      allow read: if true;

      // Only authenticated, email-verified users can write their own avatar
      // The filename must be {uid}.{ext} — enforced by matching the uid segment
      allow write: if request.auth != null
                   && request.auth.token.email_verified == true
                   && filename.matches(request.auth.uid + '\\.[a-zA-Z]+')
                   && request.resource.size <= 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');

      // Only the owner can delete their own avatar
      allow delete: if request.auth != null
                    && filename.matches(request.auth.uid + '\\.[a-zA-Z]+');
    }

    // Reject everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
