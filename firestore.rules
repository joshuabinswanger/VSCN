rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /publicProfiles/{uid} {
      // Public directory data only. Never store phone numbers or emails here.
      allow read: if true;

      allow create, update: if request.auth != null
                            && request.auth.uid == uid
                            && request.auth.token.email_verified == true
                            && validPublicProfile(request.resource.data);

      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      // Private owner profile data. Contains email and phone.
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create, update: if request.auth != null
                            && request.auth.uid == uid
                            && validPrivateUser(request.resource.data, request.auth);

      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function validPublicProfile(data) {
  let allowedKeys = ['displayName', 'photoURL', 'role', 'bio', 'portfolio', 'socialMedia', 'openTo', 'active', 'createdAt', 'updatedAt'];

  return data.keys().hasOnly(allowedKeys)
    && validPublicFields(data);
}

function validPrivateUser(data, auth) {
  let allowedKeys = ['displayName', 'photoURL', 'role', 'bio', 'portfolio', 'socialMedia', 'openTo', 'phone', 'email', 'createdAt', 'updatedAt'];

  return data.keys().hasOnly(allowedKeys)
    && validPublicFields(data)
    && (!('phone' in data) || (data.phone is string && data.phone.size() <= 40))
    && (!('email' in data) || data.email == auth.token.email);
}

function validPublicFields(data) {
  return (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
    && (!('bio' in data) || (data.bio is string
                             && data.bio.size() <= 500
                             && validBioWordCount(data.bio)))
    && (!('role' in data) || (data.role is string && data.role.size() <= 100))
    && (!('portfolio' in data) || (data.portfolio is string && data.portfolio.size() <= 200))
    && (!('socialMedia' in data) || (data.socialMedia is string && data.socialMedia.size() <= 200))
    && (!('openTo' in data) || (data.openTo is list && data.openTo.size() <= 3 && data.openTo.hasOnly(['offering', 'seeking', 'networking'])))
    && (!('active' in data) || data.active is bool)
    && (!('photoURL' in data) || data.photoURL == ''
        || data.photoURL.matches('https://firebasestorage\\.googleapis\\.com/v0/b/vscn-39508\\.firebasestorage\\.app/.*')
        || data.photoURL.matches('https://storage\\.googleapis\\.com/vscn-39508\\.firebasestorage\\.app/.*'))
    && (!('createdAt' in data) || data.createdAt is timestamp)
    && (!('updatedAt' in data) || data.updatedAt is timestamp);
}

function validBioWordCount(bio) {
  // Keep this regex in sync with MAX_BIO_WORDS in src/lib/validation.ts.
  return bio.size() == 0 || bio.matches('^\\s*\\S+(\\s+\\S+){0,34}\\s*$');
}
